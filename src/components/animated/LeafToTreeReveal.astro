---
// Animated component 2/2, v4 — a pile of ~120 individually-animated leaves
// scatters outward as a tree emerges from the same spot, all scroll-
// scrubbed (see the big comment further down for why this mechanism was
// chosen over a trigger-once approach).
//
// v3 change from v2: the "leaves fly outward" stage no longer introduces
// a separate handful of new leaf elements after the tree appears — that
// duplicated effort and looked disconnected. Instead, the SAME pile
// leaves that were sitting there all along are what scatter outward, and
// they do it BEFORE/AS the tree appears, not after. Every leaf carries
// its own baked-in fly-out trajectory (direction, distance, spin,
// stagger delay) generated deterministically at build time — 120 unique
// paths, but only ONE shared "how far through the scatter are we"
// progress value is ever written by JS on scroll; each leaf's own CSS
// derives its individual timing/position from that single shared value
// via clamp()/calc(), which is why this scales to 120 leaves without 120
// separate property writes per scroll tick.
//
// v4 change from v3: doubled leaf count (60 -> 120) with a wider pile
// footprint to match, removed the flame/fire effect entirely (the three
// amber teardrop shapes were reading as leftover vertical yellow leaves,
// not fire), scaled the whole graphic 1.8x, and dropped the two
// desaturated/neutral colours (sand, sage) from the leaf palette in
// favour of more vibrant, on-brand greens plus amber.
interface Props {
  eyebrow?: string;
  heading?: string;
  text?: string;
}

const { eyebrow = 'Renewal', heading, text } = Astro.props;

// Deterministic PRNG (mulberry32) — same seed always produces the same
// pile layout, so SSR output doesn't shuffle between builds/requests.
function mulberry32(seed: number) {
  return function () {
    seed |= 0;
    seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const LEAF_COUNT = 120;
const VARIANTS = ['pointed', 'rounded', 'narrow'] as const;
// Vibrant, on-brand only — no --sand or --sage (both read as grey/neutral,
// which is exactly what was asked to remove). Mix of greens plus a warm
// amber for natural variety without going off-brand.
const COLORS = ['var(--leaf)', 'var(--ink-accent)', 'var(--signal)', 'var(--amber)', 'var(--ink-amber)'];

const rand = mulberry32(20260722); // fixed seed
const leaves = Array.from({ length: LEAF_COUNT }, (_, i) => {
  const r1 = rand();
  const r2 = rand();
  const r3 = rand();
  const r4 = rand();
  const r5 = rand();
  const r6 = rand();
  const r7 = rand();

  // Pile position — clustered around (120, 197), flattened vertically so
  // it reads as a low pile rather than a ball, denser near the centre.
  // Spread widened (was *40/*13) to match the doubled leaf count — 120
  // leaves in the old footprint would just be a denser clump, not a
  // visibly bigger pile.
  const angle = r1 * Math.PI * 2;
  const spread = Math.pow(r2, 0.6); // bias toward the centre, long tail outward
  const px = 120 + Math.cos(angle) * spread * 54;
  const py = 198 + Math.sin(angle) * spread * 17 - spread * 5;

  const rotation = Math.round((r3 - 0.5) * 70);
  const scale = 0.5 + r4 * 0.7;
  const variant = VARIANTS[Math.floor(r5 * VARIANTS.length)];
  const color = COLORS[Math.floor(r6 * COLORS.length)];

  // Fly-out trajectory — roughly the same direction as the leaf's own
  // position relative to pile-centre (so it looks like it's being thrown
  // OUT of the pile, not in a random unrelated direction), biased upward,
  // with per-leaf distance/rotation/stagger variety.
  const flyAngle = angle + (r7 - 0.5) * 0.8;
  const flyDistance = 55 + r4 * 95;
  const dx = Math.cos(flyAngle) * flyDistance;
  const dy = Math.sin(flyAngle) * flyDistance * 0.5 - 50 - r2 * 45;
  const dr = Math.round((r7 - 0.5) * 420);
  const delay = Math.min(r2 * 0.55, 0.5); // clamped so 1 - delay never gets too close to 0

  return { px, py, rotation, scale, variant, color, dx, dy, dr, delay };
});
---

<div class="leaf-burn" data-leaf-burn>
  <div class="leaf-burn-pin">
    <svg class="leaf-burn-scene" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <defs>
        <symbol id="leaf-pointed" viewBox="0 0 40 60">
          <path d="M20 2C29 12 34 24 34 36C34 48 28 56 20 58C12 56 6 48 6 36C6 24 11 12 20 2Z" fill="currentColor" />
          <path d="M20 8V54" stroke="black" stroke-opacity="0.18" stroke-width="1.4" stroke-linecap="round" />
        </symbol>
        <symbol id="leaf-rounded" viewBox="0 0 40 60">
          <path d="M20 6C30 10 36 20 36 32C36 46 29 56 20 58C11 56 4 46 4 32C4 20 10 10 20 6Z" fill="currentColor" />
          <path d="M20 12V52" stroke="black" stroke-opacity="0.18" stroke-width="1.4" stroke-linecap="round" />
        </symbol>
        <symbol id="leaf-narrow" viewBox="0 0 40 60">
          <path d="M20 2C25 10 28 20 28 34C28 48 25 56 20 59C15 56 12 48 12 34C12 20 15 10 20 2Z" fill="currentColor" />
          <path d="M20 10V50" stroke="black" stroke-opacity="0.18" stroke-width="1.4" stroke-linecap="round" />
        </symbol>
      </defs>

      <ellipse cx="120" cy="204" rx="88" ry="9" fill="var(--pine)" />

      <!-- stage 1 + 2: the pile IS the flying-leaves — every leaf here
           carries its own scatter trajectory, driven by one shared
           --scatter-t. Hidden entirely (opacity 0) until JS confirms
           it's running, via .js-active — the safe no-JS default is just
           the finished tree below, same principle as everywhere else on
           this site. -->
      <g class="leaf-pile-group">
        {leaves.map((leaf, i) => (
          <g transform={`translate(${leaf.px.toFixed(1)} ${leaf.py.toFixed(1)}) rotate(${leaf.rotation}) scale(${leaf.scale.toFixed(2)})`}>
            <use
              href={`#leaf-${leaf.variant}`}
              x="-8" y="-12" width="16" height="24"
              color={leaf.color}
              class="pile-leaf"
              style={`--d:${leaf.delay.toFixed(3)}; --dx:${leaf.dx.toFixed(1)}px; --dy:${leaf.dy.toFixed(1)}px; --dr:${leaf.dr}deg;`}
            />
          </g>
        ))}
      </g>

      <!-- tree: scales up out of the same spot as the pile scatters clear -->
      <g class="tree">
        <rect x="115" y="150" width="10" height="52" rx="3" fill="var(--charcoal)" />
        <circle cx="120" cy="140" r="30" fill="var(--leaf)" />
        <circle cx="100" cy="152" r="22" fill="var(--leaf)" />
        <circle cx="140" cy="152" r="22" fill="var(--leaf)" />
      </g>
    </svg>

    {(heading || text) && (
      <div class="leaf-burn-copy">
        {eyebrow && <p class="leaf-burn-eyebrow">{eyebrow}</p>}
        {heading && <h3>{heading}</h3>}
        {text && <p>{text}</p>}
      </div>
    )}

    <p class="leaf-burn-hint" aria-hidden="true">Scroll ↓</p>
  </div>
</div>

<style>
  .leaf-burn {
    position: relative;
    height: 180vh;
  }

  .leaf-burn-pin {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    overflow: hidden;
  }

  .leaf-burn-scene {
    width: min(648px, 88vw); /* 1.8x the previous 360px/70vw */
    height: auto;
  }

  .leaf-burn-copy {
    text-align: center;
    max-width: 480px;
  }

  .leaf-burn-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--signal);
    margin: 0 0 12px;
  }

  .leaf-burn-copy h3 {
    font-size: clamp(22px, 2.8vw, 30px);
    margin: 0 0 12px;
  }

  .leaf-burn-copy p:not(.leaf-burn-eyebrow) {
    font-size: 15.5px;
    color: var(--mist-muted);
    line-height: 1.6;
    margin: 0;
  }

  .leaf-burn-hint {
    position: absolute;
    bottom: 28px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mist-faint);
    opacity: var(--hint-opacity, 1);
    transition: opacity 0.3s ease;
    margin: 0;
  }

  /* ---- Pile group: hidden by default (safe no-JS fallback = just the
     tree below). Revealed only once the scroll handler confirms it's
     actually running, via .js-active — a single, simple class toggle,
     not a multi-stage timing chain, so there's very little to go wrong. */
  .leaf-pile-group {
    opacity: 0;
  }
  .leaf-burn.js-active .leaf-pile-group {
    opacity: 1;
  }

  /* ---- Each leaf derives its OWN progress (--leaf-t) from the single
     shared --scatter-t plus its own baked-in --d (delay), via clamp() —
     this is what lets 120 leaves stagger individually while the scroll
     handler only ever writes one shared value per tick. ---- */
  .pile-leaf {
    --leaf-t: clamp(0, calc((var(--scatter-t, 0) - var(--d, 0)) / (1 - var(--d, 0))), 1);
    transform-box: fill-box;
    transform-origin: center;
    transform: translate(calc(var(--leaf-t) * var(--dx)), calc(var(--leaf-t) * var(--dy))) rotate(calc(var(--leaf-t) * var(--dr)));
    opacity: calc(1 - var(--leaf-t));
  }

  .tree {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    transform: scale(var(--tree-scale, 1));
    opacity: var(--tree-opacity, 1);
  }

  /* ---- Reduced motion / no-JS fallback: a single static frame, not a
     scroll-jacked section. ---- */
  .leaf-burn.leaf-burn--static {
    height: auto;
  }
  .leaf-burn.leaf-burn--static .leaf-burn-pin {
    position: relative;
    height: auto;
    padding-block: var(--space-section);
  }
  .leaf-burn.leaf-burn--static .leaf-burn-hint {
    display: none;
  }

  @media (max-width: 700px) {
    .leaf-burn {
      height: 150vh;
    }
  }
</style>

<script>
  function initLeafBurn() {
    document.querySelectorAll<HTMLElement>('[data-leaf-burn]').forEach((wrapper) => {
      if (wrapper.dataset.lbInit) return;
      wrapper.dataset.lbInit = 'true';

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        wrapper.classList.add('leaf-burn--static');
        return;
      }

      wrapper.classList.add('js-active');

      const mapRange = (value: number, [min, max]: [number, number]) => {
        if (max === min) return value < min ? 0 : 1;
        return Math.min(1, Math.max(0, (value - min) / (max - min)));
      };
      const ease = (t: number) => t * t * (3 - 2 * t); // smoothstep

      // The pile scatters BEFORE/AS the tree appears — TREE_IN starts
      // while SCATTER is still finishing, so the tree emerges into the
      // space the leaves are clearing, rather than after a pause.
      const SCATTER: [number, number] = [0.18, 0.5];
      const TREE_IN: [number, number] = [0.42, 0.64];

      let ticking = false;

      const update = () => {
        const rect = wrapper.getBoundingClientRect();
        const scrollable = wrapper.offsetHeight - window.innerHeight;
        const scrolled = Math.min(Math.max(-rect.top, 0), Math.max(scrollable, 0));
        const progress = scrollable > 0 ? scrolled / scrollable : 0;

        const scatterT = ease(mapRange(progress, SCATTER));
        const treeT = ease(mapRange(progress, TREE_IN));

        wrapper.style.setProperty('--scatter-t', scatterT.toFixed(3));
        // Small sine bulge around the midpoint gives the tree a gentle
        // overshoot-and-settle "pop" purely as a function of scroll
        // position — no animation-timing involved at all.
        wrapper.style.setProperty('--tree-scale', (0.05 + 0.95 * treeT + 0.1 * Math.sin(treeT * Math.PI)).toFixed(3));
        wrapper.style.setProperty('--tree-opacity', treeT.toFixed(3));
        wrapper.style.setProperty('--hint-opacity', progress > 0.05 ? '0' : '1');

        ticking = false;
      };

      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();
    });
  }

  initLeafBurn();
  document.addEventListener('astro:page-load', initLeafBurn);
</script>
