---
// Animated component 1/2 — on scroll into view, a wind turbine's blades
// start spinning (paused off-screen to avoid wasting CPU/battery on a
// section nobody's looking at) while a short statement fades in to its
// left, using the site's existing scroll-reveal convention.
interface Props {
  eyebrow?: string;
  heading: string;
  text: string;
}

const { eyebrow = 'Renewable by design', heading, text } = Astro.props;
---

<div class="wind-reveal" data-wind-reveal>
  <div class="wind-copy" data-reveal>
    <p class="wind-eyebrow">{eyebrow}</p>
    <h3>{heading}</h3>
    <p>{text}</p>
  </div>

  <div class="wind-turbine-wrap" aria-hidden="true">
    <svg class="wind-turbine" viewBox="0 0 200 260" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- ground shadow -->
      <ellipse cx="100" cy="252" rx="46" ry="6" fill="var(--pine)" />
      <!-- tower -->
      <path d="M96 250 L104 250 L112 92 L88 92 Z" fill="var(--moss)" />
      <!-- nacelle (housing behind the hub) -->
      <rect x="88" y="82" width="36" height="16" rx="6" fill="var(--charcoal)" />
      <!-- blades: drawn in local space around (0,0), then translated to the hub.
           Rotated as a whole group via CSS for a smooth continuous spin. -->
      <g class="turbine-blades" transform="translate(107 90)">
        <path class="blade" d="M0 0 L-7 -76 Q0 -86 7 -76 Z" fill="var(--signal)" />
        <path class="blade" d="M0 0 L-7 -76 Q0 -86 7 -76 Z" fill="var(--signal)" transform="rotate(120)" />
        <path class="blade" d="M0 0 L-7 -76 Q0 -86 7 -76 Z" fill="var(--signal)" transform="rotate(240)" />
      </g>
      <circle cx="107" cy="90" r="8" fill="var(--charcoal)" />
    </svg>
  </div>
</div>

<style>
  .wind-reveal {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-section);
  }

  .wind-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--signal);
    margin: 0 0 16px;
  }

  .wind-copy h3 {
    font-size: clamp(24px, 3.2vw, 36px);
    line-height: 1.15;
    margin: 0 0 16px;
    max-width: 480px;
  }

  .wind-copy p:not(.wind-eyebrow) {
    font-size: 16px;
    line-height: 1.65;
    color: var(--mist-muted);
    max-width: 460px;
    margin: 0;
  }

  .wind-turbine-wrap {
    flex-shrink: 0;
  }

  .wind-turbine {
    width: 150px;
    height: auto;
  }

  .turbine-blades {
    transform-box: fill-box;
    transform-origin: center;
    animation: spin-turbine 5s linear infinite;
    animation-play-state: paused;
  }

  .wind-reveal.is-spinning .turbine-blades {
    animation-play-state: running;
  }

  @keyframes spin-turbine {
    to { transform: translate(107px, 90px) rotate(360deg); }
    from { transform: translate(107px, 90px) rotate(0deg); }
  }

  @media (max-width: 760px) {
    .wind-reveal {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
    .wind-copy h3,
    .wind-copy p {
      max-width: 420px;
      margin-inline: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .turbine-blades {
      animation: none;
    }
  }
</style>

<script>
  function initWindReveal() {
    document.querySelectorAll<HTMLElement>('[data-wind-reveal]').forEach((el) => {
      if (el.dataset.windInit) return;
      el.dataset.windInit = 'true';

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            el.classList.toggle('is-spinning', entry.isIntersecting);
          });
        },
        { threshold: 0.25 },
      );
      observer.observe(el);
    });
  }

  initWindReveal();
  document.addEventListener('astro:page-load', initWindReveal);
</script>
