---
// Reusable decorative motif — a handful of low-opacity leaves drifting
// gently in place, for background texture on any page/section. Purely
// ambient (not scroll-linked) — see LeafSwoosh.astro for the scroll-
// triggered left-to-right variant.
//
// Usage: drop as the first child of any `position: relative` container
// (a Section, a hero, a card) — it fills that container via
// `position: absolute; inset: 0`.
//
// Reuses the same leaf silhouette family as the tree animation
// (LeafToTreeReveal.astro) as a recurring visual motif across the site,
// but with its own <symbol> ids (leaf-float-*) to avoid colliding with
// that component's ids (leaf-*) if both appear on the same page.
interface Props {
  count?: number;
  seed?: number;
  maxOpacity?: number;
}

const { count = 6, seed = 1, maxOpacity = 0.12 } = Astro.props;

function mulberry32(seedValue: number) {
  return function () {
    seedValue |= 0;
    seedValue = (seedValue + 0x6d2b79f5) | 0;
    let t = Math.imul(seedValue ^ (seedValue >>> 15), 1 | seedValue);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const VARIANTS = ['pointed', 'rounded', 'narrow'] as const;
const COLORS = ['var(--leaf)', 'var(--ink-accent)', 'var(--signal)', 'var(--amber)'];

const rand = mulberry32(seed * 97 + 13);
const leaves = Array.from({ length: count }, () => {
  const r1 = rand();
  const r2 = rand();
  const r3 = rand();
  const r4 = rand();
  const r5 = rand();
  const r6 = rand();
  return {
    left: (r1 * 88 + 4).toFixed(1),
    top: (r2 * 84 + 4).toFixed(1),
    size: (18 + r3 * 22).toFixed(0),
    rotation: Math.round(r4 * 360),
    variant: VARIANTS[Math.floor(r5 * VARIANTS.length)],
    color: COLORS[Math.floor(r6 * COLORS.length)],
    duration: (14 + r3 * 12).toFixed(1),
    delay: (-(r6 * 20)).toFixed(1),
  };
});
---

<div class="floating-leaves" style={`--max-opacity:${maxOpacity}`} aria-hidden="true">
  <svg width="0" height="0" style="position:absolute">
    <defs>
      <symbol id="leaf-float-pointed" viewBox="0 0 40 60">
        <path d="M20 2C29 12 34 24 34 36C34 48 28 56 20 58C12 56 6 48 6 36C6 24 11 12 20 2Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-float-rounded" viewBox="0 0 40 60">
        <path d="M20 6C30 10 36 20 36 32C36 46 29 56 20 58C11 56 4 46 4 32C4 20 10 10 20 6Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-float-narrow" viewBox="0 0 40 60">
        <path d="M20 2C25 10 28 20 28 34C28 48 25 56 20 59C15 56 12 48 12 34C12 20 15 10 20 2Z" fill="currentColor" />
      </symbol>
    </defs>
  </svg>

  {leaves.map((leaf, i) => (
    <svg
      class="floating-leaf"
      viewBox="0 0 40 60"
      style={`left:${leaf.left}%; top:${leaf.top}%; width:${leaf.size}px; height:${leaf.size}px; color:${leaf.color}; animation-duration:${leaf.duration}s; animation-delay:${leaf.delay}s; --rot:${leaf.rotation}deg;`}
    >
      <use href={`#leaf-float-${leaf.variant}`} width="40" height="60" />
    </svg>
  ))}
</div>

<style>
  .floating-leaves {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .floating-leaf {
    position: absolute;
    opacity: var(--max-opacity, 0.12);
    transform: rotate(var(--rot, 0deg));
    animation-name: leaf-drift;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }

  @keyframes leaf-drift {
    0% { transform: translate(0, 0) rotate(var(--rot, 0deg)); }
    50% { transform: translate(14px, -20px) rotate(calc(var(--rot, 0deg) + 14deg)); }
    100% { transform: translate(0, 0) rotate(var(--rot, 0deg)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-leaf {
      animation: none;
    }
  }
</style>
