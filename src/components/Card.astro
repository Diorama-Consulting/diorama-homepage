---
interface Props {
  title: string;
  description: string;
  href?: string;
  linkText?: string;
}

const { title, description, href, linkText = 'Learn more' } = Astro.props;
---

<div class="card">
  <div class="card-icon">
    <slot name="icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke-width="1.8" style="stroke: var(--signal);">
        <path d="M12 3C9 7 7 10 7 13a5 5 0 0010 0c0-3-2-6-5-10z" />
      </svg>
    </slot>
  </div>
  <h3>{title}</h3>
  <p>{description}</p>
  {href && <a href={href}>{linkText} →</a>}
</div>

<style>
  .card {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 26px;
  }

  .card-icon {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    background: rgba(46, 204, 113, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .card h3 {
    font-size: 16.5px;
    margin-bottom: 9px;
  }

  .card p {
    font-size: 14px;
    color: var(--mist-muted);
    margin: 0 0 18px;
  }

  .card a {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
    text-decoration: none;
  }
  .card a:hover {
    color: var(--mint);
  }
</style>
