---
// Interactive "description on the left, image on the right" component.
// Clicking an option on the left cross-fades the image on the right and
// swaps the active description, with an animated progress rail on the
// active tab. Used on the homepage feature grid and on /services.
import type { ImageMetadata } from 'astro';

interface Option {
  title: string;
  description: string;
  image: ImageMetadata | string;
  imageAlt?: string;
  href?: string;
  linkText?: string;
}

interface Props {
  options: Option[];
  id?: string;
}

const { options, id = 'showcase' } = Astro.props;
---

<div class="showcase" id={id} data-showcase>
  <div class="showcase-options" role="tablist">
    {options.map((option, i) => (
      <button
        type="button"
        class="showcase-option"
        class:list={{ 'is-active': i === 0 }}
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        data-index={i}
      >
        <span class="showcase-option-title">{option.title}</span>
        <span class="showcase-option-desc">{option.description}</span>
        {option.href && <span class="showcase-option-link">{option.linkText || 'Learn more'} →</span>}
        <span class="showcase-option-rail"><span class="showcase-option-rail-fill"></span></span>
      </button>
    ))}
  </div>

  <div class="showcase-media">
    {options.map((option, i) => {
      const src = typeof option.image === 'string' ? option.image : option.image?.src;
      return (
        <img
          src={src}
          alt={option.imageAlt || ''}
          class="showcase-media-img"
          class:list={{ 'is-active': i === 0 }}
          data-index={i}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      );
    })}
    <div class="showcase-media-glow" aria-hidden="true"></div>
  </div>
</div>

<style>
  .showcase {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-xl);
    align-items: stretch;
  }

  .showcase-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .showcase-option {
    position: relative;
    text-align: left;
    background: transparent;
    border: none;
    border-top: 1px solid var(--hairline);
    padding: var(--space-sm) var(--space-2xs) var(--space-sm) var(--space-sm);
    cursor: pointer;
    color: var(--mist-muted);
    font-family: var(--font-body);
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: color 0.2s ease, padding-left 0.3s ease;
  }

  .showcase-options .showcase-option:last-child {
    border-bottom: 1px solid var(--hairline);
  }

  .showcase-option-title {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 600;
    color: var(--mist);
    transition: color 0.2s ease;
  }

  .showcase-option-desc {
    font-size: 14.5px;
    line-height: 1.6;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease, margin-top 0.4s ease;
  }

  .showcase-option-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, opacity 0.3s ease;
  }

  .showcase-option-rail {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--hairline);
  }

  .showcase-option-rail-fill {
    display: block;
    width: 100%;
    height: 0%;
    background: var(--signal);
    transition: height 0.4s ease;
  }

  .showcase-option.is-active {
    padding-left: var(--space-md);
  }

  .showcase-option.is-active .showcase-option-title {
    color: #ffffff;
  }

  .showcase-option.is-active .showcase-option-desc,
  .showcase-option.is-active .showcase-option-link {
    max-height: 200px;
    opacity: 1;
    margin-top: 2px;
  }

  .showcase-option.is-active .showcase-option-rail-fill {
    height: 100%;
  }

  .showcase-media {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--pine);
    min-height: 320px;
  }

  .showcase-media-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.04);
    transition: opacity 0.5s ease, transform 0.6s ease;
  }

  .showcase-media-img.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .showcase-media-glow {
    position: absolute;
    inset: 0;
    background: var(--gradient-radial-glow);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  @media (max-width: 860px) {
    .showcase {
      grid-template-columns: 1fr;
    }
    .showcase-media {
      order: -1;
      min-height: 220px;
    }
  }
</style>

<script>
  function initShowcases() {
    document.querySelectorAll<HTMLElement>('[data-showcase]').forEach((root) => {
      const options = Array.from(root.querySelectorAll<HTMLButtonElement>('.showcase-option'));
      const images = Array.from(root.querySelectorAll<HTMLImageElement>('.showcase-media-img'));

      options.forEach((btn) => {
        btn.addEventListener('click', () => {
          const index = btn.dataset.index;
          options.forEach((o) => {
            const active = o.dataset.index === index;
            o.classList.toggle('is-active', active);
            o.setAttribute('aria-selected', active ? 'true' : 'false');
          });
          images.forEach((img) => img.classList.toggle('is-active', img.dataset.index === index));
        });
      });
    });
  }

  initShowcases();
  document.addEventListener('astro:page-load', initShowcases);
</script>
