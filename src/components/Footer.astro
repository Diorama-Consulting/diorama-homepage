---
import SustainabilityNote from './SustainabilityNote.astro';
import ContactForm from './ContactForm.astro';
import { reader } from '../lib/keystatic';

interface LinkGroup {
  heading: string;
  links: { label: string; href: string }[];
}

interface Props {
  brandName?: string;
  brandBlurb?: string;
  legalLine?: string;
  groups?: LinkGroup[];
}

const siteSettings = await reader.singletons.siteSettings.read();

const {
  brandName = 'Diorama Consulting Ltd',
  brandBlurb = 'AI Technology Advice led by Mal Minhas with a focus on D2C marketplaces and products.',
  legalLine = `© ${new Date().getFullYear()} Diorama Consulting Ltd. All rights reserved. Registered at 71-75 Shelton Street, Covent Garden, London, WC2H 9JQ in England No. 16137029 with VAT Registration No. 483184277`,
  groups = [
    {
      heading: 'Site',
      links: [
        { label: 'Services', href: '/services' },
        { label: 'Projects', href: '/projects' },
        { label: 'Teaching', href: '/teaching' },
        { label: 'Blog', href: '/blog' },
      ],
    },
    {
      heading: 'Company',
      links: [
        { label: 'About', href: '/about' },
        { label: 'Team', href: '/about#team' },
        { label: 'FAQ', href: '/about/faq' },
        { label: 'Contact', href: '/contact' },
      ],
    },
    {
      heading: 'Legal',
      links: [
        { label: 'Privacy', href: '#' },
        { label: 'Terms', href: '#' },
        { label: 'Cookies', href: '#' },
        { label: 'Accessibility', href: '#' },
      ],
    },
  ],
} = Astro.props;
---

<footer class="site-footer">
  <div class="container footer-cta">
    <div class="footer-cta-copy">
      <p class="footer-cta-eyebrow">Get in touch</p>
      <h3>Have a project in mind?</h3>
      <p class="footer-cta-sub">Send a quick note — we'll reply within a couple of working days.</p>
    </div>
    <ContactForm formId="footer-contact-form" compact />
  </div>

  <div class="container footer-top">
    <div class="footer-brand">
      <a href="/" class="logo">
        <svg width="16" height="16" viewBox="0 0 24 24">
          <path d="M12 3C9 7 7 10 7 13a5 5 0 0010 0c0-3-2-6-5-10z" style="fill: var(--signal);" />
        </svg>
        {brandName}
      </a>
      <p>{brandBlurb}</p>
    </div>
    {groups.map((group) => (
      <div class="footer-group">
        <h4>{group.heading}</h4>
        <ul>
          {group.links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>
  <div class="container footer-sustainability">
    <SustainabilityNote
      hostingProvider={siteSettings?.hostingProvider}
      hostingRegion={siteSettings?.hostingRegion}
      greenHostingVerified={siteSettings?.greenHostingVerified}
      greenHostingEvidenceUrl={siteSettings?.greenHostingEvidenceUrl}
      sustainabilityNotes={siteSettings?.sustainabilityNotes}
      showSustainabilitySection={siteSettings?.showSustainabilitySection}
      showCarbonBadge={siteSettings?.showCarbonBadge}
      showCo2Estimate={siteSettings?.showCo2Estimate}
      showHostingInfo={siteSettings?.showHostingInfo}
      showVerificationStatus={siteSettings?.showVerificationStatus}
      showSustainabilityNotes={siteSettings?.showSustainabilityNotes}
      showMethodologyLink={siteSettings?.showMethodologyLink}
    />
  </div>
  <div class="container footer-bottom">
    <p>{legalLine}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--canopy);
    border-top: 1px solid var(--hairline);
    margin-top: var(--space-2xl);
  }

  .footer-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
    padding-block: var(--space-xl);
    border-bottom: 1px solid var(--hairline);
  }

  .footer-cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mint);
    margin: 0 0 10px;
  }

  .footer-cta-copy h3 {
    font-size: clamp(22px, 2.6vw, 30px);
    margin-bottom: 10px;
  }

  .footer-cta-sub {
    color: var(--mist-muted);
    font-size: 14.5px;
    max-width: 380px;
    margin: 0;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-md);
    padding-block: var(--space-lg) var(--space-md);
  }

  @media (max-width: 860px) {
    .footer-cta {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  .footer-brand .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: #fff;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }

  .footer-brand p {
    font-size: 13.5px;
    color: var(--mist-muted);
    max-width: 260px;
    margin: 0;
  }

  .footer-group h4 {
    font-size: 13px;
    color: var(--mist);
    margin-bottom: 16px;
  }

  .footer-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-group a {
    font-size: 13.5px;
    color: var(--mist-muted);
    text-decoration: none;
  }
  .footer-group a:hover {
    color: var(--signal);
  }

  .footer-sustainability {
    margin-bottom: 32px;
  }

  .footer-bottom {
    border-top: 1px solid var(--hairline);
    padding-block: 20px;
  }

  .footer-bottom p {
    font-size: 12.5px;
    color: var(--mist-muted);
    margin: 0;
  }

  @media (max-width: 760px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: 12px;
    }
  }
</style>
