---
// Footer — redesigned.
//
// Changes from the previous version:
//   - The contact-form CTA block hides itself on /contact (the page has
//     its own form; two forms on one page was redundant). Detection is by
//     pathname, so no prop-threading through every page is needed.
//   - The sustainability strip now leads with the LIVE Website Carbon
//     badge (always visible); the green-hosting badge moved into its
//     expanded details area. See SustainabilityNote.astro.
//   - Link groups restructured around the site's real information
//     architecture (Services / Explore / Company / Legal), with the five
//     legal & policy pages now real: Privacy Policy, Terms of Use,
//     Cookie Policy, Accessibility, Sustainability. NOTE: the groups
//     rendered in production come from Keystatic (footer-nav.yaml) — the
//     defaults below only apply if that file's groups are emptied. Both
//     were updated together in this change.
//   - New credit line in the bottom bar: "Website by paolo.org.uk" with
//     its mark (public/images/paolo-icon.svg), alongside the legal line.
import SustainabilityNote from './SustainabilityNote.astro';
import ContactForm from './ContactForm.astro';
import { reader } from '../lib/keystatic';

interface LinkGroup {
  heading: string;
  links: { label: string; href: string }[];
}

interface Props {
  brandName?: string;
  brandBlurb?: string;
  legalLine?: string;
  groups?: LinkGroup[];
  /** Footer contact CTA block — editable in Keystatic (Footer singleton). */
  ctaEyebrow?: string;
  ctaHeading?: string;
  ctaSub?: string;
}

const siteSettings = await reader.singletons.siteSettings.read();
// Read here directly (same pattern as siteSettings above) so every one of
// the ~16 call sites gets the editable CTA copy automatically — pages
// only need to pass brandBlurb/groups/legalLine explicitly; the CTA prop
// overrides below exist for a caller that already has footerNav in scope
// and wants to pass it through explicitly (e.g. the About page), but are
// optional.
const footerNavForCta = await reader.singletons.footerNav.read().catch(() => null);

// The contact page already has a full-size form — showing the footer's
// compact one there as well meant two forms on one page.
const onContactPage = Astro.url.pathname.startsWith('/contact');

const {
  brandName = 'Diorama Consulting Ltd',
  brandBlurb = 'AI Technology Advice led by Mal Minhas with a focus on D2C marketplaces and products.',
  legalLine = `© ${new Date().getFullYear()} Diorama Consulting Ltd. All rights reserved. Registered at 71-75 Shelton Street, Covent Garden, London, WC2H 9JQ in England No. 16137029 with VAT Registration No. 483184277`,
  groups = [
    {
      heading: 'Services',
      links: [
        { label: 'Overview', href: '/services' },
        { label: 'Consulting', href: '/services/consulting' },
        { label: 'Charities', href: '/services/charities' },
      ],
    },
    {
      heading: 'Explore',
      links: [
        { label: 'Tools', href: '/tools' },
        { label: 'Insights', href: '/insights' },
        { label: 'Events', href: '/events' },
        { label: 'Teaching', href: '/teaching' },
      ],
    },
    {
      heading: 'Company',
      links: [
        { label: 'About', href: '/about' },
        { label: 'Team', href: '/about#team' },
        { label: 'FAQ', href: '/about/faq' },
        { label: 'Contact', href: '/contact' },
      ],
    },
    {
      heading: 'Legal',
      links: [
        { label: 'Privacy Policy', href: '/legal/privacy-policy' },
        { label: 'Terms of Use', href: '/legal/terms-of-use' },
        { label: 'Cookie Policy', href: '/legal/cookies-policy' },
        { label: 'Accessibility', href: '/legal/accessibility' },
        { label: 'Sustainability', href: '/legal/sustainability' },
      ],
    },
  ],
  // Defaults mirror the footerNav Keystatic schema's own defaults — kept
  // in sync so a never-edited entry and a freshly-created one read the
  // same copy. "Have a project in mind?" was the previous hardcoded copy;
  // the new default is more direct and matches what's now editable here.
  ctaEyebrow = footerNavForCta?.ctaEyebrow || 'Get in touch',
  ctaHeading = footerNavForCta?.ctaHeading || 'Get in touch to discuss your needs',
  ctaSub = footerNavForCta?.ctaSub || "Send a quick note — we'll reply within a couple of working days.",
} = Astro.props;
---

<footer class="site-footer">
  {!onContactPage && (
    <div class="container footer-cta">
      <div class="footer-cta-copy">
        <p class="footer-cta-eyebrow">{ctaEyebrow}</p>
        <h3>{ctaHeading}</h3>
        <p class="footer-cta-sub">{ctaSub}</p>
      </div>
      <ContactForm formId="footer-contact-form" compact />
    </div>
  )}

  <div class="container footer-top">
    <div class="footer-brand">
      <a href="/" class="logo">
        <svg width="16" height="16" viewBox="0 0 24 24">
          <path d="M12 3C9 7 7 10 7 13a5 5 0 0010 0c0-3-2-6-5-10z" style="fill: var(--ink-accent);" />
        </svg>
        {brandName}
      </a>
      <p>{brandBlurb}</p>
    </div>
    {groups.map((group) => (
      <div class="footer-group">
        <h4>{group.heading}</h4>
        <ul>
          {group.links.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="container footer-sustainability">
    <SustainabilityNote
      hostingProvider={siteSettings?.hostingProvider}
      hostingRegion={siteSettings?.hostingRegion}
      greenHostingVerified={siteSettings?.greenHostingVerified}
      greenHostingEvidenceUrl={siteSettings?.greenHostingEvidenceUrl}
      sustainabilityNotes={siteSettings?.sustainabilityNotes}
      showSustainabilitySection={siteSettings?.showSustainabilitySection}
      showGreenBadges={siteSettings?.showGreenBadges}
      showCarbonBadge={siteSettings?.showCarbonBadge}
      showHostingInfo={siteSettings?.showHostingInfo}
      showVerificationStatus={siteSettings?.showVerificationStatus}
      showSustainabilityNotes={siteSettings?.showSustainabilityNotes}
      showMethodologyLink={siteSettings?.showMethodologyLink}
    />
  </div>

  <div class="container footer-bottom">
    <p class="legal-line">{legalLine}</p>
    <a class="site-credit" href="https://paolo.org.uk" target="_blank" rel="noopener noreferrer">
      <img src="/images/paolo-icon.svg" alt="" width="18" height="18" loading="lazy" />
      <span>Website by <strong>paolo.org.uk</strong></span>
    </a>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink-bg);
    border-top: 1px solid var(--ink-border);
    margin-top: var(--space-2xl);
  }

  .footer-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: center;
    padding-block: var(--space-xl);
    border-bottom: 1px solid var(--ink-border);
  }

  .footer-cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-accent);
    margin: 0 0 10px;
  }

  .footer-cta-copy h3 {
    font-size: clamp(22px, 2.6vw, 30px);
    margin-bottom: 10px;
    color: var(--ink-text);
  }

  .footer-cta-sub {
    color: var(--ink-text-muted);
    font-size: 14.5px;
    max-width: 380px;
    margin: 0;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--space-md);
    padding-block: var(--space-lg) var(--space-md);
  }

  .footer-brand .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    color: var(--ink-text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
  }

  .footer-brand p {
    font-size: 13.5px;
    color: var(--ink-text-muted);
    max-width: 260px;
    margin: 0;
  }

  .footer-group h4 {
    font-size: 13px;
    color: var(--ink-text);
    margin-bottom: 16px;
  }

  .footer-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-group a {
    font-size: 13.5px;
    color: var(--ink-text-muted);
    text-decoration: none;
  }
  .footer-group a:hover {
    color: var(--ink-accent-hover);
  }

  .footer-sustainability {
    margin-bottom: 32px;
  }

  .footer-bottom {
    border-top: 1px solid var(--ink-border);
    padding-block: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .legal-line {
    font-size: 12.5px;
    color: var(--ink-text-muted);
    margin: 0;
    max-width: 72ch;
  }

  .site-credit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    color: var(--ink-text-muted);
    text-decoration: none;
    flex-shrink: 0;
    transition: color 0.2s ease;
  }
  .site-credit strong {
    color: var(--ink-text);
    font-weight: 600;
    transition: color 0.2s ease;
  }
  .site-credit:hover strong {
    color: var(--ink-accent-hover);
  }
  .site-credit img {
    display: block;
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .site-credit:hover img {
    transform: rotate(60deg);
  }

  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
      margin-bottom: 12px;
    }
  }

  @media (max-width: 860px) {
    .footer-cta {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-credit img { transition: none; }
    .site-credit:hover img { transform: none; }
  }
</style>
