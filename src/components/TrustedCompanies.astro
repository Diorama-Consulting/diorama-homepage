---
// Homepage trust banner — a quiet row of client/partner logos. Logos are
// desaturated to greyscale by default and warm to full colour + brand
// green tint on hover, so the row stays calm until someone actually looks
// at it. Content (name + logo, local upload or external URL) is managed
// in Keystatic on the Homepage singleton.
interface Company {
  name: string;
  logo: string;
  href?: string;
}

interface Props {
  companies: Company[];
  heading?: string;
}

const { companies, heading = 'Trusted by teams at' } = Astro.props;
---

{companies.length > 0 && (
  <div class="trusted-banner">
    <div class="container trusted-inner">
      <p class="trusted-heading">{heading}</p>
      <ul class="trusted-logos">
        {companies.map((company) => (
          <li>
            {company.href ? (
              <a href={company.href} target="_blank" rel="noopener noreferrer" aria-label={company.name}>
                <img src={company.logo} alt={company.name} loading="lazy" decoding="async" />
              </a>
            ) : (
              <img src={company.logo} alt={company.name} loading="lazy" decoding="async" />
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
)}

<style>
  .trusted-banner {
    padding-block: var(--space-lg);
    border-bottom: 1px solid var(--hairline);
  }

  .trusted-inner {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .trusted-heading {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mist-faint);
    white-space: nowrap;
    margin: 0;
  }

  .trusted-logos {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-xl);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .trusted-logos img {
    height: 26px;
    width: auto;
    max-width: 130px;
    object-fit: contain;
    filter: grayscale(1) brightness(1.8) contrast(0.8);
    opacity: 0.55;
    transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
  }

  .trusted-logos li:hover img {
    filter: none;
    opacity: 1;
    transform: translateY(-1px);
  }

  @media (max-width: 700px) {
    .trusted-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
    .trusted-logos {
      gap: var(--space-lg);
      justify-content: center;
      width: 100%;
    }
  }
</style>
