---
// Scroll-linked variant of the leaf motif — leaves sweep left-to-right as
// the host section scrolls through the viewport (not a pinned/scroll-
// jacked section like LeafToTreeReveal; this just reads its own natural
// scroll position, same scroll-scrubbing principle as everywhere else on
// the site — see LeafToTreeReveal.astro for the fuller explanation of why
// this mechanism is preferred over trigger-once animations).
//
// Usage: drop as a child of any `position: relative` container — fills
// it via `position: absolute; inset: 0`.
interface Props {
  count?: number;
  seed?: number;
  maxOpacity?: number;
}

const { count = 10, seed = 7, maxOpacity = 0.16 } = Astro.props;

function mulberry32(seedValue: number) {
  return function () {
    seedValue |= 0;
    seedValue = (seedValue + 0x6d2b79f5) | 0;
    let t = Math.imul(seedValue ^ (seedValue >>> 15), 1 | seedValue);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const VARIANTS = ['pointed', 'rounded', 'narrow'] as const;
const COLORS = ['var(--leaf)', 'var(--ink-accent)', 'var(--signal)', 'var(--amber)'];

const rand = mulberry32(seed * 131 + 7);
const leaves = Array.from({ length: count }, () => {
  const r1 = rand();
  const r2 = rand();
  const r3 = rand();
  const r4 = rand();
  const r5 = rand();
  const r6 = rand();
  const r7 = rand();
  return {
    top: (r1 * 80 + 4).toFixed(1),
    size: (16 + r2 * 20).toFixed(0),
    rotStart: Math.round(r3 * 360),
    rotDelta: Math.round((r7 - 0.5) * 200),
    variant: VARIANTS[Math.floor(r4 * VARIANTS.length)],
    color: COLORS[Math.floor(r5 * COLORS.length)],
    dx: Math.round(220 + r6 * 260), // px swept left-to-right
    delay: Math.min(r2 * 0.5, 0.45), // clamped, same reasoning as LeafToTreeReveal
  };
});
---

<div class="leaf-swoosh" data-leaf-swoosh aria-hidden="true">
  <svg width="0" height="0" style="position:absolute">
    <defs>
      <symbol id="leaf-swoosh-pointed" viewBox="0 0 40 60">
        <path d="M20 2C29 12 34 24 34 36C34 48 28 56 20 58C12 56 6 48 6 36C6 24 11 12 20 2Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-swoosh-rounded" viewBox="0 0 40 60">
        <path d="M20 6C30 10 36 20 36 32C36 46 29 56 20 58C11 56 4 46 4 32C4 20 10 10 20 6Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-swoosh-narrow" viewBox="0 0 40 60">
        <path d="M20 2C25 10 28 20 28 34C28 48 25 56 20 59C15 56 12 48 12 34C12 20 15 10 20 2Z" fill="currentColor" />
      </symbol>
    </defs>
  </svg>

  {leaves.map((leaf) => (
    <svg
      class="swoosh-leaf"
      viewBox="0 0 40 60"
      style={`top:${leaf.top}%; left:-8%; width:${leaf.size}px; height:${leaf.size}px; color:${leaf.color}; --d:${leaf.delay.toFixed(3)}; --dx:${leaf.dx}px; --rot0:${leaf.rotStart}deg; --rotd:${leaf.rotDelta}deg; --max-opacity:${maxOpacity};`}
    >
      <use href={`#leaf-swoosh-${leaf.variant}`} width="40" height="60" />
    </svg>
  ))}
</div>

<style>
  .leaf-swoosh {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .swoosh-leaf {
    position: absolute;
    --leaf-t: clamp(0, calc((var(--swoosh-t, 0) - var(--d, 0)) / (1 - var(--d, 0))), 1);
    transform: translateX(calc(var(--leaf-t) * var(--dx))) rotate(calc(var(--rot0) + var(--leaf-t) * var(--rotd)));
    opacity: calc(var(--max-opacity, 0.16) * sin(var(--leaf-t) * 3.14159));
  }

  @media (prefers-reduced-motion: reduce) {
    .swoosh-leaf {
      display: none;
    }
  }
</style>

<script>
  function initLeafSwoosh() {
    document.querySelectorAll<HTMLElement>('[data-leaf-swoosh]').forEach((el) => {
      if (el.dataset.lsInit) return;
      el.dataset.lsInit = 'true';

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let ticking = false;
      const update = () => {
        const rect = el.getBoundingClientRect();
        const total = rect.height + window.innerHeight;
        const progress = total > 0 ? (window.innerHeight - rect.top) / total : 0;
        el.style.setProperty('--swoosh-t', Math.min(Math.max(progress, 0), 1).toFixed(3));
        ticking = false;
      };
      const onScroll = () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(update);
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();
    });
  }

  initLeafSwoosh();
  document.addEventListener('astro:page-load', initLeafSwoosh);
</script>
