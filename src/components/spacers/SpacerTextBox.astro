---
// 4 of 5 spacer components — a simple, centred callout box: a short
// standalone line of text (a principle, a value, a one-line statement),
// not a full section with its own heading hierarchy. Meant to give the
// eye and the reading rhythm a rest between two denser blocks of prose.
interface Props {
  eyebrow?: string;
  text: string;
  tone?: 'green' | 'sand';
}

const { eyebrow, text, tone = 'green' } = Astro.props;
---

<div class="spacer-textbox" data-reveal>
  <div class:list={['textbox-inner', `tone-${tone}`]}>
    {eyebrow && <span class="textbox-eyebrow">{eyebrow}</span>}
    <p>{text}</p>
  </div>
</div>

<style>
  .spacer-textbox {
    padding-block: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  .textbox-inner {
    max-width: 620px;
    text-align: center;
    padding: 36px 44px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--hairline);
  }

  .tone-green {
    background: var(--signal-soft);
  }

  .tone-sand {
    background: var(--sand-soft);
  }

  .textbox-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 12px;
  }

  .textbox-inner p {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(18px, 2.2vw, 24px);
    line-height: 1.45;
    color: var(--text-strong);
  }

  @media (max-width: 640px) {
    .textbox-inner {
      padding: 28px 24px;
    }
  }
</style>
