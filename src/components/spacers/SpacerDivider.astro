---
// 5 of 5 spacer components — a horizontal line that draws itself inward
// from both edges on scroll reveal, with an optional centred label/value
// chip. The two hairlines are always visibly present regardless of JS
// (they're a real background colour, not clipped to nothing) — the
// animated highlight that sweeps across them is a pure enhancement.
interface Props {
  label?: string;
  value?: string;
}

const { label, value } = Astro.props;
---

<div class="spacer-divider" data-reveal>
  <span class="divider-line divider-line--left" aria-hidden="true"></span>
  {(label || value) && (
    <span class="divider-chip">
      {value && <strong>{value}</strong>}
      {label && <span>{label}</span>}
    </span>
  )}
  <span class="divider-line divider-line--right" aria-hidden="true"></span>
</div>

<style>
  .spacer-divider {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-block: var(--space-xl);
  }

  .divider-line {
    flex: 1 1 auto;
    height: 1px;
    background: var(--hairline);
    position: relative;
    overflow: hidden;
  }

  .divider-line::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--signal);
    transform: scaleX(0);
    transition: transform 1.1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .divider-line--left::after { transform-origin: left; }
  .divider-line--right::after { transform-origin: right; }

  .spacer-divider.is-visible .divider-line::after {
    transform: scaleX(1);
  }

  .divider-chip {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    color: var(--mist-muted);
    white-space: nowrap;
  }

  .divider-chip strong {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-strong);
    letter-spacing: -0.01em;
  }

  @media (prefers-reduced-motion: reduce) {
    .divider-line::after {
      transition: none;
    }
  }
</style>
