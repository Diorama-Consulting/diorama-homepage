---
import Button from './Button.astro';

interface Props {
  /** Unique id — required when more than one ContactForm renders on a page (e.g. footer + /contact). */
  formId?: string;
  /** Compact renders a tighter, side-by-side layout for the footer mini-form. */
  compact?: boolean;
  heading?: string;
}

const { formId = 'contact-form', compact = false, heading } = Astro.props;
---

<div class:list={['contact-form-wrap', compact && 'contact-form-wrap--compact']}>
  {heading && <h3 class="contact-form-heading">{heading}</h3>}
  <form class:list={['contact-form', compact && 'contact-form--compact']} id={formId} method="POST" action="/api/contact" novalidate>
    <div class="field hp" aria-hidden="true">
      <label for={`${formId}-company`}>Company</label>
      <input type="text" id={`${formId}-company`} name="company" tabindex="-1" autocomplete="off" />
    </div>

    <div class="field">
      {!compact && <label for={`${formId}-name`}>Name</label>}
      <input type="text" id={`${formId}-name`} name="name" placeholder="Name" required />
    </div>
    <div class="field">
      {!compact && <label for={`${formId}-email`}>Email</label>}
      <input type="email" id={`${formId}-email`} name="email" placeholder="you@example.com" required />
    </div>
    <div class="field field-message">
      {!compact && <label for={`${formId}-message`}>Message</label>}
      <textarea id={`${formId}-message`} name="message" placeholder={compact ? 'Quick message…' : 'Tell us about your project...'} required></textarea>
    </div>

    <p class="form-status" data-status role="status" aria-live="polite"></p>
    <Button type="submit" size={compact ? 'sm' : 'md'}>{compact ? 'Send' : 'Send message'}</Button>
  </form>
</div>

<style>
  .contact-form-wrap {
    width: 100%;
  }

  .contact-form-heading {
    font-size: 15px;
    color: #fff;
    margin-bottom: var(--space-sm);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 480px;
  }

  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  .field label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--mist-muted);
    margin-bottom: 7px;
  }

  .field input,
  .field textarea {
    width: 100%;
    background: var(--canopy);
    border: 1.5px solid var(--hairline);
    border-radius: 8px;
    padding: 11px 14px;
    color: var(--mist);
    font-family: var(--font-body);
    font-size: 14px;
    transition: border-color 0.2s ease;
  }
  .field textarea {
    resize: vertical;
    min-height: 110px;
  }
  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--mist-faint);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--signal);
  }

  .form-status { font-size: 14px; margin: 0; min-height: 1.2em; }
  .form-status[data-state='ok'] { color: var(--signal); }
  .form-status[data-state='error'] { color: var(--rose); }

  /* ---- Compact variant: footer mini-form ---- */
  .contact-form--compact {
    max-width: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .contact-form--compact .field-message {
    grid-column: 1 / -1;
  }
  .contact-form--compact .field textarea {
    min-height: 64px;
  }
  .contact-form--compact .form-status {
    grid-column: 1 / -1;
  }
  .contact-form--compact :global(.btn) {
    grid-column: 1 / -1;
    justify-self: start;
  }

  @media (max-width: 540px) {
    .contact-form--compact {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initContactForm(form: HTMLFormElement) {
    const status = form.querySelector<HTMLElement>('[data-status]');
    if (!status) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      const submitBtn = form.querySelector('button');
      submitBtn?.setAttribute('disabled', 'true');

      try {
        const formData = Object.fromEntries(new FormData(form));
        const w = window as any;
        const sessionId = w.posthog?.get_session_id?.() || '';
        const distinctId = w.posthog?.get_distinct_id?.() || '';
        const res = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-PostHog-Session-Id': sessionId,
            'X-PostHog-Distinct-Id': distinctId,
          },
          body: JSON.stringify(formData),
        });
        const result = await res.json();

        if (result.ok) {
          status.dataset.state = 'ok';
          status.textContent = "Thanks — we'll be in touch shortly.";
          w.posthog?.capture('contact_form_submitted');
          form.reset();
        } else {
          status.dataset.state = 'error';
          status.textContent = result.error ?? 'Something went wrong. Please try again.';
        }
      } catch (err) {
        status.dataset.state = 'error';
        status.textContent = 'Network error — please try again.';
        (window as any).posthog?.captureException?.(err);
      } finally {
        submitBtn?.removeAttribute('disabled');
      }
    });
  }

  function initAllContactForms() {
    document.querySelectorAll<HTMLFormElement>('.contact-form').forEach((form) => {
      if (form.dataset.initialized) return;
      form.dataset.initialized = 'true';
      initContactForm(form);
    });
  }

  initAllContactForms();
  document.addEventListener('astro:page-load', initAllContactForms);
</script>
