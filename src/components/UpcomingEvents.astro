---
// Events list — redesigned as an image-led vertical list (was a compact
// date-tile grid). Each event is now a full-width row: a photo on one
// side, the date/title/description/CTA on the other, alternating sides
// down the page for rhythm rather than a repetitive grid. Events without
// a hero image fall back to a token-built date panel (no broken-image
// gaps, no layout collapse) rather than being visually demoted.
//
// Still called twice from /events (upcoming + past, different heading/
// eyebrow, pre-filtered lists) — same prop shape as before, plus
// `heroImage`/`heroImageUrl`, which the page now actually passes through
// (previously in the schema but never read).
import Section from './Section.astro';

interface EventItem {
  title: string;
  date: string; // ISO date
  location?: string;
  description?: string;
  href?: string;
  linkText?: string;
  heroImage?: string;
}

interface Props {
  events: EventItem[];
  eyebrow?: string;
  heading?: string;
  subheading?: string;
  id?: string;
}

const { events, eyebrow = 'Upcoming', heading = 'Events', subheading, id = 'events' } = Astro.props;

function formatEventDate(iso: string) {
  const d = new Date(iso);
  return {
    day: d.toLocaleDateString('en-GB', { day: '2-digit' }),
    month: d.toLocaleDateString('en-GB', { month: 'short' }),
    full: d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }),
  };
}
---

{events.length > 0 && (
  <Section id={id} eyebrow={eyebrow} heading={heading} subheading={subheading}>
    <div class="events-list">
      {events.map((event, i) => {
        const { day, month, full } = formatEventDate(event.date);
        const Tag = event.href ? 'a' : 'div';
        return (
          <Tag
            class:list={['event-row', i % 2 === 1 && 'event-row--flip']}
            href={event.href}
            {...(event.href?.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            data-reveal
          >
            <div class="event-media">
              {event.heroImage ? (
                <img src={event.heroImage} alt="" loading={i === 0 ? 'eager' : 'lazy'} />
              ) : (
                <div class="event-media-fallback" aria-hidden="true">
                  <span class="fallback-day">{day}</span>
                  <span class="fallback-month">{month}</span>
                </div>
              )}
              <span class="event-date-chip">
                <span class="chip-day">{day}</span>
                <span class="chip-month">{month}</span>
              </span>
            </div>
            <div class="event-body">
              <p class="event-full-date">{full}{event.location ? ` · ${event.location}` : ''}</p>
              <h3>{event.title}</h3>
              {event.description && <p class="event-description">{event.description}</p>}
              {event.href && <span class="event-cta">{event.linkText ?? 'Details'}<span class="arrow">→</span></span>}
            </div>
          </Tag>
        );
      })}
    </div>
  </Section>
)}

<style>
  .events-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .event-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    gap: var(--space-lg);
    align-items: center;
    text-decoration: none;
    color: inherit;
  }

  .event-row--flip {
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
  }
  .event-row--flip .event-media { order: 2; }
  .event-row--flip .event-body { order: 1; }

  /* ---- Media ---- */
  .event-media {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: var(--gradient-surface);
    transition: box-shadow 0.3s ease;
  }

  .event-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  a.event-row:hover .event-media img {
    transform: scale(1.04);
  }
  a.event-row:hover .event-media {
    box-shadow: var(--shadow-lg);
  }

  .event-media-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: linear-gradient(150deg, var(--signal-soft), var(--gradient-surface));
  }
  .fallback-day {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 58px);
    font-weight: 700;
    color: var(--text-strong);
    line-height: 1;
  }
  .fallback-month {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mist-muted);
  }

  /* Small date chip overlaid on the image itself — present whether or
     not there's a photo, so the date reads at a glance either way. */
  .event-date-chip {
    position: absolute;
    top: 16px;
    left: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.05;
    padding: 8px 12px;
    border-radius: var(--radius-md);
    background: hsl(var(--hue-green) 30% 9% / 0.72);
    backdrop-filter: blur(6px);
    color: var(--ink-text);
  }
  .event-media:has(.event-media-fallback) .event-date-chip {
    display: none; /* fallback panel already shows the date, full-size */
  }
  .chip-day {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
  }
  .chip-month {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  /* ---- Body ---- */
  .event-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
  }

  .event-full-date {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--mist-faint);
    margin: 0;
  }

  .event-body h3 {
    font-size: clamp(19px, 2.2vw, 25px);
    color: var(--text-strong);
    margin: 0;
  }

  .event-description {
    font-size: 15px;
    line-height: 1.65;
    color: var(--mist-muted);
    max-width: 46ch;
    margin: 4px 0 0;
  }

  .event-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--signal);
    width: fit-content;
  }
  .event-cta .arrow {
    transition: transform 0.2s ease;
  }
  a.event-row:hover .event-cta {
    color: var(--mint);
  }
  a.event-row:hover .event-cta .arrow {
    transform: translateX(3px);
  }

  @media (max-width: 760px) {
    .event-row,
    .event-row--flip {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }
    .event-row--flip .event-media,
    .event-row--flip .event-body {
      order: initial;
    }
    .event-media {
      aspect-ratio: 16 / 10;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .event-media img,
    .event-cta .arrow {
      transition: none;
    }
    a.event-row:hover .event-media img {
      transform: none;
    }
  }
</style>