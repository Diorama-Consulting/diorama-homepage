---
// Third leaf-motif variant — many more leaves than FloatingLeaves, moving
// faster, generally falling downward with some drifting straight down and
// others swaying side-to-side as they fall (randomized per leaf). Colour
// restricted to vibrant greens only (--leaf, --ink-accent) — no amber, no
// muted tones — per "much more vibrant green" feedback on the ambient
// version. Loops continuously (unlike FloatingLeaves, which drifts in
// place) — intended for the homepage and other major pages as a livelier
// background layer.
//
// Usage: drop as a child of any `position: relative` container (Section
// already provides this) — fills it via `position: absolute; inset: 0`.
interface Props {
  count?: number;
  seed?: number;
  maxOpacity?: number;
}

const { count = 22, seed = 1, maxOpacity = 0.16 } = Astro.props;

function mulberry32(seedValue: number) {
  return function () {
    seedValue |= 0;
    seedValue = (seedValue + 0x6d2b79f5) | 0;
    let t = Math.imul(seedValue ^ (seedValue >>> 15), 1 | seedValue);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const VARIANTS = ['pointed', 'rounded', 'narrow'] as const;
// Vibrant greens only, deliberately no amber/muted tones this time.
const COLORS = ['var(--leaf)', 'var(--ink-accent)'];

const rand = mulberry32(seed * 151 + 31);
const leaves = Array.from({ length: count }, () => {
  const r1 = rand();
  const r2 = rand();
  const r3 = rand();
  const r4 = rand();
  const r5 = rand();
  const r6 = rand();
  const r7 = rand();
  return {
    left: (r1 * 96).toFixed(1),
    startTop: (r2 * -30 - 2).toFixed(1), // starts above the container, staggered
    size: (14 + r3 * 18).toFixed(0),
    rotStart: Math.round(r4 * 360),
    variant: VARIANTS[Math.floor(r5 * VARIANTS.length)],
    color: COLORS[Math.floor(r6 * COLORS.length)],
    // Some leaves fall almost straight down (small sway), others swing
    // noticeably side-to-side — both patterns mixed across the set.
    sway: Math.round(10 + r7 * 70),
    duration: (5.5 + r3 * 5.5).toFixed(1), // faster than FloatingLeaves' 14-24s ambient drift
    delay: (-(r6 * 12)).toFixed(1),
  };
});
---

<div class="falling-leaves" style={`--max-opacity:${maxOpacity}`} aria-hidden="true">
  <svg width="0" height="0" style="position:absolute">
    <defs>
      <symbol id="leaf-fall-pointed" viewBox="0 0 40 60">
        <path d="M20 2C29 12 34 24 34 36C34 48 28 56 20 58C12 56 6 48 6 36C6 24 11 12 20 2Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-fall-rounded" viewBox="0 0 40 60">
        <path d="M20 6C30 10 36 20 36 32C36 46 29 56 20 58C11 56 4 46 4 32C4 20 10 10 20 6Z" fill="currentColor" />
      </symbol>
      <symbol id="leaf-fall-narrow" viewBox="0 0 40 60">
        <path d="M20 2C25 10 28 20 28 34C28 48 25 56 20 59C15 56 12 48 12 34C12 20 15 10 20 2Z" fill="currentColor" />
      </symbol>
    </defs>
  </svg>

  {leaves.map((leaf) => (
    <svg
      class="falling-leaf"
      viewBox="0 0 40 60"
      style={`left:${leaf.left}%; top:${leaf.startTop}%; width:${leaf.size}px; height:${leaf.size}px; color:${leaf.color}; animation-duration:${leaf.duration}s; animation-delay:${leaf.delay}s; --rot0:${leaf.rotStart}deg; --sway:${leaf.sway}px;`}
    >
      <use href={`#leaf-fall-${leaf.variant}`} width="40" height="60" />
    </svg>
  ))}
</div>

<style>
  .falling-leaves {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .falling-leaf {
    position: absolute;
    opacity: var(--max-opacity, 0.16);
    animation-name: leaf-fall;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  @keyframes leaf-fall {
    0%   { transform: translate(0, 0) rotate(var(--rot0, 0deg)); }
    25%  { transform: translate(var(--sway), 25vh) rotate(calc(var(--rot0, 0deg) + 70deg)); }
    50%  { transform: translate(0, 50vh) rotate(calc(var(--rot0, 0deg) + 160deg)); }
    75%  { transform: translate(calc(var(--sway) * -1), 75vh) rotate(calc(var(--rot0, 0deg) + 250deg)); }
    100% { transform: translate(0, 100vh) rotate(calc(var(--rot0, 0deg) + 360deg)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .falling-leaf {
      display: none;
    }
  }
</style>
