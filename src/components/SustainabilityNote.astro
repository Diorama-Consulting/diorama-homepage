---
// src/components/SustainabilityNote.astro — reworked.
//
// Collapsed bar (always visible): the LIVE Website Carbon badge is now the
// headline — a real per-page measurement from websitecarbon.com, replacing
// the previous self-computed co2.js estimate (the "guessed number", now
// removed entirely). Right side: a label and the Details chevron.
//
// Expanded panel: the Green Web Foundation hosting badge (moved here from
// the collapsed bar), hosting provider/region, verification status, the
// sustainability notes, and methodology links — plus a pointer to the new
// /legal/sustainability page which carries the full story.
//
// Still built on native <details>/<summary>: expand/collapse works with
// zero client JS. The Website Carbon badge is the one external script on
// the page (cached client-side per page per day); showCarbonBadge in
// Keystatic still disables it if ever needed.

interface Props {
  hostingProvider?: string;
  hostingRegion?: string;
  greenHostingVerified?: boolean;
  greenHostingEvidenceUrl?: string;
  sustainabilityNotes?: string;
  showSustainabilitySection?: boolean;
  showGreenBadges?: boolean;
  showCarbonBadge?: boolean;
  showHostingInfo?: boolean;
  showVerificationStatus?: boolean;
  showSustainabilityNotes?: boolean;
  showMethodologyLink?: boolean;
}

const {
  hostingProvider = 'DigitalOcean & Cloudflare',
  hostingRegion,
  greenHostingVerified = false,
  greenHostingEvidenceUrl,
  sustainabilityNotes,
  showSustainabilitySection = true,
  showGreenBadges = true,
  showCarbonBadge = true,
  showHostingInfo = true,
  showVerificationStatus = true,
  showSustainabilityNotes = true,
  showMethodologyLink = false,
} = Astro.props;

const siteDomain = import.meta.env.SITE_DOMAIN || 'dioramas.uk';
const greenCheckImageUrl = `https://app.greenweb.org/api/v3/greencheckimage/${siteDomain}?nocache=true`;
const greenCheckLinkUrl = `https://www.thegreenwebfoundation.org/green-web-check/?url=${siteDomain}`;
const showExpandedGrid = showHostingInfo || showVerificationStatus;
---

{showSustainabilitySection && (
  <details class="sustainability-note">
    <summary class="sustainability-summary">
      {showCarbonBadge && (
        <span class="carbon-live">
          <div id="wcb" class="carbonbadge wcb-d"></div>
          <script is:inline src="https://unpkg.com/website-carbon-badges@1.1.3/b.min.js" defer></script>
        </span>
      )}

      <span class="sustainability-label">
        <span class="label-title">This page's carbon footprint</span>
        <span class="label-sub">Measured live by Website Carbon</span>
      </span>

      <span class="sustainability-spacer"></span>

      <span class="sustainability-toggle" aria-hidden="true">
        <span class="toggle-text">Details</span>
        <svg class="sustainability-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 9l6 6 6-6" />
        </svg>
      </span>
    </summary>

    <div class="sustainability-panel">
      <div class="panel-columns">
        {showGreenBadges && (
          <a class="green-badge" href={greenCheckLinkUrl} target="_blank" rel="noopener noreferrer" aria-label="Green Web Foundation check for this site">
            <img src={greenCheckImageUrl} alt="This website runs on green hosting - verified by thegreenwebfoundation.org" width="160" height="66" loading="lazy" />
          </a>
        )}

        {showExpandedGrid && (
          <div class="sustainability-grid">
            {showHostingInfo && (
              <div class="sustainability-stat">
                <span class="stat-value">{hostingProvider}{hostingRegion && ` · ${hostingRegion}`}</span>
                <span class="stat-label">Current hosting</span>
              </div>
            )}
            {showVerificationStatus && (
              <div class="sustainability-stat">
                <span class="stat-value">{greenHostingVerified ? 'Verified green' : 'Not yet verified'}</span>
                <span class="stat-label">
                  <a href={greenCheckLinkUrl} target="_blank" rel="noopener noreferrer">Green Web Foundation status →</a>
                  {greenHostingEvidenceUrl && (
                    <>
                      {' '}·{' '}
                      <a href={greenHostingEvidenceUrl} target="_blank" rel="noopener noreferrer">Evidence →</a>
                    </>
                  )}
                </span>
              </div>
            )}
          </div>
        )}
      </div>

      {showSustainabilityNotes && sustainabilityNotes && (
        <p class="sustainability-notes">{sustainabilityNotes}</p>
      )}

      <p class="sustainability-more">
        Full detail on how this site is built and hosted: <a href="/legal/sustainability/">Sustainability →</a>
        {showMethodologyLink && (
          <>
            {' '}· Live badge via <a href="https://www.websitecarbon.com/" target="_blank" rel="noopener noreferrer">Website Carbon</a>
          </>
        )}
      </p>
    </div>
  </details>
)}

<style>
  .sustainability-note {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--ink-border);
    border-radius: var(--radius-lg);
    padding: 4px;
    transition: border-color 0.25s ease;
  }
  .sustainability-note:hover {
    border-color: var(--ink-border-hover);
  }

  .sustainability-summary {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 14px 20px;
    cursor: pointer;
    list-style: none;
  }
  .sustainability-summary::-webkit-details-marker { display: none; }
  .sustainability-summary::marker { content: ''; }

  /* The live badge — the star of the bar. wcb-d is the badge's own dark
     variant, which sits naturally on the ink footer. */
  .carbon-live {
    flex-shrink: 0;
    min-height: 28px;
    display: flex;
    align-items: center;
  }

  .sustainability-label {
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.2;
  }
  .label-title {
    font-family: var(--font-display);
    font-size: 14.5px;
    font-weight: 600;
    color: var(--ink-text);
  }
  .label-sub {
    font-size: 12px;
    color: var(--ink-text-muted);
  }

  .sustainability-spacer { flex: 1 1 auto; }

  .sustainability-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--ink-text-muted);
    flex-shrink: 0;
  }
  .toggle-text {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .sustainability-chevron {
    transition: transform 0.25s ease;
  }
  details[open] .sustainability-chevron {
    transform: rotate(180deg);
  }

  /* ---- Expanded ---- */
  .sustainability-panel {
    padding: 6px 20px 18px;
    border-top: 1px solid var(--ink-border);
    margin: 0 4px;
  }

  .panel-columns {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    padding-top: 16px;
  }

  .green-badge img {
    display: block;
    opacity: 0.92;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .green-badge:hover img {
    opacity: 1;
    transform: translateY(-1px);
  }

  .sustainability-grid {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }
  .sustainability-stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .stat-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink-text);
  }
  .stat-label {
    font-size: 12px;
    color: var(--ink-text-muted);
  }
  .stat-label a {
    color: var(--ink-accent);
    text-decoration: none;
  }
  .stat-label a:hover { text-decoration: underline; }

  .sustainability-notes {
    font-size: 13px;
    line-height: 1.6;
    color: var(--ink-text-muted);
    max-width: 640px;
    margin: 14px 0 0;
  }

  .sustainability-more {
    font-size: 12.5px;
    color: var(--ink-text-muted);
    margin: 12px 0 0;
  }
  .sustainability-more a {
    color: var(--ink-accent);
    text-decoration: none;
  }
  .sustainability-more a:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .sustainability-summary { flex-wrap: wrap; gap: 12px; }
    .sustainability-label { min-width: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .sustainability-chevron,
    .green-badge img { transition: none; }
  }
</style>
