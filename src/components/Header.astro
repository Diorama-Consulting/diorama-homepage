---
import Button from './Button.astro';
import { Image } from 'astro:assets';
import dioramaLogo from '../assets/Logo.svg';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  logoText?: string;
  links?: NavLink[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  logoText = 'Diorama',
  links = [
    { label: 'Insights', href: '/insights' },
    { label: 'Services', href: '/services' },
    { label: 'Tools', href: '/tools' },
    { label: 'About', href: '/about' },
  ],
  ctaText = 'Contact',
  ctaHref = '/contact',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="site-header header-preload" id="site-header">
  <div class="container nav">
    <a href="/" class="logo">
      <span class="logo-mark-wrap">
        <!-- Solid white silhouette via CSS filter stack. 
            This bypasses the low-res rasterization bug caused by nested SVG masks, 
            and brightness(0) invert(1) is mathematically guaranteed to yield true white. -->
        <Image 
          src={dioramaLogo} 
          alt="" 
          class="logo-mark logo-mark-mono" 
          aria-hidden="true" 
        />
        <Image src={dioramaLogo} alt="" class="logo-mark logo-mark-colour" />
      </span>                         
      <span class="logo-text">{logoText}</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((link) => (
        <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
          {link.label}
        </a>
      ))}
      <Button href={ctaHref} size="sm">{ctaText}</Button>
    </nav>

    <button
      class="menu-toggle"
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile">
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
    <Button href={ctaHref} size="sm" class="mobile-cta">{ctaText}</Button>
  </nav>
</header>

<!-- Runs synchronously, immediately after the header exists in the DOM and
     BEFORE first paint: sets the condensed state if the page loads already
     scrolled (browser scroll restoration on reload), then lifts the
     transition freeze on the next frame so normal animation resumes.
     This is what stops the bar visibly "enlarging then shrinking" on
     reload. -->
<script is:inline>
  (function () {
    var h = document.getElementById('site-header');
    if (!h) return;
    if (window.scrollY > 90) h.classList.add('is-scrolled');
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        h.classList.remove('header-preload');
      });
    });
  })();
</script>

<style>
  /* SCROLL-GLITCH FIX (the "white fading in at the top" on light pages):
     two things caused it and both are gone.
       1. backdrop-filter: blur() on a sticky bar over a near-white page —
          the blur samples the light content beneath/around the bar's
          edge, which reads as a white haze bleeding in from the top the
          moment the compositor promotes the layer (~the is-scrolled
          toggle, i.e. after about 2cm of scroll). The header background
          is fully opaque, so the blur contributed nothing visually —
          removed entirely.
       2. `background` was in the transition list while toggling between
          a GRADIENT (base) and a semi-transparent color-mix (scrolled).
          Gradients and flat colours can't interpolate, so the browser
          snapped between them mid-"transition" — a visible flicker, and
          the 6% transparency let the white page glow through. The bar is
          now opaque in both states and `background` is no longer
          transitioned at all.
     RELOAD-JUMP FIX: the scrolled state is applied by a tiny inline
     script (below, runs before first paint) AND transitions are disabled
     until the first frame via .header-preload — so reloading mid-page
     renders the condensed bar instantly instead of animating from the
     tall one. */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(180deg, var(--ink-bg) 0%, var(--ink-bg-2) 100%);
    border-bottom: 1px solid var(--ink-border);
    transition: border-color 0.35s ease, box-shadow 0.35s ease;
  }

  /* Condensed once scrolled — same bar, just tightened up. Fully opaque. */
  .site-header.is-scrolled {
    border-bottom-color: var(--ink-border-hover);
    box-shadow: 0 4px 24px hsl(var(--hue-green) 60% 4% / 0.35);
  }

  /* Kill ALL descendant transitions for the very first frame so a reload
     mid-scroll paints the final (condensed) geometry with zero motion. */
  .site-header.header-preload,
  .site-header.header-preload * {
    transition: none !important;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 24px;
    transition: padding 0.35s ease;
  }
  .site-header.is-scrolled .nav {
    padding-block: 14px;
  }

  /* --- Logo: Much bigger, interactive hover state --- */
  .logo {
    display: flex;
    align-items: center;
    gap: 20px; /* More breathing room between mark and wordmark */
    text-decoration: none;
    transform-origin: left center;
    /* Adds a nice bouncy feel to the hover enlargement */
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .logo:hover {
    transform: scale(1.08);
  }

  .logo-mark-wrap {
    position: relative;
    display: inline-flex;
    height: 72px; /* Increased from 34px */
    transition: height 0.35s ease;
  }
  .site-header.is-scrolled .logo-mark-wrap {
    height: 34px; /* Condenses down nicely */
  }

  .logo-mark {
    height: 100%;
    width: auto;
    transform-origin: center;
    transition: opacity 0.3s ease,
      transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  /* White silhouette: a solid white box cut to the logo's shape via
     mask, so it's guaranteed flat white regardless of the source
     colours — no dependence on filter() interactions. Sits on top by
     default. */
  .logo-mark-mono {
    position: absolute;
    inset: 0;
    filter: brightness(0) invert(1);
    -webkit-filter: brightness(0) invert(1);
  }

  /* Full-colour version underneath, revealed on hover. */
  .logo-mark-colour {
    position: relative;
    opacity: 0;
  }

  .logo:hover .logo-mark-mono {
    opacity: 0;
  }
  .logo:hover .logo-mark-colour {
    opacity: 1;
  }
  .logo:hover .logo-mark {
    transform: scale(1.15);
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px; /* Increased from 21px */
    letter-spacing: -0.015em;
    color: var(--ink-text);
    transition: font-size 0.35s ease;
  }
  .site-header.is-scrolled .logo-text {
    font-size: 21px; /* Shrinks to the original default size */
  }

  /* --- Nav links with an animated underline --- */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 34px;
    font-size: 14.5px;
    letter-spacing: 0.01em;
  }
  .nav-links a:not(.btn) {
    position: relative;
    color: var(--ink-text-muted);
    font-weight: 500;
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.2s ease;
  }
  .nav-links a:not(.btn)::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--ink-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-links a:not(.btn):hover {
    color: var(--ink-accent-hover);
  }
  .nav-links a:not(.btn):hover::after,
  .nav-links a:not(.btn)[aria-current='page']::after {
    transform: scaleX(1);
  }
  .nav-links a:not(.btn)[aria-current='page'] {
    color: var(--ink-accent-hover);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--ink-text);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Mobile menu --- */
  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 24px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    border-top: 1px solid transparent;
    transition: max-height 0.3s ease, opacity 0.2s ease, padding 0.3s ease;
  }
  .mobile-menu.is-open {
    max-height: 420px;
    opacity: 1;
    padding: 8px 24px 20px;
    border-top-color: var(--ink-border);
  }
  .mobile-menu a:not(.btn) {
    color: var(--ink-text-muted);
    text-decoration: none;
    padding: 10px 0;
    font-size: 15px;
  }
  .mobile-menu a:not(.btn):hover {
    color: var(--ink-accent-hover);
  }
  .mobile-cta {
    margin-top: 8px;
    align-self: flex-start;
  }

  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .nav,
    .logo,
    .logo-mark-wrap,
    .logo-mark,
    .logo-text,
    .mobile-menu {
      transition: none;
    }
    .logo:hover {
      transform: none;
    }
    .logo:hover .logo-mark {
      transform: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  if (header) {
    // Hysteresis: the bar condenses at 90px but only expands again below
    // 30px. Shrinking the sticky bar changes the page's own height, which
    // nudges scrollY — with a single threshold that could oscillate the
    // class on/off in a loop right at the boundary (another source of the
    // reported top-of-page glitching). Two well-separated thresholds make
    // that impossible.
    const ENTER = 90;
    const EXIT = 30;
    let ticking = false;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const scrolled = header.classList.contains('is-scrolled');
        if (!scrolled && y > ENTER) header.classList.add('is-scrolled');
        else if (scrolled && y < EXIT) header.classList.remove('is-scrolled');
        ticking = false;
      });
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>