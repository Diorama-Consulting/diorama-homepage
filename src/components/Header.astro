---
import Button from './Button.astro';
import { Image } from 'astro:assets';
import dioramaLogo from '../assets/Logo.svg';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  logoText?: string;
  links?: NavLink[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  logoText = 'Diorama',
  links = [
    { label: 'Insights', href: '/insights' },
    { label: 'Services', href: '/services' },
    { label: 'Tools', href: '/tools' },
    { label: 'About', href: '/about' },
  ],
  ctaText = 'Contact',
  ctaHref = '/contact',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="container nav">
    <a href="/" class="logo">
      <Image src={dioramaLogo} alt="" class="logo-mark" />
      <span class="logo-text">{logoText}</span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      {links.map((link) => (
        <a href={link.href} aria-current={currentPath === link.href ? 'page' : undefined}>
          {link.label}
        </a>
      ))}
      <Button href={ctaHref} size="sm">{ctaText}</Button>
    </nav>

    <button
      class="menu-toggle"
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile">
    {links.map((link) => <a href={link.href}>{link.label}</a>)}
    <Button href={ctaHref} size="sm" class="mobile-cta">{ctaText}</Button>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: linear-gradient(180deg, var(--ink-bg) 0%, var(--ink-bg-2) 100%);
    border-bottom: 1px solid var(--ink-border);
    /* backdrop-filter is constant (see below) precisely so it never has
       to be transitioned — see the comment on .is-scrolled for why. */
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    transition: padding 0.35s ease,
      border-color 0.35s ease, box-shadow 0.35s ease, background 0.35s ease;
  }

  /* Slightly darker and condensed once scrolled — same bar, just tightened up.
     THE SCROLL GLITCH FIX: backdrop-filter used to live only here and was
     included in the transition list above, meaning the browser animated it
     from "none" to "blur(16px)" over 0.35s every time is-scrolled toggled.
     Animating backdrop-filter is a known cross-browser flicker source — the
     GPU has to build a new blur-sampling compositor layer mid-transition,
     and on a light-background page behind a dark header that showed up as
     exactly the "white band blurring in" glitch described. Fix: backdrop-
     filter is now constant on the base rule above (harmless there since the
     base background is fully opaque, so blur has nothing to show through
     yet) — only background opacity/border/shadow animate here now, all of
     which are simple colour interpolations with no equivalent flicker risk. */
  .site-header.is-scrolled {
    background: color-mix(in srgb, var(--ink-bg-2) 94%, transparent);
    border-bottom-color: var(--ink-border-hover);
    box-shadow: 0 4px 24px hsl(var(--hue-green) 60% 4% / 0.35);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 24px;
    transition: padding 0.35s ease;
  }
  .site-header.is-scrolled .nav {
    padding-block: 14px;
  }

  /* --- Logo: Much bigger, interactive hover state --- */
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    transform-origin: left center;
    /* Adds a nice bouncy feel to the hover enlargement */
    transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .logo:hover {
    transform: scale(1.08);
  }

  .logo-mark {
    height: 48px; /* Increased from 34px */
    width: auto;
    transition: height 0.35s ease;
  }
  .site-header.is-scrolled .logo-mark {
    height: 34px; /* Condenses down nicely */
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px; /* Increased from 21px */
    letter-spacing: -0.015em;
    color: var(--ink-text);
    transition: font-size 0.35s ease;
  }
  .site-header.is-scrolled .logo-text {
    font-size: 21px; /* Shrinks to the original default size */
  }

  /* --- Nav links with an animated underline --- */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 34px;
    font-size: 14.5px;
    letter-spacing: 0.01em;
  }
  .nav-links a:not(.btn) {
    position: relative;
    color: var(--ink-text-muted);
    font-weight: 500;
    text-decoration: none;
    padding: 4px 0;
    transition: color 0.2s ease;
  }
  .nav-links a:not(.btn)::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--ink-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-links a:not(.btn):hover {
    color: var(--ink-accent-hover);
  }
  .nav-links a:not(.btn):hover::after,
  .nav-links a:not(.btn)[aria-current='page']::after {
    transform: scaleX(1);
  }
  .nav-links a:not(.btn)[aria-current='page'] {
    color: var(--ink-accent-hover);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .menu-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--ink-text);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Mobile menu --- */
  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 24px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    border-top: 1px solid transparent;
    transition: max-height 0.3s ease, opacity 0.2s ease, padding 0.3s ease;
  }
  .mobile-menu.is-open {
    max-height: 420px;
    opacity: 1;
    padding: 8px 24px 20px;
    border-top-color: var(--ink-border);
  }
  .mobile-menu a:not(.btn) {
    color: var(--ink-text-muted);
    text-decoration: none;
    padding: 10px 0;
    font-size: 15px;
  }
  .mobile-menu a:not(.btn):hover {
    color: var(--ink-accent-hover);
  }
  .mobile-cta {
    margin-top: 8px;
    align-self: flex-start;
  }

  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .nav,
    .logo,
    .logo-mark,
    .logo-text,
    .mobile-menu {
      transition: none;
    }
    .logo:hover {
      transform: none;
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  if (header) {
    const THRESHOLD = 80;
    let ticking = false;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        header.classList.toggle('is-scrolled', window.scrollY > THRESHOLD);
        ticking = false;
      });
    };

    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>