---
// Full-screen hero carousel — the dynamic alternative to the static Hero.
// Cycles through up to 4 featured articles (picked in Keystatic on the
// Homepage singleton), each rendered as a full-bleed slide with the
// ShaderCanvas layered on top in 'screen' blend mode for a subtle moving
// colour-field over the photography. Desktop: hover-revealed arrows,
// bottom-right. Mobile: native swipe (CSS scroll-snap) + dot indicators,
// titles centred with generous padding. Autoplays gently; pauses on
// hover/focus/touch and respects prefers-reduced-motion.
import ShaderCanvas from './ShaderCanvas.astro';
import Button from './Button.astro';

interface Slide {
  eyebrow?: string;
  title: string;
  description?: string;
  image: string;
  imageAlt?: string;
  href: string;
  linkText?: string;
}

interface Props {
  slides: Slide[];
  heading?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { slides, ctaText = 'Get started', ctaHref = '/contact' } = Astro.props;
---

<section class="hero-carousel" aria-roledescription="carousel" aria-label="Featured articles">
  <ShaderCanvas opacity={0.32} class="hero-carousel-shader" />

  <div class="hero-carousel-track" id="hero-carousel-track">
    {slides.map((slide, i) => (
      <article class="hero-slide" data-index={i} aria-hidden={i === 0 ? 'false' : 'true'}>
        <img src={slide.image} alt={slide.imageAlt ?? ''} class="hero-slide-bg" loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'low'} />
        <div class="hero-slide-scrim" aria-hidden="true"></div>
        <div class="container hero-slide-content">
          <p class="eyebrow">{slide.eyebrow ?? 'Featured'}</p>
          <h1>{slide.title}</h1>
          {slide.description && <p class="subheading">{slide.description}</p>}
          <div class="hero-actions">
            <a class="hero-slide-link" href={slide.href}>{slide.linkText ?? 'Read article'} →</a>
            <Button href={ctaHref} variant="secondary">{ctaText}</Button>
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="hero-carousel-controls">
    <button type="button" class="hero-arrow hero-arrow-prev" aria-label="Previous slide">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
    </button>
    <button type="button" class="hero-arrow hero-arrow-next" aria-label="Next slide">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
    </button>
  </div>

  <div class="hero-carousel-dots" role="tablist" aria-label="Slides">
    {slides.map((_, i) => (
      <button type="button" class="hero-dot" data-index={i} aria-selected={i === 0 ? 'true' : 'false'} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background: var(--canopy);
  }

  .hero-carousel-shader {
    z-index: 1;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-carousel-track {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .hero-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .hero-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    scroll-snap-align: start;
  }

  .hero-slide-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
  }

  .hero-slide-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--gradient-hero);
  }

  .hero-slide-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 680px;
  }

  .hero-slide-content .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mint);
    margin: 0 0 18px;
  }

  .hero-slide-content h1 {
    font-size: clamp(32px, 4.4vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 20px;
    color: #fff;
  }

  .hero-slide-content .subheading {
    font-size: 17px;
    color: rgba(255, 255, 255, 0.82);
    margin: 0 0 32px;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .hero-slide-link {
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    border-bottom: 1.5px solid var(--signal);
    padding-bottom: 2px;
  }
  .hero-slide-link:hover {
    color: var(--mint);
    border-color: var(--mint);
  }

  /* ---- Desktop arrows: bottom-right, revealed on hover ---- */
  .hero-carousel-controls {
    position: absolute;
    z-index: 3;
    right: var(--space-lg);
    bottom: var(--space-lg);
    display: flex;
    gap: 10px;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .hero-carousel:hover .hero-carousel-controls,
  .hero-carousel:focus-within .hero-carousel-controls {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid hsl(0 0% 100% / 0.25);
    background: hsl(0 0% 0% / 0.25);
    backdrop-filter: blur(6px);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .hero-arrow:hover {
    background: hsl(0 0% 0% / 0.45);
    border-color: var(--signal);
  }

  /* ---- Dots: hidden on desktop (arrows do the job), shown on mobile ---- */
  .hero-carousel-dots {
    position: absolute;
    z-index: 3;
    left: 0;
    right: 0;
    bottom: var(--space-sm);
    display: none;
    justify-content: center;
    gap: 8px;
  }

  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: hsl(0 0% 100% / 0.35);
    padding: 0;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .hero-dot[aria-selected='true'] {
    background: var(--signal);
    transform: scale(1.3);
  }

  /* ---- Mobile: centred titles, generous padding, swipe + dots, no hover arrows ---- */
  @media (max-width: 700px) {
    .hero-carousel-controls {
      display: none;
    }
    .hero-carousel-dots {
      display: flex;
    }
    .hero-slide-content {
      text-align: center;
      align-items: center;
      max-width: none;
      padding-inline: var(--space-md);
      padding-bottom: var(--space-xl);
    }
    .hero-slide-content .subheading {
      max-width: 420px;
      margin-inline: auto;
    }
    .hero-actions {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-carousel-controls,
    .hero-dot {
      transition: none;
    }
  }
</style>

<script>
  function initHeroCarousel() {
    const track = document.getElementById('hero-carousel-track');
    const carousel = track?.closest('.hero-carousel');
    if (!track || !carousel) return;

    const slides = Array.from(track.querySelectorAll<HTMLElement>('.hero-slide'));
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>('.hero-dot'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('.hero-arrow-prev');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('.hero-arrow-next');
    let active = 0;
    let autoplayId: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      active = (index + slides.length) % slides.length;
      slides[active].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== active)));
      dots.forEach((d, i) => d.setAttribute('aria-selected', String(i === active)));
    }

    prevBtn?.addEventListener('click', () => goTo(active - 1));
    nextBtn?.addEventListener('click', () => goTo(active + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Keep dots/aria in sync when the user swipes on mobile.
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.6) {
            const idx = Number((entry.target as HTMLElement).dataset.index);
            active = idx;
            slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== idx)));
            dots.forEach((d, i) => d.setAttribute('aria-selected', String(i === idx)));
          }
        });
      },
      { root: track, threshold: [0.6] },
    );
    slides.forEach((s) => observer.observe(s));

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (slides.length > 1 && !reduceMotion) {
      const start = () => {
        autoplayId = setInterval(() => goTo(active + 1), 7000);
      };
      const stop = () => {
        if (autoplayId) clearInterval(autoplayId);
      };
      start();
      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);
      carousel.addEventListener('touchstart', stop, { passive: true });
    }
  }

  initHeroCarousel();
  document.addEventListener('astro:page-load', initHeroCarousel);
</script>
