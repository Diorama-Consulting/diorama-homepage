---
// Full-screen hero carousel, styled after a large professional-services
// site pattern: left-aligned editorial content over a horizontal
// dark-to-transparent scrim (so the photo stays visible on the right),
// a small green vertical accent bar beside the body copy, and a
// persistent (always-visible, not hover-only) bottom bar with text-tab
// navigation on the left and prev/next/play-pause controls on the right.
//
// ShaderCanvas still runs underneath in 'screen' blend mode for the
// "dynamic feel" — subtle enough not to fight the new, more editorial
// layout.
import ShaderCanvas from './ShaderCanvas.astro';

interface Slide {
  eyebrow?: string;
  title: string;
  description?: string;
  image: string;
  imageAlt?: string;
  href: string;
  linkText?: string;
  /** Short label for the bottom tab strip — falls back to a truncated title. */
  tabLabel?: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;

function shortTabLabel(slide: Slide) {
  if (slide.tabLabel) return slide.tabLabel;
  const words = slide.title.split(' ');
  return words.length > 3 ? `${words.slice(0, 3).join(' ')}…` : slide.title;
}
---

<section class="hero-carousel" aria-roledescription="carousel" aria-label="Featured articles">
  <ShaderCanvas opacity={0.22} class="hero-carousel-shader" />

  <div class="hero-carousel-track" id="hero-carousel-track">
    {slides.map((slide, i) => (
      <article class="hero-slide" data-index={i} aria-hidden={i === 0 ? 'false' : 'true'}>
        <img src={slide.image} alt={slide.imageAlt ?? ''} class="hero-slide-bg" data-parallax loading={i === 0 ? 'eager' : 'lazy'} fetchpriority={i === 0 ? 'high' : 'low'} />
        <div class="hero-slide-scrim" aria-hidden="true"></div>
        <div class="container hero-slide-content">
          <p class="eyebrow">{slide.eyebrow ?? 'Featured'}</p>
          <h1>{slide.title}</h1>
          {slide.description && (
            <div class="hero-slide-body">
              <span class="body-accent" aria-hidden="true"></span>
              <p class="subheading">{slide.description}</p>
            </div>
          )}
          <a class="hero-slide-link" href={slide.href}>{slide.linkText ?? 'Read article'} →</a>
        </div>
      </article>
    ))}
  </div>

  <div class="hero-carousel-bar">
    <div class="container hero-carousel-bar-inner">
      <div class="hero-tabs" role="tablist" aria-label="Slides">
        {slides.map((slide, i) => (
          <button type="button" class="hero-tab" data-index={i} aria-selected={i === 0 ? 'true' : 'false'} role="tab">
            {shortTabLabel(slide)}
          </button>
        ))}
      </div>

      <div class="hero-carousel-controls">
        <button type="button" class="hero-control hero-control-prev" aria-label="Previous slide">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6" /></svg>
        </button>
        <button type="button" class="hero-control hero-control-next" aria-label="Next slide">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6" /></svg>
        </button>
        <button type="button" class="hero-control hero-control-playpause" aria-label="Pause autoplay" data-playing="true">
          <svg class="icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14" rx="1" /><rect x="14" y="5" width="4" height="14" rx="1" /></svg>
          <svg class="icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    height: 100vh;
    min-height: 620px;
    overflow: hidden;
    background: var(--canopy);
  }

  .hero-carousel-shader {
    z-index: 1;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-carousel-track {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }
  .hero-carousel-track::-webkit-scrollbar {
    display: none;
  }

  .hero-slide {
    position: relative;
    flex: 0 0 100%;
    height: 100%;
    scroll-snap-align: start;
    overflow: hidden;
  }

  .hero-slide-bg {
    position: absolute;
    inset: -4% 0 0 0;
    width: 100%;
    height: 108%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    will-change: transform;
  }

  .hero-slide-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--gradient-hero-horizontal), var(--gradient-hero);
  }

  /* ---- Left-aligned editorial content block, sitting above the bottom bar ---- */
  .hero-slide-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-bottom: 96px; /* clears the persistent bottom bar */
    max-width: 700px;
  }

  .hero-slide-content .eyebrow {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--signal);
    margin: 0 0 20px;
  }

  .hero-slide-content h1 {
    font-size: clamp(34px, 4.6vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    font-weight: 700;
    margin: 0 0 24px;
    color: #fff;
  }

  .hero-slide-body {
    display: flex;
    gap: 16px;
    margin-bottom: 28px;
  }

  .body-accent {
    flex-shrink: 0;
    width: 3px;
    border-radius: 2px;
    background: var(--signal);
  }

  .hero-slide-content .subheading {
    font-size: 16.5px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.82);
    margin: 0;
    max-width: 520px;
  }

  .hero-slide-link {
    align-self: flex-start;
    font-weight: 600;
    font-size: 14.5px;
    color: #fff;
    text-decoration: none;
    border-bottom: 1.5px solid var(--signal);
    padding-bottom: 3px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .hero-slide-link:hover {
    color: var(--mint);
    border-color: var(--mint);
  }

  /* ---- Persistent bottom bar: tabs (left) + controls (right), always visible ---- */
  .hero-carousel-bar {
    position: absolute;
    z-index: 3;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--gradient-hero-bottom-bar);
    border-top: 1px solid hsl(0 0% 100% / 0.1);
    padding-top: 12px;
  }

  .hero-carousel-bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-bottom: 22px;
  }

  .hero-tabs {
    display: flex;
    align-items: center;
    gap: 28px;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .hero-tabs::-webkit-scrollbar {
    display: none;
  }

  .hero-tab {
    position: relative;
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 8px 0;
    font-family: var(--font-body);
    font-size: 14.5px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
    cursor: pointer;
    transition: color 0.25s ease;
  }
  .hero-tab::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--signal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }
  .hero-tab:hover {
    color: rgba(255, 255, 255, 0.8);
  }
  .hero-tab[aria-selected='true'] {
    color: #fff;
  }
  .hero-tab[aria-selected='true']::after {
    transform: scaleX(1);
  }

  .hero-carousel-controls {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .hero-control {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid hsl(0 0% 100% / 0.2);
    background: hsl(0 0% 0% / 0.3);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .hero-control:hover {
    background: hsl(0 0% 0% / 0.5);
    border-color: var(--signal);
  }

  .hero-control-playpause .icon-play {
    display: none;
  }
  .hero-control-playpause[data-playing='false'] .icon-pause {
    display: none;
  }
  .hero-control-playpause[data-playing='false'] .icon-play {
    display: block;
  }

  /* ---- Mobile: centred titles, generous padding, tabs scroll horizontally ---- */
  @media (max-width: 700px) {
    .hero-slide-content {
      text-align: center;
      align-items: center;
      max-width: none;
      padding-inline: var(--space-md);
    }
    .hero-slide-body {
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .body-accent {
      width: 28px;
      height: 3px;
    }
    .hero-slide-content .subheading {
      max-width: 420px;
      margin-inline: auto;
    }
    .hero-carousel-bar-inner {
      flex-direction: column;
      align-items: stretch;
      gap: 14px;
    }
    .hero-tabs {
      justify-content: flex-start;
    }
    .hero-carousel-controls {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-slide-bg {
      transform: none !important;
    }
  }
</style>

<script>
  function initHeroCarousel() {
    const track = document.getElementById('hero-carousel-track');
    const carousel = track?.closest('.hero-carousel');
    if (!track || !carousel) return;

    const slides = Array.from(track.querySelectorAll<HTMLElement>('.hero-slide'));
    const tabs = Array.from(carousel.querySelectorAll<HTMLButtonElement>('.hero-tab'));
    const prevBtn = carousel.querySelector<HTMLButtonElement>('.hero-control-prev');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('.hero-control-next');
    const playPauseBtn = carousel.querySelector<HTMLButtonElement>('.hero-control-playpause');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let active = 0;
    let autoplayId: ReturnType<typeof setInterval> | null = null;
    let playing = !reduceMotion;

    function goTo(index: number) {
      active = (index + slides.length) % slides.length;
      slides[active].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== active)));
      tabs.forEach((t, i) => t.setAttribute('aria-selected', String(i === active)));
    }

    prevBtn?.addEventListener('click', () => goTo(active - 1));
    nextBtn?.addEventListener('click', () => goTo(active + 1));
    tabs.forEach((tab, i) => tab.addEventListener('click', () => goTo(i)));

    function startAutoplay() {
      if (slides.length < 2) return;
      autoplayId = setInterval(() => goTo(active + 1), 7000);
    }
    function stopAutoplay() {
      if (autoplayId) clearInterval(autoplayId);
      autoplayId = null;
    }

    playPauseBtn?.addEventListener('click', () => {
      playing = !playing;
      playPauseBtn.dataset.playing = String(playing);
      playPauseBtn.setAttribute('aria-label', playing ? 'Pause autoplay' : 'Resume autoplay');
      if (playing) startAutoplay();
      else stopAutoplay();
    });

    if (playPauseBtn) {
      playPauseBtn.dataset.playing = String(playing);
      playPauseBtn.setAttribute('aria-label', playing ? 'Pause autoplay' : 'Resume autoplay');
    }

    // Keep tabs/aria in sync when the user swipes on mobile.
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && entry.intersectionRatio > 0.6) {
            const idx = Number((entry.target as HTMLElement).dataset.index);
            active = idx;
            slides.forEach((s, i) => s.setAttribute('aria-hidden', String(i !== idx)));
            tabs.forEach((t, i) => t.setAttribute('aria-selected', String(i === idx)));
          }
        });
      },
      { root: track, threshold: [0.6] },
    );
    slides.forEach((s) => observer.observe(s));

    if (playing) {
      startAutoplay();
      carousel.addEventListener('mouseenter', stopAutoplay);
      carousel.addEventListener('mouseleave', () => { if (playing) startAutoplay(); });
    }

    // ---- Subtle scroll parallax on the background images ----
    if (!reduceMotion) {
      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const rect = carousel.getBoundingClientRect();
          // Only move while the hero is at least partially in view.
          if (rect.bottom > 0 && rect.top < window.innerHeight) {
            const progress = Math.min(Math.max(-rect.top / rect.height, 0), 1);
            const offset = progress * 40; // px of drift, subtle
            track.querySelectorAll<HTMLImageElement>('[data-parallax]').forEach((img) => {
              img.style.transform = `translateY(${offset}px)`;
            });
          }
          ticking = false;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }

  initHeroCarousel();
  document.addEventListener('astro:page-load', initHeroCarousel);
</script>
