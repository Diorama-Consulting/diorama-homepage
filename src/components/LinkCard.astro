---
// Single consistent "box link" pattern for the whole site: homepage explore
// cards, homepage network widgets, services tiles, and anywhere else a
// clickable box with a title/description is needed. The whole box is the
// link (not just a "learn more →" line), it supports an optional image with
// a subtle zoom-on-hover, and it lifts + gains an accent border on hover.
// Use this instead of ad-hoc `.card`/`.service-tile`/`.widget-card` styles.
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  href?: string;
  linkText?: string;
  image?: ImageMetadata | string;
  imageAlt?: string;
  external?: boolean;
  /** 'default' = image on top, text below. 'compact' = no image, denser padding (for icon-led grids). */
  variant?: 'default' | 'compact';
}

const {
  title,
  description,
  eyebrow,
  href,
  linkText = 'Learn more',
  image,
  imageAlt = '',
  external = false,
  variant = 'default',
} = Astro.props;

const Tag = href ? 'a' : 'div';
const imageSrc = typeof image === 'string' ? image : image?.src;
---

<Tag
  class:list={['link-card', `link-card--${variant}`, image && 'has-image']}
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
>
  {imageSrc && (
    <div class="link-card-media">
      <img src={imageSrc} alt={imageAlt} loading="lazy" decoding="async" />
    </div>
  )}
  <div class="link-card-body">
    {eyebrow && <span class="link-card-eyebrow">{eyebrow}</span>}
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    {href && <span class="link-card-cta">{external ? `${linkText} ↗` : `${linkText} →`}</span>}
  </div>
</Tag>

<style>
  .link-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    height: 100%;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  a.link-card {
    cursor: pointer;
  }

  a.link-card:hover,
  a.link-card:focus-visible {
    border-color: var(--moss);
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  a.link-card:focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 2px;
  }

  .link-card-media {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--pine);
  }

  .link-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  a.link-card:hover .link-card-media img {
    transform: scale(1.06);
  }

  .link-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding: var(--space-md);
    flex-grow: 1;
  }

  .link-card--compact .link-card-body {
    padding: var(--space-sm);
  }

  .link-card-eyebrow {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mint);
  }

  .link-card-body h3 {
    font-size: 18px;
  }

  .link-card-body p {
    color: var(--mist-muted);
    font-size: 14.5px;
    margin: 0;
    flex-grow: 1;
  }

  .link-card-cta {
    margin-top: var(--space-2xs);
    font-size: 13.5px;
    font-weight: 600;
    color: var(--signal);
    transition: color 0.2s ease;
  }

  a.link-card:hover .link-card-cta {
    color: var(--mint);
  }
</style>
