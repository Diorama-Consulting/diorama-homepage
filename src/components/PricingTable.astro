---
import Button from './Button.astro';

interface Tier {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  ctaText?: string;
  ctaHref?: string;
  featured?: boolean;
}

interface Props {
  tiers?: Tier[];
}

const {
  tiers = [
    {
      name: 'Starter',
      price: '$0',
      period: '/mo',
      description: 'For small sites and side projects.',
      features: ['1 meeting', 'Business Reccomendations', 'Basic analytics'],
      ctaText: 'Start free',
      ctaHref: '#',
    },
    {
      name: 'Pro',
      price: '$29',
      period: '/mo',
      description: 'For growing teams shipping regularly.',
      features: ['Unlimited conversations', 'Priority support', 'Advanced analytics', '10 hour lectures'],
      ctaText: 'Start free trial',
      ctaHref: '#',
      featured: true,
    },
    {
      name: 'Enterprise',
      price: 'Custom',
      description: 'For organisations with extensive needs.',
      features: ['Everything in Pro', 'Dedicated support', 'Cricket nets sessions', 'Long walks'],
      ctaText: 'Contact sales',
      ctaHref: '#',
    },
  ],
} = Astro.props;
---

<div class="pricing-grid">
  {tiers.map((tier) => (
    <div class:list={['tier', tier.featured && 'tier-featured']}>
      {tier.featured && <span class="tier-badge">Most popular</span>}
      <h3>{tier.name}</h3>
      <p class="tier-desc">{tier.description}</p>
      <div class="tier-price">
        <span class="amount">{tier.price}</span>
        {tier.period && <span class="period">{tier.period}</span>}
      </div>
      <ul class="tier-features">
        {tier.features.map((feature) => (
          <li>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" style="stroke: var(--signal);">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {feature}
          </li>
        ))}
      </ul>
      <Button href={tier.ctaHref} variant={tier.featured ? 'primary' : 'secondary'} class="tier-cta">
        {tier.ctaText}
      </Button>
    </div>
  ))}
</div>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .tier {
    position: relative;
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
  }

  .tier-featured {
    border: 2px solid var(--signal);
  }

  .tier-badge {
    position: absolute;
    top: -12px;
    left: 28px;
    background: var(--signal);
    color: var(--canopy);
    font-size: 11.5px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 999px;
  }

  .tier h3 {
    font-size: 19px;
    margin-bottom: 8px;
  }

  .tier-desc {
    font-size: 13.5px;
    color: var(--mist-muted);
    margin: 0 0 20px;
    min-height: 40px;
  }

  .tier-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 24px;
  }

  .amount {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 600;
    color: #fff;
  }

  .period {
    font-size: 14px;
    color: var(--mist-muted);
  }

  .tier-features {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .tier-features li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--mist);
  }

  .tier-cta {
    margin-top: auto;
    width: 100%;
    justify-content: center;
  }

  @media (max-width: 860px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
