---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Social {
  label: string;
  href: string;
}

interface Props {
  name: string;
  role: string;
  bio?: string;
  avatar?: ImageMetadata;
  socials?: Social[];
}

const { name, role, bio, avatar, socials = [] } = Astro.props;

const initials = name
  .split(' ')
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<div class="profile">
  {avatar ? (
    <Image src={avatar} alt={name} class="profile-avatar" width={72} height={72} />
  ) : (
    <span class="profile-avatar profile-avatar--fallback">{initials}</span>
  )}
  <h3>{name}</h3>
  <p class="profile-role">{role}</p>
  {bio && <p class="profile-bio">{bio}</p>}
  {socials.length > 0 && (
    <div class="profile-socials">
      {socials.map((social) => (
        <a href={social.href} target="_blank" rel="noopener noreferrer">{social.label} ↗</a>
      ))}
    </div>
  )}
</div>

<style>
  .profile {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 28px;
    text-align: center;
  }

  .profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    margin: 0 auto 18px;
    object-fit: cover;
  }

  .profile-avatar--fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(46, 204, 113, 0.15);
    color: var(--signal);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
  }

  .profile h3 {
    font-size: 17px;
    margin-bottom: 4px;
  }

  .profile-role {
    font-size: 13.5px;
    color: var(--mint);
    margin: 0 0 14px;
  }

  .profile-bio {
    font-size: 14px;
    color: var(--mist-muted);
    margin: 0 0 18px;
  }

  .profile-socials {
    display: flex;
    justify-content: center;
    gap: 16px;
  }

  .profile-socials a {
    font-size: 12.5px;
    color: var(--mist-muted);
    text-decoration: none;
  }
  .profile-socials a:hover {
    color: var(--signal);
  }
</style>
