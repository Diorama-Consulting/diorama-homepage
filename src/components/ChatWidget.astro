---
// Reads chatbotSettings at render time. On pages that are statically
// prerendered (the default for this project — see astro.config), that
// means "enabled" and the welcome message are baked in at build time, same
// as every other piece of Keystatic copy on the site: toggling `enabled`
// off in Keystatic takes effect after the next deploy. /api/chat.ts also
// checks `enabled` itself on every request, so that's the instant kill
// switch if you need the bot gone right now without waiting on a rebuild.
import { reader } from '../lib/keystatic';

const settings = await reader.singletons.chatbotSettings.read();
if (settings?.enabled === false) {
  return null;
}

const welcomeMessage =
  settings?.welcomeMessage ||
  "Hi — I'm the Diorama site assistant. Ask me about our consulting or charity work, or how to get in touch.";
---

<div id="chat-widget" data-welcome={welcomeMessage}>
  <button id="chat-toggle" type="button" aria-expanded="false" aria-controls="chat-panel" aria-label="Open chat">
    <svg id="chat-icon-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
    </svg>
    <svg id="chat-icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;">
      <path d="M18 6 6 18M6 6l12 12"></path>
    </svg>
  </button>

  <div id="chat-panel" role="dialog" aria-label="Chat with Diorama Consulting" aria-hidden="true">
    <div
      id="chat-resize-handle"
      role="separator"
      aria-orientation="horizontal"
      aria-label="Resize chat window — drag, or use arrow keys"
      tabindex="0"
    >
      <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
        <path d="M9.5 9.5 9.5 1.5M9.5 9.5 1.5 9.5M9.5 9.5 5.5 5.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
      </svg>
    </div>
    <header class="chat-header">
      <span>Diorama Assistant</span>
      <button id="chat-close" type="button" aria-label="Close chat">✕</button>
    </header>

    <div id="chat-messages"></div>

    <form id="chat-form">
      <textarea
        id="chat-input"
        rows="1"
        maxlength="2000"
        placeholder="Ask a question…"
        aria-label="Message"
      ></textarea>
      <button type="submit" id="chat-send" aria-label="Send">→</button>
    </form>
    <p class="chat-disclaimer">General info only — for anything specific, use the <a href="/contact">contact form</a>.</p>
  </div>
</div>

<style>
  #chat-widget {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 60;
    font-family: var(--font-body);
  }

  #chat-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    background: var(--signal);
    color: var(--canopy);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    transition: background 0.15s ease, transform 0.15s ease;
  }

  #chat-toggle:hover {
    background: var(--mint);
    transform: translateY(-1px);
  }

  #chat-toggle svg {
    width: 24px;
    height: 24px;
  }

  #chat-panel {
    /* Defaults — identical to the previous fixed min()s, just promoted to
       custom properties so the resize handle below can override them
       per-user without fighting a hardcoded value. */
    --chat-width: min(360px, calc(100vw - 40px));
    --chat-height: min(480px, calc(100vh - 140px));
    position: absolute;
    right: 0;
    bottom: 72px;
    width: var(--chat-width);
    height: var(--chat-height);
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(12px) scale(0.98);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  #chat-panel.is-resizing {
    transition: none;
  }

  #chat-widget.open #chat-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* Grows toward the top-left — the panel's right/bottom edges stay put
     (anchored above the toggle button), so the handle sits in the
     opposite corner from where it's anchored. */
  #chat-resize-handle {
    position: absolute;
    top: 0;
    left: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    padding: 4px;
    color: var(--mist-faint);
    cursor: nwse-resize;
    touch-action: none;
    z-index: 2;
    border-radius: var(--radius-lg) 0 var(--radius-sm) 0;
    transition: color 0.15s ease, background 0.15s ease;
  }
  #chat-resize-handle:hover,
  #chat-resize-handle:focus-visible {
    color: var(--signal);
    background: rgba(255, 255, 255, 0.04);
    outline: none;
  }

  .chat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 14px 30px;
    border-bottom: 1px solid var(--hairline);
    color: var(--text-strong);
    font-weight: 600;
    font-size: 14.5px;
    position: relative;
  }

  .chat-header button {
    background: none;
    border: none;
    color: var(--mist-muted);
    cursor: pointer;
    font-size: 14px;
    line-height: 1;
  }

  .chat-header button:hover {
    color: var(--mist);
  }

  #chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .chat-bubble {
    max-width: 85%;
    padding: 9px 13px;
    border-radius: var(--radius-md);
    font-size: 14px;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  .chat-bubble.assistant {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.06);
    color: var(--mist);
    border: 1px solid var(--hairline);
  }

  .chat-bubble.assistant strong {
    color: var(--text-strong);
    font-weight: 700;
  }

  /* Markdown ATX headings (#, ##, ###…) from the assistant's replies —
     rendered as a small styled heading rather than literal "#" characters
     or a plain bold run-in line. Capped visually at two size tiers since
     a chat bubble is too small a canvas for six distinct heading sizes. */
  .chat-bubble.assistant .chat-heading {
    display: block;
    font-weight: 700;
    color: var(--text-strong);
    line-height: 1.35;
    margin: 10px 0 4px;
  }
  .chat-bubble.assistant .chat-heading:first-child {
    margin-top: 0;
  }
  .chat-bubble.assistant .chat-heading-1,
  .chat-bubble.assistant .chat-heading-2 {
    font-size: 15.5px;
  }
  .chat-bubble.assistant .chat-heading-3,
  .chat-bubble.assistant .chat-heading-4 {
    font-size: 14.5px;
    color: var(--mist);
  }

  .chat-bubble.assistant a {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .chat-bubble.user {
    align-self: flex-end;
    background: var(--signal);
    color: var(--canopy);
  }

  .chat-bubble.error {
    align-self: flex-start;
    background: rgba(244, 166, 39, 0.12);
    border: 1px solid rgba(244, 166, 39, 0.4);
    color: var(--amber);
  }

  .chat-bubble.pending {
    align-self: flex-start;
    color: var(--mist-muted);
    font-style: italic;
  }

  #chat-form {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid var(--hairline);
  }

  #chat-input {
    flex: 1;
    resize: none;
    max-height: 90px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-sm);
    color: var(--mist);
    font-family: var(--font-body);
    font-size: 14px;
    padding: 9px 11px;
  }

  #chat-input:focus {
    outline: none;
    border-color: var(--mint);
  }

  #chat-send {
    width: 38px;
    border-radius: var(--radius-sm);
    border: none;
    background: var(--signal);
    color: var(--canopy);
    font-size: 16px;
    cursor: pointer;
  }

  #chat-send:hover {
    background: var(--mint);
  }

  #chat-send:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .chat-disclaimer {
    margin: 0;
    padding: 0 14px 12px;
    font-size: 11px;
    color: var(--mist-muted);
  }

  .chat-disclaimer a {
    color: var(--signal);
  }

  @media (max-width: 480px) {
    #chat-panel {
      right: -4px;
    }
  }
</style>

<script>
  const widget = document.getElementById('chat-widget')!;
  const toggle = document.getElementById('chat-toggle')!;
  const panel = document.getElementById('chat-panel')!;
  const closeBtn = document.getElementById('chat-close')!;
  const iconOpen = document.getElementById('chat-icon-open')!;
  const iconClose = document.getElementById('chat-icon-close')!;
  const messagesEl = document.getElementById('chat-messages')!;
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const input = document.getElementById('chat-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('chat-send') as HTMLButtonElement;

  type Role = 'user' | 'assistant';
  const history: { role: Role; content: string }[] = [];
  let hasGreeted = false;
  let sending = false;

  // Claude's replies use light Markdown (**bold**, _italic_, headings,
  // line breaks, occasional links) — textContent was rendering that
  // literally as raw asterisks/hashes instead of formatting. This escapes
  // HTML first (so anything in the text, including a pasted <script> or
  // the user's own message, can never inject markup), THEN applies a
  // small, deliberately narrow set of Markdown patterns — not a full
  // Markdown parser, just what a short chat reply plausibly uses.
  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Inline-only formatting (links, bold, italic) — applied per line so
  // headings (below) can reuse it on their own content without also
  // picking up a stray line-break conversion.
  function formatInline(line: string): string {
    let html = line;
    html = html.replace(
      /\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g,
      '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>',
    );
    html = html.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/(?<!\*)\*([^*]+)\*(?!\*)/g, '<em>$1</em>');
    html = html.replace(/_([^_]+)_/g, '<em>$1</em>');
    return html;
  }

  const HEADING_RE = /^(#{1,6})\s+(.*)$/;

  function formatMessage(text: string): string {
    const escaped = escapeHtml(text);
    const lines = escaped.split('\n');
    let html = '';
    let prevWasHeading = false;

    lines.forEach((line, i) => {
      const match = line.match(HEADING_RE);
      if (match) {
        // "# Heading" etc. — never shown as literal hash characters; the
        // level still controls size (capped to two visual tiers) so the
        // structure/emphasis the assistant intended is preserved, just
        // rendered rather than left as raw Markdown syntax.
        const level = Math.min(match[1].length, 4);
        html += `<strong class="chat-heading chat-heading-${level}">${formatInline(match[2])}</strong>`;
        prevWasHeading = true;
        return;
      }
      // Headings are block-level already, so no extra <br> is needed
      // immediately before/after one — only between two ordinary lines.
      if (i > 0 && !prevWasHeading) html += '<br>';
      html += formatInline(line);
      prevWasHeading = false;
    });

    return html;
  }

  function addBubble(role: Role | 'error' | 'pending', text: string) {
    const bubble = document.createElement('div');
    bubble.className = `chat-bubble ${role}`;
    // User's own messages still render as plain text — no reason to parse
    // Markdown in something the visitor typed themselves.
    if (role === 'user') {
      bubble.textContent = text;
    } else {
      bubble.innerHTML = formatMessage(text);
    }
    messagesEl.appendChild(bubble);
    messagesEl.scrollTop = messagesEl.scrollHeight;
    return bubble;
  }

  function setOpen(open: boolean) {
    widget.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    panel.setAttribute('aria-hidden', String(!open));
    iconOpen.style.display = open ? 'none' : '';
    iconClose.style.display = open ? '' : 'none';
    if (open) {
      if (!hasGreeted) {
        hasGreeted = true;
        addBubble('assistant', widget.dataset.welcome || 'Hi! How can I help?');
        window.posthog?.capture('chat_opened');
      }
      input.focus();
    }
  }

  toggle.addEventListener('click', () => setOpen(!widget.classList.contains('open')));
  closeBtn.addEventListener('click', () => setOpen(false));

  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = `${Math.min(input.scrollHeight, 90)}px`;
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const text = input.value.trim();
    if (!text || sending) return;

    sending = true;
    sendBtn.disabled = true;
    input.value = '';
    input.style.height = 'auto';

    addBubble('user', text);
    history.push({ role: 'user', content: text });
    const pending = addBubble('pending', 'Thinking…');
    const sessionId = window.posthog?.get_session_id?.() || '';
    const distinctId = window.posthog?.get_distinct_id?.() || '';

    window.posthog?.capture('chat_message_sent', { turn: history.length });

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-PostHog-Session-Id': sessionId,
          'X-PostHog-Distinct-Id': distinctId,
        },
        body: JSON.stringify({ messages: history }),
      });
      const data = await res.json();
      pending.remove();

      if (!res.ok) {
        addBubble('error', data.error || 'Something went wrong — please try again.');
      } else {
        addBubble('assistant', data.reply);
        history.push({ role: 'assistant', content: data.reply });
      }
    } catch (err) {
      pending.remove();
      addBubble('error', 'Network error — please check your connection and try again.');
      window.posthog?.captureException(err);
    } finally {
      sending = false;
      sendBtn.disabled = false;
      input.focus();
    }
  });

  form.addEventListener('keydown', (event) => {
    if (event instanceof KeyboardEvent && event.key === 'Enter' && !event.shiftKey) {
      event.preventDefault();
      form.requestSubmit();
    }
  });

  // ------------------------------------------------------------------
  // Drag-to-resize: the panel is anchored bottom-right (right:0,
  // bottom:72px), so the handle sits at the OPPOSITE corner (top-left)
  // and dragging it out grows the panel toward the top-left — the only
  // direction that doesn't push the panel off-anchor or under the toggle
  // button. Width/height are held as CSS custom properties so the panel's
  // existing transform/opacity transitions are untouched; only size
  // changes, position logic stays exactly as it was.
  // ------------------------------------------------------------------
  const handle = document.getElementById('chat-resize-handle');
  const SIZE_KEY = 'diorama-chat-size';
  const MIN_W = 300;
  const MIN_H = 340;

  function maxSize() {
    return { w: window.innerWidth - 40, h: window.innerHeight - 140 };
  }

  function clamp(w: number, h: number) {
    const { w: maxW, h: maxH } = maxSize();
    return {
      w: Math.min(Math.max(w, MIN_W), Math.max(maxW, MIN_W)),
      h: Math.min(Math.max(h, MIN_H), Math.max(maxH, MIN_H)),
    };
  }

  function applySize(w: number, h: number) {
    const c = clamp(w, h);
    panel.style.setProperty('--chat-width', `${c.w}px`);
    panel.style.setProperty('--chat-height', `${c.h}px`);
    return c;
  }

  function saveSize(w: number, h: number) {
    try {
      localStorage.setItem(SIZE_KEY, JSON.stringify({ w, h }));
    } catch {
      // Private browsing / storage disabled — resizing still works for
      // this session, it just won't be remembered next visit.
    }
  }

  // Restore a remembered size on load, if any (still clamped to the
  // current viewport in case the window is smaller than it was before).
  try {
    const saved = localStorage.getItem(SIZE_KEY);
    if (saved) {
      const { w, h } = JSON.parse(saved);
      if (typeof w === 'number' && typeof h === 'number') applySize(w, h);
    }
  } catch {
    // Corrupt/blocked storage — fall back to the CSS default size.
  }

  if (handle) {
    let dragging = false;
    let startX = 0;
    let startY = 0;
    let startW = 0;
    let startH = 0;

    const onMove = (clientX: number, clientY: number) => {
      const next = applySize(startW + (startX - clientX), startH + (startY - clientY));
      return next;
    };

    handle.addEventListener('pointerdown', (event) => {
      const e = event as PointerEvent;
      dragging = true;
      startX = e.clientX;
      startY = e.clientY;
      const rect = panel.getBoundingClientRect();
      startW = rect.width;
      startH = rect.height;
      panel.classList.add('is-resizing');
      handle.setPointerCapture(e.pointerId);
      e.preventDefault();
    });

    handle.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      const e = event as PointerEvent;
      onMove(e.clientX, e.clientY);
    });

    const endDrag = (event: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      panel.classList.remove('is-resizing');
      const final = onMove(event.clientX, event.clientY);
      saveSize(final.w, final.h);
    };
    handle.addEventListener('pointerup', endDrag);
    handle.addEventListener('pointercancel', endDrag);

    // Double-click/tap the handle to reset to the default size.
    handle.addEventListener('dblclick', () => {
      panel.style.removeProperty('--chat-width');
      panel.style.removeProperty('--chat-height');
      try {
        localStorage.removeItem(SIZE_KEY);
      } catch {
        /* ignore */
      }
    });

    // Keyboard alternative for anyone who can't drag: arrow keys resize
    // in fixed steps while the handle has focus.
    handle.addEventListener('keydown', (event) => {
      const STEP = 16;
      const rect = panel.getBoundingClientRect();
      let w = rect.width;
      let h = rect.height;
      switch (event.key) {
        case 'ArrowLeft':
          w += STEP;
          break;
        case 'ArrowRight':
          w -= STEP;
          break;
        case 'ArrowUp':
          h += STEP;
          break;
        case 'ArrowDown':
          h -= STEP;
          break;
        default:
          return;
      }
      event.preventDefault();
      const final = applySize(w, h);
      saveSize(final.w, final.h);
    });

    // Re-clamp on viewport resize so a stored size can't push the panel
    // off-screen after e.g. rotating a device or shrinking the window.
    window.addEventListener('resize', () => {
      const rect = panel.getBoundingClientRect();
      applySize(rect.width, rect.height);
    });
  }
</script>