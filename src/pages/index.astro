---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import TrustedCompanies from '../components/TrustedCompanies.astro';
import Section from '../components/Section.astro';
import FeatureToggle from '../components/FeatureToggle.astro';
import ImageFeatureCard from '../components/ImageFeatureCard.astro';
import Footer from '../components/Footer.astro';
import WindTurbineReveal from '../components/animated/WindTurbineReveal.astro';
import AboutIntro from '../components/AboutIntro.astro';
import FallingLeaves from '../components/FallingLeaves.astro';
import OutcomesBand from '../components/OutcomesBand.astro';
import LiveProof from '../components/LiveProof.astro';
import { reader, resolveImageSrc, resolveImageUrl } from '../lib/keystatic';
import defaultHeroPhoto from '../assets/hero/dark-background.jpg';
import defaultFounderPortrait from '../assets/hero/MalmCol.png';

const page = await reader.singletons.home.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || siteSettings?.defaultSeoTitle || 'Diorama Consulting';
const pageDescription =
  page?.seoDescription ||
  siteSettings?.defaultSeoDescription ||
  'AI Technology Advisory for Boards, Founders and Investors, with a focus on D2C marketplaces and consumer products.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

// Hero image/face fall back to the original shipped defaults if nothing has
// been set in Keystatic yet, so the homepage never renders with a missing
// background.
const heroImage = resolveImageSrc(page?.heroImage, page?.heroImageUrl) ?? defaultHeroPhoto;
const heroFace = resolveImageSrc(page?.heroFace, page?.heroFaceUrl) ?? defaultFounderPortrait;

const exploreCards = page?.exploreCards?.length
  ? page.exploreCards
  : [
      { title: 'Services', description: 'Consulting and advisory services we offer, plus our charity work.', href: '/services', linkText: 'View Services' },
      { title: 'Tools', description: 'Side projects, apps, and interactive tools built with AI coding assistants.', href: '/tools', linkText: 'View Tools' },
      { title: 'Insights', description: 'Articles, talks, and events on AI strategy and technology.', href: '/insights', linkText: 'View Insights' },
    ];

const defaultHeroPhotoUrl = (defaultHeroPhoto as unknown as { src: string }).src;
const exploreItems = exploreCards.map((card) => ({
  title: card.title,
  description: card.description,
  href: card.href,
  linkText: card.linkText,
  image: resolveImageUrl(card.image, card.imageUrl) || defaultHeroPhotoUrl,
}));

// -----------------------------------------------------------------------
// HERO CAROUSEL — a single ordered list (heroCarouselItems) where each
// row is tagged blog/event and can be freely reordered/mixed in
// Keystatic (drag-to-reorder on the array field), resolved here in that
// exact order. Falls back to the classic static Hero if the carousel is
// off or nothing resolves — this fallback is unconditional, never
// dependent on Keystatic content existing.
// -----------------------------------------------------------------------
const heroCarouselRefs = (page?.heroCarouselItems ?? []).slice(0, 4);
let heroCarouselSlides: { eyebrow: string; title: string; description?: string; image: string; imageAlt: string; href: string; linkText: string }[] = [];

if (page?.heroCarouselEnabled && heroCarouselRefs.length > 0) {
  const needsBlog = heroCarouselRefs.some((r) => r.kind !== 'event' && r.blogPost);
  const needsEvents = heroCarouselRefs.some((r) => r.kind === 'event' && r.event);
  const [allPosts, allEvents] = await Promise.all([
    needsBlog ? getCollection('blog', ({ data }) => !data.draft) : Promise.resolve([]),
    needsEvents ? getCollection('events', ({ data }) => !data.draft) : Promise.resolve([]),
  ]);

  heroCarouselSlides = heroCarouselRefs
    .map((ref) => {
      if (ref.kind === 'event') {
        if (!ref.event) return null;
        const event = allEvents.find((e) => e.id === ref.event);
        if (!event) return null;
        return {
          eyebrow: 'Upcoming event',
          kind: 'event' as const,
          title: event.data.title,
          description: event.data.description,
          image: resolveImageUrl(event.data.heroImage, event.data.heroImageUrl) || defaultHeroPhotoUrl,
          imageAlt: event.data.title,
          href: event.data.href || '/events/',
          linkText: event.data.linkText || 'Event details',
        };
      }
      if (!ref.blogPost) return null;
      const post = allPosts.find((p) => p.id === ref.blogPost);
      if (!post) return null;
      return {
        eyebrow: 'Featured article',
        kind: 'article' as const,
        title: post.data.title,
        description: post.data.description,
        image: resolveImageUrl(post.data.heroImage, post.data.heroImageUrl) || defaultHeroPhotoUrl,
        imageAlt: post.data.title,
        href: `/insights/${post.id}/`,
        linkText: 'Read article',
      };
    })
    .filter((slide): slide is NonNullable<typeof slide> => Boolean(slide));
}
const useHeroCarousel = page?.heroCarouselEnabled && heroCarouselSlides.length > 0;

// -----------------------------------------------------------------------
// TRUSTED COMPANIES
// -----------------------------------------------------------------------
const trustedCompanies = (page?.trustedCompanies ?? [])
  .map((c) => ({ name: c.name, logo: resolveImageUrl(c.logo, c.logoUrl), href: c.href || undefined }))
  .filter((c): c is { name: string; logo: string; href?: string } => Boolean(c.logo));

// -----------------------------------------------------------------------
// EVENTS ARE DELIBERATELY NOT ON THE HOMEPAGE.
// They used to sit in the #2 position (right after Trusted Companies),
// which was a default from when the section was first built, not an
// actual decision — see the site audit. Events are tertiary,
// intermittent content for a practice this size; they now live at
// /events (see src/pages/events/index.astro) and are reachable from the
// footer nav, not competing with Services/Explore for homepage attention.
// -----------------------------------------------------------------------

// Homepage widgets are deliberately standalone content (their own Keystatic
// singletons) rather than teasers pulled live from /services/charities or
// the CxAI Substack — see README for the reasoning.
// Featured live tools for the LiveProof section — first three
// applications by sort order from the same collection that drives /tools.
const liveTools = (await getCollection('projects', ({ data }) => !data.draft && !data.restricted && data.category === 'application'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)
  .map((t) => ({
    id: t.id,
    title: t.data.title,
    tagline: t.data.tagline,
    summary: t.data.summary,
    accent: t.data.accent,
    monogram: t.data.monogram,
    externalUrl: t.data.externalUrl,
  }));

const charityWidget = await reader.singletons.homeCharityWidget.read();
const cxaiWidget = await reader.singletons.homeCxaiWidget.read();
const showCharityWidget = page?.showCharityWidget ?? true;
const showCxaiWidget = page?.showCxaiWidget ?? true;

// Both widget images fall back to the same default hero photo everything
// else on the site falls back to, so the new bigger image-led cards never
// render with a blank background before a real photo is uploaded.
const charityWidgetImage =
  resolveImageUrl(charityWidget?.image, charityWidget?.imageUrl) || defaultHeroPhotoUrl;
const cxaiWidgetImage =
  resolveImageUrl(cxaiWidget?.image, cxaiWidget?.imageUrl) || defaultHeroPhotoUrl;
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  {useHeroCarousel ? (
    <HeroCarousel slides={heroCarouselSlides} />
  ) : (
    <>
      {import.meta.env.DEV && page?.heroCarouselEnabled && (
        <div class="hero-carousel-dev-notice">
          Hero carousel is <strong>ON</strong> in Keystatic, but 0 slides resolved — showing the static hero instead.
          Check Homepage → "Hero carousel items" actually have entries with Type + the matching Article/Event
          dropdown filled in, and that those entries aren't marked as drafts. (This notice only shows in dev.)
        </div>
      )}
      <Hero
        eyebrow={page?.heroEyebrow || 'AI Technology Advisory'}
        heading={page?.heroHeading || 'Bridging product strategy, engineering and AI.'}
        subheading={page?.heroSubheading || 'AI Technology Advisory led by Mal Minhas, partnering with C-Suite, Boards, Founders and Investors — with a focus on D2C marketplaces and products.'}
        ctaText={page?.heroCtaText || 'Book a conversation'}
        ctaHref={page?.heroCtaHref || '/contact'}
        revealHeading={page?.revealHeading || 'Unique Industry Experience.'}
        revealSubheading={page?.revealSubheading || 'Our team has extensive experience in developing, delivering and evolving AI product software across startups, scale-ups, SMEs and Big Tech. We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI.'}
        image={heroImage}
        face={heroFace}
        faceAlt={page?.heroFaceAlt || 'Portrait of the founder.'}
      />
    </>
  )}

  <AboutIntro />

  <div data-reveal style="position: relative;">
    <FallingLeaves count={20} seed={11} maxOpacity={0.14} />
    <TrustedCompanies companies={trustedCompanies} heading={page?.trustedCompaniesHeading} />
  </div>

  <Section
    id="explore"
    eyebrow={page?.exploreEyebrow || 'Explore'}
    heading={page?.exploreHeading || 'Where to start'}
    subheading={page?.exploreSubheading || "A quick map of what's on this site."}
  >
    <div data-reveal>
      <FeatureToggle groupId="explore" items={exploreItems} />
    </div>
  </Section>

  <LiveProof tools={liveTools} />

  <div class="container">
    <WindTurbineReveal
      eyebrow={page?.craftBandEyebrow || 'Built with care'}
      heading={page?.craftBandHeading || 'Built with the same discipline we bring to client work'}
      text={page?.craftBandText || 'A fast, static-first site with optimised images and a public per-page carbon measurement — the site itself is a small proof point for how we work.'}
    />
  </div>

  <!-- ===================================================================
       HOMEPAGE WIDGETS
       Standalone content widgets, independently editable in Keystatic.
       Bigger, image-led cards (ImageFeatureCard) rather than the plain
       text LinkCard — this closing section is meant to feel more like a
       "come explore" moment than a footnote. Add further widgets here
       following the same ImageFeatureCard pattern.
  ==================================================================== -->
  <OutcomesBand />

  {(showCharityWidget || showCxaiWidget) && (
    <Section id="widgets" eyebrow={page?.widgetsEyebrow || 'From the network'} heading={page?.widgetsHeading || 'More from Diorama'}>
      <div class="widget-grid">
        {showCharityWidget && charityWidget && (
          <div data-reveal>
            <ImageFeatureCard
              href={charityWidget.ctaHref}
              eyebrow="Charities"
              title={charityWidget.heading}
              description={charityWidget.body}
              linkText={charityWidget.ctaText}
              image={charityWidgetImage}
              imageAlt=""
              external={charityWidget.ctaHref?.startsWith('http')}
            />
          </div>
        )}

        {showCxaiWidget && cxaiWidget && (
          <div data-reveal data-reveal-delay="1">
            <ImageFeatureCard
              href={cxaiWidget.ctaHref}
              eyebrow="Newsletter"
              title={cxaiWidget.heading}
              description={cxaiWidget.body}
              linkText={cxaiWidget.ctaText}
              image={cxaiWidgetImage}
              imageAlt=""
              external={cxaiWidget.ctaHref?.startsWith('http')}
            />
          </div>
        )}
      </div>
    </Section>
  )}

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .hero-carousel-dev-notice {
    background: hsl(38 90% 20%);
    color: hsl(38 90% 85%);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    padding: 12px 20px;
    text-align: center;
  }

  .widget-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 860px) {
    .widget-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>