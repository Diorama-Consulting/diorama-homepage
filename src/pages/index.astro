---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import PricingTable from '../components/PricingTable.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/hero/dark-background.jpg';
import founderPortrait from '../assets/hero/MalmCol.png';
---

<Layout
  title="Diorama Consulting"
  description="A demo site built with Astro and a consistent green design syste that fits Diorama Consulting."
>
  <Header />

  <Hero
  heading="Ideas that make a difference."
  subheading="We help ambitious teams ship AI products that actually work."
  revealHeading="Unique Industry Experience."
  revealSubheading="Our team has extensive experience in developing, delivering and evolving AI product software across startups, scale-ups, SMEs and Big Tech. We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI."
  image={heroPhoto}
  face={founderPortrait}
  faceAlt="Portrait of Mal Minhas."
/>

  <Section
    id="work"
    eyebrow="What we do"
    heading="Built on decades of experience"
    subheading="We can help you create defensible growth, reduce risk and accelerate value creation through:"
  >
    <div class="card-grid">
      <Card
        title="High Level Experience"
        description="Fractional/Interim leadership (CTO, CPTO)."
      />
      <Card
        title="Economics Driven"
        description="Pragmatic AI and Data Strategy aligned to P&L."
      />
      <Card
        title="E-commerce"
        description="D2C marketplace optimisation and innovation."
      />
	  <Card
        title="E-commerce"
        description="Platform and architecture modernisation without rewrite"
      />
	  <Card
        title="Engineering"
        description="Product Engineering team organisation design."
      />
	  <Card
        title="Sustainability"
        description="Practical operationalisation of sustainability initiatives"
      />
    </div>
  </Section>

  <Section
    id="pricing"
    eyebrow="Pricing"
    heading="Simple, honest pricing"
    subheading="Start free, upgrade when you need to."
  >
    <PricingTable />
  </Section>

  <Section id="about" eyebrow="Testimonials" heading="What people say">
    <div class="testimonial-grid">
      <TestimonialCard
        quote="The whole site finally feels like one product instead of five different pages."
        name="Sonia Lad"
        role="Head of Food, Kitchen"
      />
      <TestimonialCard
        quote="We shipped a full rebrand in a week because the components already existed."
        name="Ada Topçu"
        role="Neuroscientist, UK DRI"
      />
      <TestimonialCard
        quote="It's rare to find a design system this opinionated and this easy to extend."
        name="Stef Abrar"
        role="Public Health, Tower Hamlets"
      />
    </div>
  </Section>

  <Footer />
</Layout>

<style>
  .card-grid,
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 860px) {
    .card-grid,
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
