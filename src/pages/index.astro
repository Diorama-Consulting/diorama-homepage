---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import { reader, imageSrc, imageUrl } from '../lib/keystatic';
import defaultHeroPhoto from '../assets/hero/dark-background.jpg';
import defaultFounderPortrait from '../assets/hero/MalmCol.png';

const page = await reader.singletons.home.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || siteSettings?.defaultSeoTitle || 'Diorama Consulting';
const pageDescription =
  page?.seoDescription ||
  siteSettings?.defaultSeoDescription ||
  'AI Technology Advisory for Boards, Founders and Investors, with a focus on D2C marketplaces and consumer products.';
const pageImage = imageUrl(page?.seoImage) || imageUrl(siteSettings?.defaultSeoImage);

// Hero image/face fall back to the original shipped defaults if nothing has
// been set in Keystatic yet, so the homepage never renders with a missing
// background.
const heroImage = imageSrc(page?.heroImage) ?? defaultHeroPhoto;
const heroFace = imageSrc(page?.heroFace) ?? defaultFounderPortrait;

const exploreCards = page?.exploreCards?.length
  ? page.exploreCards
  : [
      { title: 'Services', description: 'Consulting and advisory services we offer, plus our charity work.', href: '/services', linkText: 'View Services' },
      { title: 'Projects', description: 'Side projects and tools built with AI coding assistants.', href: '/projects', linkText: 'View Projects' },
      { title: 'Teaching', description: 'Interactive tools for demystifying AI, plus our blog.', href: '/teaching', linkText: 'View Teaching' },
    ];

// Homepage widgets are deliberately standalone content (their own Keystatic
// singletons) rather than teasers pulled live from /services/charities or
// the CxAI Substack — see README for the reasoning.
const charityWidget = await reader.singletons.homeCharityWidget.read();
const cxaiWidget = await reader.singletons.homeCxaiWidget.read();
const showCharityWidget = page?.showCharityWidget ?? true;
const showCxaiWidget = page?.showCxaiWidget ?? true;
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Hero
    eyebrow={page?.heroEyebrow || 'Now in beta'}
    heading={page?.heroHeading || 'Ideas that make a difference.'}
    subheading={page?.heroSubheading || 'We help ambitious teams ship AI products that actually work.'}
    ctaText={page?.heroCtaText || 'Get started'}
    ctaHref={page?.heroCtaHref || '/contact'}
    revealHeading={page?.revealHeading || 'Unique Industry Experience.'}
    revealSubheading={page?.revealSubheading || 'Our team has extensive experience in developing, delivering and evolving AI product software across startups, scale-ups, SMEs and Big Tech. We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI.'}
    image={heroImage}
    face={heroFace}
    faceAlt={page?.heroFaceAlt || 'Portrait of the founder.'}
  />

  <Section
    id="explore"
    eyebrow={page?.exploreEyebrow || 'Explore'}
    heading={page?.exploreHeading || 'Where to start'}
    subheading={page?.exploreSubheading || "A quick map of what's on this site."}
  >
    <div class="explore-grid">
      {exploreCards.map((card) => (
        <Card title={card.title} description={card.description} href={card.href} linkText={card.linkText} />
      ))}
    </div>
  </Section>

  <!-- ===================================================================
       HOMEPAGE WIDGETS
       Standalone content widgets, independently editable in Keystatic.
       Add further widgets here following the same card pattern.
  ==================================================================== -->
  {(showCharityWidget || showCxaiWidget) && (
    <Section id="widgets" eyebrow={page?.widgetsEyebrow || 'From the network'} heading={page?.widgetsHeading || 'More from Diorama'}>
      <div class="widget-grid">
        {showCharityWidget && charityWidget && (
          <a class="widget-card" href={charityWidget.ctaHref} target={charityWidget.ctaHref?.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer">
            <span class="widget-eyebrow">Charities</span>
            <h3>{charityWidget.heading}</h3>
            <p>{charityWidget.body}</p>
            <span class="widget-cta">{charityWidget.ctaText} →</span>
          </a>
        )}

        {showCxaiWidget && cxaiWidget && (
          <a class="widget-card" href={cxaiWidget.ctaHref} target={cxaiWidget.ctaHref?.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer">
            <span class="widget-eyebrow">Newsletter</span>
            <h3>{cxaiWidget.heading}</h3>
            <p>{cxaiWidget.body}</p>
            <span class="widget-cta">{cxaiWidget.ctaText} →</span>
          </a>
        )}
      </div>
    </Section>
  )}

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .explore-grid,
  .widget-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .widget-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .widget-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 28px;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .widget-card:hover {
    border-color: var(--moss);
  }

  .widget-eyebrow {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--mint);
  }

  .widget-card p {
    color: var(--mist-muted);
    font-size: 14.5px;
    flex-grow: 1;
  }

  .widget-cta {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
  }

  .widget-card:hover .widget-cta {
    color: var(--mint);
  }

  @media (max-width: 860px) {
    .explore-grid,
    .widget-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
