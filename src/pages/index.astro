---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/hero/dark-background.jpg';
import founderPortrait from '../assets/hero/MalmCol.png';

// Homepage widgets are deliberately standalone content (edited in their own
// Keystatic singletons: homeCxaiWidget, homeCharityWidget) rather than
// teasers pulled live from /services/charities or the CxAI Substack — see
// README for the reasoning. For now these are placeholder values; once
// Keystatic is wired up, replace this block with a read from those
// singletons via the Keystatic Reader API.
const cxaiWidget = {
  heading: 'CxAI',
  body: 'A Substack for C-Suite leaders on Consumer AI, technology strategy, and the occasional side project.',
  ctaText: 'Read CxAI',
  ctaHref: 'https://cxai100.substack.com',
};

const charityWidget = {
  heading: 'Supporting UK Charities',
  body: 'Beyond commercial advisory, Diorama supports the charity sector directly through Trustee roles at Helpforce and Aston-Mansfield.',
  ctaText: 'Learn more',
  ctaHref: '/services/charities',
};
---

<Layout
  title="Diorama Consulting"
  description="AI Technology Advisory for Boards, Founders and Investors, with a focus on D2C marketplaces and consumer products."
>
  <Header />

  <Hero
    heading="Ideas that make a difference."
    subheading="We help ambitious teams ship AI products that actually work."
    revealHeading="Unique Industry Experience."
    revealSubheading="Our team has extensive experience in developing, delivering and evolving AI product software across startups, scale-ups, SMEs and Big Tech. We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI."
    image={heroPhoto}
    face={founderPortrait}
    faceAlt="Portrait of Mal Minhas."
  />

  <Section
    id="explore"
    eyebrow="Explore"
    heading="Where to start"
    subheading="A quick map of what's on this site."
  >
    <div class="explore-grid">
      <Card
        title="Services"
        description="Consulting and advisory services we offer, plus our charity work."
        href="/services"
        linkText="View Services"
      />
      <Card
        title="Projects"
        description="Side projects and tools built with AI coding assistants."
        href="/projects"
        linkText="View Projects"
      />
      <Card
        title="Teaching"
        description="Interactive tools for demystifying AI, plus our blog."
        href="/teaching"
        linkText="View Teaching"
      />
    </div>
  </Section>

  <!-- ===================================================================
       HOMEPAGE WIDGETS
       Standalone content widgets, independently editable in Keystatic.
       Add further widgets here following the same card pattern.
  ==================================================================== -->
  <Section id="widgets" eyebrow="From the network" heading="More from Diorama">
    <div class="widget-grid">
      <a class="widget-card" href={charityWidget.ctaHref} target={charityWidget.ctaHref.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer">
        <span class="widget-eyebrow">Charities</span>
        <h3>{charityWidget.heading}</h3>
        <p>{charityWidget.body}</p>
        <span class="widget-cta">{charityWidget.ctaText} →</span>
      </a>

      <a class="widget-card" href={cxaiWidget.ctaHref} target={cxaiWidget.ctaHref.startsWith('http') ? '_blank' : undefined} rel="noopener noreferrer">
        <span class="widget-eyebrow">Newsletter</span>
        <h3>{cxaiWidget.heading}</h3>
        <p>{cxaiWidget.body}</p>
        <span class="widget-cta">{cxaiWidget.ctaText} →</span>
      </a>
    </div>
  </Section>

  <Footer />
</Layout>

<style>
  .explore-grid,
  .widget-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .widget-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .widget-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 28px;
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .widget-card:hover {
    border-color: var(--moss);
  }

  .widget-eyebrow {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--mint);
  }

  .widget-card p {
    color: var(--mist-muted);
    font-size: 14.5px;
    flex-grow: 1;
  }

  .widget-cta {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
  }

  .widget-card:hover .widget-cta {
    color: var(--mint);
  }

  @media (max-width: 860px) {
    .explore-grid,
    .widget-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
