---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Section from '../components/Section.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import { reader, imageUrl } from '../lib/keystatic';

const page = await reader.singletons.contactPage.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Contact — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = page?.seoDescription || 'Get in touch with the Diorama team.';
const pageImage = imageUrl(page?.seoImage) || imageUrl(siteSettings?.defaultSeoImage);
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'Contact'}
    heading={page?.heading || 'Tell us about your project'}
    subheading={page?.subheading || 'Talk to us directly and find the solution you need.'}
  >
    <ContactForm />
  </Section>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>
