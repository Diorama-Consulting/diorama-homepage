---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Profile from '../../components/Profile.astro';
import Footer from '../../components/Footer.astro';
import AboutSection from '../../components/AboutSection.astro';
import { reader, imageUrl } from '../../lib/keystatic';

const page = await reader.singletons.aboutFounder.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `The Founder — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = page?.seoDescription || `Meet ${siteSettings?.founderName ?? 'the founder'}.`;
const pageImage = imageUrl(page?.seoImage) || imageUrl(page?.portrait) || imageUrl(siteSettings?.defaultSeoImage);

// `portrait` here uses its own explicit { discriminant, value } shape (same
// convention as every other conditional image field) — AboutSection expects
// a plain string `imageSrc`, so unwrap fully to a URL string rather than
// passing through ImageMetadata.
const portraitUrl = imageUrl(page?.portrait) || '/Mal.png';

const paragraphs = page?.paragraphs?.length
  ? page.paragraphs
  : [
      'Mal Minhas founded Diorama Consulting in 2024 to help Boards, Founders and Investors turn product, technology and AI strategy into commercial outcomes through fractional CTO/CPTO leadership and AI enablement including platform modernisation and organisation design, with a particular focus on D2C marketplaces and consumer products.',
      'Alongside advisory work, Mal serves as a Trustee for two UK charities: Helpforce, which supports NHS trusts and community organisations to build high-impact volunteering programmes across the health system, and Aston-Mansfield, which supports children, young people and families in Newham and east London.',
      'Mal speaks and emcees talks regularly on AI strategy, modern platforms and technology leadership, notably with London Tech Leaders. He also builds products and tools that combine these interests.',
      'Get in touch to discuss a consulting engagement, or a Non-Executive Director or Trustee appointment or to learn more about what we are working on.',
    ];

const team = page?.team?.length
  ? page.team
  : [
      {
        name: 'Mal Minhas',
        role: 'Founder & Everything Else',
        bio: 'AI Technology Advisor, charity Trustee, and occasional Substack writer.',
        socials: [{ label: 'LinkedIn', href: 'https://linkedin.com/malminhas' }],
      },
      {
        name: 'Paolo Minhas',
        role: 'Website & Engineering',
        bio: 'Builds and maintains the Diorama site and tooling.',
        socials: [
          { label: 'GitHub', href: 'https://github.com/paolominhas' },
          { label: 'LinkedIn', href: 'https://linkedin.com/in/paolo-m' },
        ],
      },
      {
        name: 'Rowan Caulfield',
        role: 'Logo Design',
        bio: 'Makes logos.',
        socials: [{ label: 'LinkedIn', href: 'https://linkedin.com' }],
      },
    ];
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <AboutSection
    heading={page?.heading || 'Meet the Founder'}
    imageSrc={portraitUrl}
    imageAlt="A portrait of the founder smiling in a studio"
    paragraphs={paragraphs}
    quote={page?.quote || "you believe that what is contained in the taxidermy scene has something to teach you—but only by the logic of metaphor, because you are not a stuffed animal and do not live in the scene but beyond it, outside it, observing rather than participating. The logic is twisted by global warming, because it collapses the perceived distance between humans and nature—between you and the diorama. One message of climate change is: you do not live outside the scene but within it, subject to all the same horrors you can see afflicting the lives of animals."}
    quoteAuthor={page?.quoteAuthor || 'David Wallace-Wells, The Uninhabitable Earth'}
  />

  <Section eyebrow="The team" heading={page?.teamHeading || 'A small team, for complete control'}>
    <div class="profile-grid">
      {team.map((member) => (
        <Profile name={member.name} role={member.role} bio={member.bio} socials={member.socials} />
      ))}
    </div>
  </Section>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .profile-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 860px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
