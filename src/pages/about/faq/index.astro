---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { reader, resolveImageUrl } from '../../../lib/keystatic';

const page = await reader.singletons.faqPage.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `FAQ — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Frequently asked questions about how Diorama Consulting engages with clients.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

const categories = page?.categories ?? [];
const allQuestions = categories.flatMap((category) => category.questions ?? []);

// Answers are stored as plain text (see keystatic.config.ts for why
// fields.document() doesn't work for this — it expects one separate
// Markdoc file per field, not many small ones nested in arrays, and
// silently mangles hand-written/generated node trees). This renders the
// handful of conventions actually used in real answers: blank-line-separated
// paragraphs, a contiguous run of "1. " lines as a numbered list,
// [label](url) links, and **bold** spans. Anything else is escaped and
// shown as plain text — there's no risk of unrendered markdown leaking
// through unescaped HTML.
function escapeHtml(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

function inline(str: string): string {
  let out = escapeHtml(str);
  out = out.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  return out;
}

function renderAnswer(text: string | undefined | null): string {
  if (!text) return '';
  const lines = text.split('\n');
  const html: string[] = [];
  let i = 0;
  while (i < lines.length) {
    const line = lines[i];
    const listMatch = line.match(/^\d+\.\s+(.*)$/);
    if (listMatch) {
      const items: string[] = [];
      while (i < lines.length) {
        const m = lines[i].match(/^\d+\.\s+(.*)$/);
        if (!m) break;
        items.push(m[1]);
        i++;
      }
      html.push(`<ol>${items.map((item) => `<li>${inline(item)}</li>`).join('')}</ol>`);
    } else if (line.trim() === '') {
      i++;
    } else {
      html.push(`<p>${inline(line)}</p>`);
      i++;
    }
  }
  return html.join('');
}

// FAQPage structured data — specifically favoured by AI answer engines for
// extracting Q&A pairs directly. JSON-LD wants plain text, so this strips
// the [label](url) / **bold** markers rather than converting to HTML.
function toPlainText(text: string | undefined | null): string {
  if (!text) return '';
  return text
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/\*\*([^*]+)\*\*/g, '$1')
    .replace(/\n+/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: toPlainText(item.answer),
    },
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  jsonLd={allQuestions.length > 0 ? faqJsonLd : undefined}
>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <main class="container">
    <section class="page-intro">
      <p class="eyebrow">{page?.eyebrow || 'About'}</p>
      <h1>{page?.heading || 'Frequently Asked Questions'}</h1>
      <p class="subheading">
        {page?.subheading || "Common questions about how we engage with clients. Can't find what you need?"}
        {' '}<a href="/contact">Get in touch</a>.
      </p>
    </section>

    {categories.map((category) => (
      <section class="faq-category">
        <h2>{category.name}</h2>
        <div class="faq-list">
          {(category.questions ?? []).map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <div class="faq-answer">
                <div class="faq-answer-inner" set:html={renderAnswer(item.answer)} />
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}
  </main>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  main.container {
    padding-top: 56px;
    padding-bottom: 80px;
    max-width: 760px;
  }

  .page-intro {
    margin-bottom: 48px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 8px;
  }

  .subheading {
    color: var(--mist-muted);
  }

  .subheading a {
    color: var(--signal);
  }

  .faq-category {
    margin-bottom: 40px;
  }

  .faq-category h2 {
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--mint);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .faq-item {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 18px 22px;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  /* Hover = visual affordance only. It signals "this is clickable" without
     opening anything — actual opening still requires a real click/tap, which
     is what keeps this accessible and consistent between desktop and mobile. */
  .faq-item:hover {
    border-color: var(--moss);
    background-color: rgba(255, 255, 255, 0.02);
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    color: #fff;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::before {
    content: '+';
    display: inline-block;
    width: 1.2em;
    color: var(--signal);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .faq-item:hover summary::before {
    color: var(--mint);
  }

  .faq-item[open] summary::before {
    content: '−';
  }

  .faq-answer {
    padding-left: 1.2em;
    color: var(--mist-muted);
    line-height: 1.6;
  }

  .faq-answer-inner {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.25s ease, opacity 0.2s ease, margin-top 0.2s ease;
  }

  .faq-answer-inner :global(p) {
    margin: 0 0 0.6em 0;
  }

  .faq-answer-inner :global(p:last-child) {
    margin-bottom: 0;
  }

  .faq-answer-inner :global(ol) {
    margin: 0.4em 0 0 1.2em;
    padding: 0;
  }

  .faq-answer-inner :global(a) {
    color: var(--signal);
  }

  .faq-answer-inner :global(a:hover) {
    color: var(--mint);
  }

  .faq-item[open] .faq-answer-inner {
    max-height: 600px; /* generous ceiling — real content is always shorter */
    opacity: 1;
    margin-top: 12px;
  }
</style>