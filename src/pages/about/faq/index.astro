---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { DocumentRenderer } from '@keystatic/core/renderer';
import { reader, resolveImageUrl } from '../../../lib/keystatic';

// resolveLinkedFiles: true resolves every document field immediately as
// plain JSON, rather than as a deferred async function — simpler here since
// each answer is nested inside arrays-within-a-singleton, not a top-level
// collection entry with its own linked files.
const page = await reader.singletons.faqPage.read({ resolveLinkedFiles: true });
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `FAQ — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Frequently asked questions about how Diorama Consulting engages with clients.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

const categories = page?.categories ?? [];

// FAQPage structured data — specifically favoured by AI answer engines for
// extracting Q&A pairs directly. JSON-LD values must be plain text, so the
// document field's structured nodes are flattened to plain text rather
// than rendered as HTML.
function documentToPlainText(nodes: any[]): string {
  if (!Array.isArray(nodes)) return '';
  return nodes
    .map((node) => {
      if (typeof node.text === 'string') return node.text;
      if (Array.isArray(node.children)) return documentToPlainText(node.children);
      return '';
    })
    .join(' ')
    .replace(/\s+/g, ' ')
    .trim();
}

const allQuestions = categories.flatMap((category) => category.questions ?? []);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: allQuestions.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: documentToPlainText(item.answer ?? []),
    },
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  jsonLd={allQuestions.length > 0 ? faqJsonLd : undefined}
>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <main class="container">
    <section class="page-intro">
      <p class="eyebrow">{page?.eyebrow || 'About'}</p>
      <h1>{page?.heading || 'Frequently Asked Questions'}</h1>
      <p class="subheading">
        {page?.subheading || "Common questions about how we engage with clients. Can't find what you need?"}
        {' '}<a href="/contact">Get in touch</a>.
      </p>
    </section>

    {categories.map((category) => (
      <section class="faq-category">
        <h2>{category.name}</h2>
        <div class="faq-list">
          {(category.questions ?? []).map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <div class="faq-answer">
                <DocumentRenderer document={item.answer} />
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}
  </main>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  main.container {
    padding-top: 56px;
    padding-bottom: 80px;
    max-width: 760px;
  }

  .page-intro {
    margin-bottom: 48px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 8px;
  }

  .subheading {
    color: var(--mist-muted);
  }

  .subheading a {
    color: var(--signal);
  }

  .faq-category {
    margin-bottom: 40px;
  }

  .faq-category h2 {
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--mint);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .faq-item {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 18px 22px;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
    color: #fff;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::before {
    content: '+';
    display: inline-block;
    width: 1.2em;
    color: var(--signal);
  }

  .faq-item[open] summary::before {
    content: '−';
  }

  .faq-answer {
    margin-top: 12px;
    padding-left: 1.2em;
    color: var(--mist-muted);
    line-height: 1.6;
  }

  .faq-answer :global(a) {
    color: var(--signal);
  }

  .faq-answer :global(a:hover) {
    color: var(--mint);
  }
</style>
