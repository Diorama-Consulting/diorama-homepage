---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Footer from '../../components/Footer.astro';
import QuoteBanner from '../../components/QuoteBanner.astro';
import LinkCard from '../../components/LinkCard.astro';
import FallingLeaves from '../../components/FallingLeaves.astro';
import LeafToTreeReveal from '../../components/animated/LeafToTreeReveal.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';
import defaultHeroPhoto from '../../assets/hero/dark-background.jpg';

// ---------------------------------------------------------------------------
// ABOUT — redesigned as a scroll story.
//
//   Act 1  Statement hero: who we are + the mission, readable the instant
//          the page opens (word-by-word entrance on load, no scroll needed).
//          Background is the site's stock hero photo, not a flat gradient.
//   Act 2  The story: each paragraph is a full-width statement that lights
//          up as it crosses the viewport, threaded on a growing timeline.
//   Act 3  Pillars: what we actually do, as staggered cards.
//   Act 4  Numbers: stats that count up when they enter view.
//   Act 5  Approach callout, then the leaf-to-tree closing animation.
//   Act 6  Team ("Meet Mal") immediately below that animation — no longer
//          followed by the three-person profile grid, which added little
//          and is gone entirely; just the founder block.
//   Act 7  The pull quote closes the page, right before the footer.
//
// EVERY string on this page comes from the `about` / `aboutFounder`
// Keystatic singletons (with sensible fallbacks) — nothing is hardcoded.
// ---------------------------------------------------------------------------
const page = await reader.singletons.about.read();
const founder = await reader.singletons.aboutFounder.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `About — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = page?.seoDescription || page?.subheading || 'The mission behind Diorama Consulting.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

// --- Act 1 ---
const eyebrow = page?.eyebrow || 'About us';
const heading = page?.heading || 'We are all in the diorama';
const mission =
  page?.subheading ||
  'Diorama Consulting is an AI Technology Advisory practice — bridging product strategy, engineering and AI for Boards, Founders and Investors.';
const missionChips = page?.missionChips?.length
  ? page.missionChips
  : ['Fractional CTO/CPTO leadership', 'AI & data strategy', 'Platform modernisation', 'Organisation design'];
const headingWords = heading.split(/\s+/);

// The hero used to be a flat dark gradient with a couple of radial glows;
// now it's a real stock photo, with a scrim for text legibility. Editable
// via its own Keystatic field (heroBackgroundImage) so it's independent
// from the quote banner's own backdrop further down the page — falls back
// to the same default hero photo used across the rest of the site, so
// this never renders with nothing behind it.
const heroBackgroundUrl =
  resolveImageUrl(page?.heroBackgroundImage, page?.heroBackgroundImageUrl) ||
  (defaultHeroPhoto as unknown as { src: string }).src;

// --- Act 2 ---
const storyEyebrow = page?.storyEyebrow || 'Why "Diorama"';
const bodyParagraphs = page?.bodyParagraphs?.length
  ? page.bodyParagraphs
  : [
      'We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI — helping create defensible growth, reduce risk, and accelerate value creation through fractional leadership, pragmatic AI and data strategy, platform modernisation, and organisation design.',
      "The name Diorama Consulting is inspired by a quote from David Wallace-Wells and the reality that we're not outside observers of climate change, AI disruption, or technological change. We are all in the diorama, creating it and being shaped by it in turn.",
    ];

// --- Act 3 ---
const pillarsEyebrow = page?.pillarsEyebrow || 'What we do';
const pillarsHeading = page?.pillarsHeading || 'Four ways we help';
const pillars = page?.pillars?.length
  ? page.pillars
  : [
      { title: 'Fractional leadership', description: 'CTO/CPTO leadership that plugs into your team without a full-time hire — strategy, delivery, and accountability.' },
      { title: 'AI & data strategy', description: 'Pragmatic, product-led AI adoption — what to build, what to buy, and what to leave alone.' },
      { title: 'Platform modernisation', description: 'Untangling legacy platforms so technology accelerates the roadmap instead of blocking it.' },
      { title: 'Organisation design', description: 'Team shapes, operating rhythms, and hiring plans that fit the product you are actually building.' },
    ];

// --- Act 4 ---
const stats = page?.stats?.length
  ? page.stats
  : [
      { value: '25+', label: 'Years in product & technology' },
      { value: '2024', label: 'Diorama founded' },
      { value: '2', label: 'UK charity trusteeships' },
      { value: '100%', label: 'Senior attention on every engagement' },
    ];

// --- Approach callout ---
const approachEyebrow = page?.approachEyebrow || 'Our approach';
const approachText =
  page?.approachText || "Thoughtful strategy, careful execution — we'd rather do fewer things well than everything at once.";

// --- Quote (Act 5) ---
const quote =
  page?.quote ||
  'you believe that what is contained in the taxidermy scene has something to teach you—but only by the logic of metaphor… The logic is twisted by global warming, because it collapses the perceived distance between humans and nature—between you and the diorama.';
const quoteAuthor = page?.quoteAuthor || 'David Wallace-Wells, The Uninhabitable Earth';
const quoteImage =
  resolveImageUrl(page?.quoteImage, page?.quoteImageUrl) ||
  resolveImageUrl(founder?.portrait, founder?.portraitUrl) ||
  (defaultHeroPhoto as unknown as { src: string }).src;

// --- Team ---
const portraitUrl = resolveImageUrl(founder?.portrait, founder?.portraitUrl) || '/Mal.png';
const founderParagraphs = founder?.paragraphs?.length
  ? founder.paragraphs
  : [
      'Mal Minhas founded Diorama Consulting in 2024 to help Boards, Founders and Investors turn product, technology and AI strategy into commercial outcomes through fractional CTO/CPTO leadership and AI enablement including platform modernisation and organisation design, with a particular focus on D2C marketplaces and consumer products.',
      'Alongside advisory work, Mal serves as a Trustee for two UK charities: Helpforce, which supports NHS trusts and community organisations to build high-impact volunteering programmes across the health system, and Aston-Mansfield, which supports children, young people and families in Newham and east London.',
    ];

// --- Act 6: closing animated band ---
const closingEyebrow = page?.closingEyebrow || 'Renewal';
const closingHeading = page?.closingHeading || 'Small, deliberate, and growing';
const closingText =
  page?.closingText || 'A small practice by design — every engagement gets senior attention from start to finish.';
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <!-- ============================================================
       ACT 1 — the statement. Everything essential is on screen the
       moment the page opens: who, what, and for whom. The headline
       cascades in word-by-word on load (a page-load animation, NOT a
       scroll one — no interaction required to read the mission).
  ============================================================= -->
  <section class="about-hero" id="about-hero">
    <img src={heroBackgroundUrl} alt="" class="about-hero-bg" />
    <div class="about-hero-scrim" aria-hidden="true"></div>
    <div class="container about-hero-inner">
      <p class="hero-eyebrow">{eyebrow}</p>
      <h1 class="hero-heading" aria-label={heading}>
        {headingWords.map((word, i) => (
          <span class="hero-word" style={`--word-i: ${i}`} aria-hidden="true">{word}</span>
        ))}
      </h1>
      <p class="hero-mission">{mission}</p>
      {missionChips.length > 0 && (
        <ul class="hero-chips" aria-label="What we do">
          {missionChips.map((chip, i) => (
            <li style={`--chip-i: ${i}`}>{chip}</li>
          ))}
        </ul>
      )}
    </div>
    <a class="hero-scroll-cue" href="#about-story" aria-label="Scroll to read more">
      <span class="cue-label">The story</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 4v16m0 0 6-6m-6 6-6-6" />
      </svg>
    </a>
  </section>

  <!-- ============================================================
       ACT 2 — the story. A vertical timeline grows as you scroll;
       each paragraph brightens from faint to full as it crosses the
       middle of the viewport.
  ============================================================= -->
  <section class="about-story container" id="about-story">
    <p class="story-eyebrow">{storyEyebrow}</p>
    <div class="story-thread" data-story-thread>
      <div class="story-line" aria-hidden="true"><span class="story-line-fill" data-story-fill></span></div>
      <div class="story-items">
        {bodyParagraphs.map((paragraph) => (
          <div class="story-row" data-story-item>
            <span class="story-dot" aria-hidden="true"></span>
            <p class="story-paragraph">{paragraph}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       ACT [7] — the pull quote closes the page, right before the footer.
  ============================================================= -->
  <div class="container">
    <QuoteBanner quote={quote} author={quoteAuthor} image={quoteImage} imageAlt="" />
  </div>

  <!-- ============================================================
       ACT [6] — the team. Just the founder block — the three-person
       profile grid (Paolo/Rowan/Mal) that used to sit below this has
       been removed entirely; it wasn't earning its place on the page.
  ============================================================= -->
  <Section id="team" eyebrow="The team" heading={founder?.heading || 'Meet Mal'} subheading={founder?.teamHeading}>
    <FallingLeaves count={14} seed={21} maxOpacity={0.08} />
    <div class="founder-block" data-reveal>
      <div class="founder-portrait">
        <img src={portraitUrl} alt="A portrait of Mal smiling in a studio" loading="lazy" />
      </div>
      <div class="founder-copy">
        {founderParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    <div class="about-links" data-reveal>
      <LinkCard
        href="/about/faq"
        eyebrow="Questions"
        title={page?.faqLinkTitle || 'FAQ'}
        description={page?.faqLinkDescription || 'How we engage with clients and what to expect.'}
        linkText="View FAQ"
        size="compact"
      />
      <LinkCard
        href="/contact"
        eyebrow="Next step"
        title="Start a conversation"
        description={page?.founderLinkDescription || 'The story behind Diorama and the people building it.'}
        linkText="Get in touch"
        size="compact"
      />
    </div>
  </Section>

  <!-- ============================================================
       ACT 3 — pillars.
  ============================================================= -->
  <Section id="pillars" eyebrow={pillarsEyebrow} heading={pillarsHeading}>
    <FallingLeaves count={10} seed={17} maxOpacity={0.06} />
    <div class="pillar-grid">
      {pillars.map((pillar, i) => (
        <article class="pillar-card" data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
          <span class="pillar-index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <h3>{pillar.title}</h3>
          {pillar.description && <p>{pillar.description}</p>}
        </article>
      ))}
    </div>
  </Section>

  <!-- ============================================================
       ACT 4 — the numbers, counting up on arrival.
  ============================================================= -->
  {stats.length > 0 && (
    <div class="container">
      <div class="stats-band" data-reveal>
        {stats.map((stat) => (
          <div class="stat">
            <span class="stat-value" data-count-value={stat.value}>{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="container">
    <div class="approach-callout" data-reveal>
      <span class="approach-eyebrow">{approachEyebrow}</span>
      <p>{approachText}</p>
    </div>
  </div>

  <!-- ============================================================
       ACT 5 — the classic leaf-to-tree scroll animation ("the old
       animation effects, utilised towards the bottom"), now followed
       immediately by the team section rather than preceding it.
  ============================================================= -->
  <div class="container">
    <LeafToTreeReveal eyebrow={closingEyebrow} heading={closingHeading} text={closingText} />
  </div>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} ctaEyebrow={footerNav?.ctaEyebrow} ctaHeading={footerNav?.ctaHeading} ctaSub={footerNav?.ctaSub} />
</Layout>

<style>
  /* =================== ACT 1: statement hero =================== */
  .about-hero {
    position: relative;
    min-height: calc(100svh - 120px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .about-hero-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(60% 80% at 75% 15%, hsl(var(--hue-green) 55% 30% / 0.25), transparent 65%),
      linear-gradient(180deg, hsl(var(--hue-green) 30% 6% / 0.55) 0%, hsl(var(--hue-green) 30% 5% / 0.86) 100%);
  }

  .about-hero-inner {
    position: relative;
    z-index: 2;
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-accent);
    margin: 0 0 20px;
    animation: hero-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-heading {
    font-size: clamp(42px, 7vw, 92px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink-text);
    margin: 0 0 26px;
    max-width: 14ch;
  }

  .hero-word {
    display: inline-block;
    margin-right: 0.24em;
    opacity: 0;
    transform: translateY(0.5em) rotate(1.5deg);
    animation: hero-word-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.12s + var(--word-i) * 0.09s);
  }

  .hero-mission {
    font-size: clamp(17px, 2vw, 22px);
    line-height: 1.55;
    color: var(--ink-text-muted);
    max-width: 640px;
    margin: 0 0 30px;
    animation: hero-rise 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
  }

  .hero-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hero-chips li {
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.02em;
    color: var(--ink-text);
    border: 1px solid var(--ink-border-hover);
    background: hsl(0 0% 100% / 0.05);
    border-radius: 999px;
    padding: 8px 16px;
    opacity: 0;
    animation: hero-rise 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(0.75s + var(--chip-i) * 0.08s);
  }

  .hero-scroll-cue {
    position: absolute;
    left: 50%;
    bottom: 26px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--ink-text-muted);
    text-decoration: none;
    font-family: var(--font-mono);
    animation: hero-rise 0.7s ease 1.2s both;
    transition: color 0.2s ease;
  }
  .hero-scroll-cue:hover { color: var(--ink-accent-hover); }
  .cue-label {
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .hero-scroll-cue svg { animation: cue-bob 2.2s ease-in-out 1.6s infinite; }

  @keyframes hero-word-in {
    to { opacity: 1; transform: translateY(0) rotate(0deg); }
  }
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes cue-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(5px); }
  }

  /* =================== ACT 2: the story thread =================== */
  .about-story {
    padding-block: var(--space-2xl) var(--space-xl);
  }

  .story-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--signal);
    margin: 0 0 var(--space-md);
  }

  .story-thread {
    /* THE ALIGNMENT FIX: previously the line lived in a separate 24px
       grid column (centred within it) while each dot was positioned with
       a hand-picked negative-pixel offset relative to the paragraph text
       column — two independent numbers that had to happen to agree, and
       quietly didn't (worse at the mobile breakpoint, where the column
       width/gap/offset were all reduced by different, unrelated
       amounts). Now there is exactly ONE number, --story-gutter, and
       both the line (via `left`) and every dot (via `left`) reference
       it with a matching negative margin equal to half their own
       thickness — so they are mathematically guaranteed to share the
       same centre at every breakpoint, because there's only one
       measurement to get right instead of two that have to match.
    */
    --story-gutter: 20px;
    position: relative;
    max-width: 820px;
  }

  .story-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--story-gutter);
    width: 2px;
    margin-left: -1px; /* half the line's own width — centres it exactly on the gutter */
    background: var(--hairline);
    border-radius: 999px;
    overflow: hidden;
  }

  /* Grows top-to-bottom with scroll progress (JS writes --story-progress). */
  .story-line-fill {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--signal), var(--leaf));
    transform-origin: top;
    transform: scaleY(var(--story-progress, 0));
  }

  .story-items {
    display: flex;
    flex-direction: column;
    gap: clamp(48px, 8vh, 88px);
    padding-block: 8px;
  }

  .story-row {
    position: relative;
    padding-left: calc(var(--story-gutter) + 24px);
  }

  .story-paragraph {
    font-family: var(--font-display);
    font-size: clamp(19px, 2.5vw, 27px);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: -0.005em;
    color: var(--text-strong);
    margin: 0;
    opacity: 0.22;
    transform: translateY(14px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .story-row.is-lit .story-paragraph {
    opacity: 1;
    transform: translateY(0);
  }

  .story-dot {
    position: absolute;
    left: var(--story-gutter);
    top: 0.55em;
    width: 10px;
    height: 10px;
    margin-left: -5px; /* half the dot's own width — same centring logic as the line, above */
    border-radius: 50%;
    background: var(--canopy);
    border: 2px solid var(--hairline-hover);
    transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
  }
  .story-row.is-lit .story-dot {
    background: var(--signal);
    border-color: var(--signal);
    box-shadow: 0 0 0 5px var(--signal-soft);
  }

  /* =================== ACT 3: pillars =================== */
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: var(--space-sm);
  }

  .pillar-card {
    position: relative;
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 28px 26px 26px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .pillar-card::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 3px;
    background: linear-gradient(90deg, var(--signal), var(--leaf));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .pillar-card:hover {
    transform: translateY(-5px);
    border-color: var(--hairline-hover);
    box-shadow: var(--shadow-md);
  }
  .pillar-card:hover::after { transform: scaleX(1); }

  .pillar-index {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 700;
    color: var(--signal);
    letter-spacing: 0.05em;
  }
  .pillar-card h3 {
    font-size: 18px;
    margin: 12px 0 10px;
  }
  .pillar-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--mist-muted);
    margin: 0;
  }

  /* =================== ACT 4: stats =================== */
  .stats-band {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--space-sm);
    background: var(--ink-bg);
    border-radius: var(--radius-xl);
    padding: clamp(32px, 5vw, 56px);
    margin-block: var(--space-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 700;
    color: var(--ink-accent);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 13px;
    color: var(--ink-text-muted);
    line-height: 1.4;
  }

  /* =================== Approach callout =================== */
  .approach-callout {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 40px 44px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--hairline);
    background: var(--sand-soft);
  }
  .approach-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 12px;
  }
  .approach-callout p {
    font-family: var(--font-display);
    font-size: clamp(17px, 2vw, 21px);
    line-height: 1.55;
    color: var(--text-strong);
    margin: 0;
  }

  /* =================== Team =================== */
  .founder-block {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .founder-portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .founder-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--mist);
    line-height: 1.7;
  }
  .founder-copy p { margin: 0; }

  .about-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  /* =================== Responsive =================== */
  @media (max-width: 860px) {
    .about-links {
      grid-template-columns: 1fr;
    }
    .founder-block {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
    .founder-portrait img {
      max-width: 280px;
      margin: 0 auto;
    }
    .story-thread {
      --story-gutter: 12px;
    }
    .story-row {
      padding-left: calc(var(--story-gutter) + 18px);
    }
    .hero-scroll-cue { display: none; }
  }

  @media (max-width: 480px) {
    .story-thread {
      --story-gutter: 8px;
    }
    .story-row {
      padding-left: calc(var(--story-gutter) + 16px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-word,
    .hero-mission,
    .hero-chips li,
    .hero-scroll-cue {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .hero-scroll-cue svg { animation: none; }
    .story-paragraph {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .story-line-fill { transform: scaleY(1); }
    .pillar-card,
    .pillar-card::after { transition: none; }
  }
</style>

<script>
  // ------------------------------------------------------------------
  // Story thread: light paragraphs as they cross the viewport, and scrub
  // the timeline fill with scroll progress through the section.
  // ------------------------------------------------------------------
  function initAboutStory() {
    const thread = document.querySelector<HTMLElement>('[data-story-thread]');
    if (!thread || thread.dataset.init) return;
    thread.dataset.init = 'true';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = Array.from(thread.querySelectorAll<HTMLElement>('[data-story-item]'));

    if (reduced) {
      items.forEach((el) => el.classList.add('is-lit'));
      return;
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle('is-lit', entry.isIntersecting);
        });
      },
      // "Lit" while the paragraph is in the middle band of the viewport —
      // paragraphs dim again as they leave, so the highlight tracks your
      // reading position both directions.
      { rootMargin: '-25% 0px -25% 0px', threshold: 0 },
    );
    items.forEach((el) => io.observe(el));

    let ticking = false;
    const scrub = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const rect = thread.getBoundingClientRect();
        const vh = window.innerHeight;
        // 0 when the top of the thread reaches 75% down the screen,
        // 1 when the bottom reaches 35% — a comfortable reading scrub.
        const start = vh * 0.75;
        const end = vh * 0.35;
        const total = rect.height + (start - end);
        const progress = Math.min(1, Math.max(0, (start - rect.top) / total));
        thread.style.setProperty('--story-progress', progress.toFixed(4));
        ticking = false;
      });
    };
    scrub();
    window.addEventListener('scroll', scrub, { passive: true });
    window.addEventListener('resize', scrub);
  }

  // ------------------------------------------------------------------
  // Stats: count numeric values up when the band enters view. Values
  // keep any prefix/suffix ("25+", "100%", "£3m") and non-numeric values
  // ("2024" counts; pure text is left alone).
  // ------------------------------------------------------------------
  function initStatCounters() {
    const values = Array.from(document.querySelectorAll<HTMLElement>('[data-count-value]'));
    if (!values.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return; // final values are already server-rendered

    const animate = (el: HTMLElement) => {
      const raw = el.dataset.countValue || '';
      const match = raw.match(/^(\D*)(\d[\d,.]*)(\D*)$/);
      if (!match) return;
      const [, prefix, numStr, suffix] = match;
      const target = parseFloat(numStr.replace(/,/g, ''));
      if (!isFinite(target)) return;
      const decimals = (numStr.split('.')[1] || '').length;
      const dur = 1200;
      const t0 = performance.now();
      const step = (t: number) => {
        const p = Math.min(1, (t - t0) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        const val = (target * eased).toFixed(decimals);
        el.textContent = `${prefix}${Number(val).toLocaleString('en-GB', { minimumFractionDigits: decimals, maximumFractionDigits: decimals })}${suffix}`;
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = raw;
      };
      requestAnimationFrame(step);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target as HTMLElement);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 },
    );
    values.forEach((el) => io.observe(el));
  }

  initAboutStory();
  initStatCounters();
  document.addEventListener('astro:page-load', () => {
    initAboutStory();
    initStatCounters();
  });
</script>
