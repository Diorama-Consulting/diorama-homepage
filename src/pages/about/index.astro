---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Footer from '../../components/Footer.astro';
import QuoteBanner from '../../components/QuoteBanner.astro';
import LinkCard from '../../components/LinkCard.astro';
import Profile from '../../components/Profile.astro';
import SpacerImageSweep from '../../components/spacers/SpacerImageSweep.astro';
import SpacerTextBox from '../../components/spacers/SpacerTextBox.astro';
import FloatingLeaves from '../../components/FloatingLeaves.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';
import defaultHeroPhoto from '../../assets/hero/dark-background.jpg';

// The former standalone /about/mal page is now merged into this page as a
// "Team" section — see about/mal.astro, which now just redirects here for
// old links/bookmarks/SEO. Both singletons are still read independently so
// no Keystatic content had to be migrated.
const page = await reader.singletons.about.read();
const founder = await reader.singletons.aboutFounder.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `About — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = page?.seoDescription || page?.subheading || 'The mission behind Diorama Consulting.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

const bodyParagraphs = page?.bodyParagraphs?.length
  ? page.bodyParagraphs
  : [
      'We partner with C-Suite, Boards, Founders and Investors to bridge product strategy, engineering and AI — helping create defensible growth, reduce risk, and accelerate value creation through fractional leadership, pragmatic AI and data strategy, platform modernisation, and organisation design.',
      "The name Diorama Consulting is inspired by a quote from David Wallace-Wells and the reality that we're not outside observers of climate change, AI disruption, or technological change. We are all in the diorama, creating it and being shaped by it in turn.",
    ];

const quote =
  page?.quote ||
  "you believe that what is contained in the taxidermy scene has something to teach you—but only by the logic of metaphor, because you are not a stuffed animal and do not live in the scene but beyond it, outside it, observing rather than participating. The logic is twisted by global warming, because it collapses the perceived distance between humans and nature—between you and the diorama.";
const quoteAuthor = page?.quoteAuthor || 'David Wallace-Wells, The Uninhabitable Earth';
// Falls back to the site's default hero photograph if no dedicated quote
// backdrop has been uploaded yet, so the banner never renders with nothing
// behind it.
const quoteImage =
  resolveImageUrl(page?.quoteImage, page?.quoteImageUrl) ||
  resolveImageUrl(founder?.portrait, founder?.portraitUrl) ||
  (defaultHeroPhoto as unknown as { src: string }).src;

const portraitUrl = resolveImageUrl(founder?.portrait, founder?.portraitUrl) || '/Mal.png';

const founderParagraphs = founder?.paragraphs?.length
  ? founder.paragraphs
  : [
      'Mal Minhas founded Diorama Consulting in 2024 to help Boards, Founders and Investors turn product, technology and AI strategy into commercial outcomes through fractional CTO/CPTO leadership and AI enablement including platform modernisation and organisation design, with a particular focus on D2C marketplaces and consumer products.',
      'Alongside advisory work, Mal serves as a Trustee for two UK charities: Helpforce, which supports NHS trusts and community organisations to build high-impact volunteering programmes across the health system, and Aston-Mansfield, which supports children, young people and families in Newham and east London.',
    ];

const team = founder?.team?.length
  ? founder.team
  : [
      {
        name: 'Mal Minhas',
        role: 'Founder & Everything Else',
        bio: 'AI Technology Advisor, charity Trustee, and occasional Substack writer.',
        socials: [{ label: 'LinkedIn', href: 'https://linkedin.com/malminhas' }],
      },
      {
        name: 'Paolo Minhas',
        role: 'Website & Engineering',
        bio: 'Builds and maintains the Diorama site and tooling.',
        socials: [
          { label: 'GitHub', href: 'https://github.com/paolominhas' },
          { label: 'LinkedIn', href: 'https://linkedin.com/in/paolo-m' },
        ],
      },
      {
        name: 'Rowan Caulfield',
        role: 'Logo Design',
        bio: 'Makes logos.',
        socials: [{ label: 'LinkedIn', href: 'https://linkedin.com' }],
      },
    ];
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'About us'}
    heading={page?.heading || 'We are all in the diorama'}
    subheading={page?.subheading || 'Diorama Consulting Ltd is an AI Technology Advisory practice with a focus on D2C marketplaces and consumer products.'}
  >
    <FloatingLeaves count={4} seed={5} maxOpacity={0.06} />
    <div class="about-prose" data-reveal>
      {bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <div class="about-links" data-reveal data-reveal-delay="1">
      <LinkCard
        href="#team"
        eyebrow="Meet the team"
        title={founder?.heading?.replace('Meet ', '') || 'Mal & the team'}
        description={page?.founderLinkDescription || 'The story behind Diorama and the people building it.'}
        linkText="Read more"
        size="compact"
      />
      <LinkCard
        href="/about/faq"
        eyebrow="Questions"
        title={page?.faqLinkTitle || 'FAQ'}
        description={page?.faqLinkDescription || 'How we engage with clients and what to expect.'}
        linkText="View FAQ"
        size="compact"
      />
    </div>
  </Section>

  <div class="container">
    <SpacerTextBox eyebrow="Our approach" text="Thoughtful strategy, careful execution — we'd rather do fewer things well than everything at once." tone="sand" />
  </div>

  <div class="container">
    <QuoteBanner quote={quote} author={quoteAuthor} image={quoteImage} imageAlt="" />
  </div>

  <!-- ===================================================================
       TEAM — merged in from the former standalone /about/mal page.
  ==================================================================== -->
  <Section id="team" eyebrow="The team" heading={founder?.heading || 'Meet Mal'} subheading={founder?.teamHeading}>
    <div class="founder-block" data-reveal>
      <div class="founder-portrait">
        <img src={portraitUrl} alt="A portrait of Mal smiling in a studio" loading="lazy" />
      </div>
      <div class="founder-copy">
        {founderParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    <div class="profile-grid">
      {team.map((member, i) => (
        <div data-reveal data-reveal-delay={String(Math.min(i + 1, 4))}>
          <Profile name={member.name} role={member.role} bio={member.bio} socials={member.socials} />
        </div>
      ))}
    </div>
  </Section>

  <div class="container">
    <SpacerImageSweep image={(defaultHeroPhoto as unknown as { src: string }).src} imageAlt="" caption="Building thoughtfully, one project at a time." />
  </div>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .about-prose {
    max-width: 760px;
    color: var(--mist);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .about-prose p {
    margin-bottom: 1.2rem;
  }

  .about-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  .founder-block {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: var(--space-xl);
    align-items: center;
    margin-bottom: var(--space-xl);
  }

  .founder-portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .founder-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--mist);
    line-height: 1.7;
  }

  .founder-copy p {
    margin: 0;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-sm);
  }

  @media (max-width: 860px) {
    .about-links,
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .founder-block {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
    .founder-portrait img {
      max-width: 280px;
      margin: 0 auto;
    }
  }
</style>
