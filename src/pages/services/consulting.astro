---
// /services/consulting — rebuilt around the firm's REAL service catalogue
// (all copy below is the exact supplied text — titles, intros and bullet
// wording must not be paraphrased when editing; hover/expand presentation
// is the only thing added). Structure:
//   1. Intro + the four key business outcomes (OutcomesBand, exact text)
//   2. Eight service areas as expandable cards — title + intro always
//      visible, bullets revealed on open (native <details>, keyboard-
//      accessible, no JS required)
//   3. Optional editorial sections (only if authored in Keystatic — the
//      previous default filler copy is gone)
//   4. Testimonials (unchanged)
// Service areas are Keystatic-editable via the servicesConsulting
// singleton's serviceAreas field; the defaults below are the exact text.
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import OutcomesBand from '../../components/OutcomesBand.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';
import { resolveServiceAreas } from '../../lib/site-content';

const page = await reader.singletons.servicesConsulting.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Consulting — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Fractional and interim advisory across Board and Investor Advisory, AI and Data Strategy, marketplaces, platform modernisation, and more.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

// Service catalogue: Keystatic override or the exact shared defaults —
// same source the chatbot's knowledge base reads (src/lib/site-content.ts).
const rawAreas = resolveServiceAreas(page?.serviceAreas);

type ServiceArea = { title: string; introHtml: string; bulletsHtml: string[] };

const serviceAreas: ServiceArea[] = rawAreas
  .filter((a) => a.title)
  .map((a) => ({
    title: a.title,
    introHtml: marked.parseInline(a.intro) as string,
    bulletsHtml: a.bullets.map((b) => marked.parseInline(b) as string),
  }));

// Optional editorial sections — ONLY when authored in Keystatic; the old
// default filler copy is intentionally gone.
const editorialSections = (page?.sections ?? [])
  .map((s) => ({
    heading: s.heading || '',
    bodyHtml: s.body ? (marked.parse(s.body) as string) : '',
    image: resolveImageUrl(s.image, s.imageUrl),
    imageAlt: s.imageAlt || s.heading || '',
    imageSide: (s.imageSide as 'left' | 'right') || 'right',
  }))
  .filter((s) => s.heading || s.bodyHtml);

const testimonials = page?.testimonials ?? [];
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'Consulting'}
    heading={page?.heading || 'Fractional and interim advisory'}
    subheading={page?.subheading || 'Services provided by Diorama Consulting cover a broad spectrum of fractional and interim advisory focussed on four key business outcomes.'}
  >
    <OutcomesBand showHead={false} showProofStrip={false} />
  </Section>

  <Section eyebrow="Services" heading="What we do" subheading="Open any area for the detail — every engagement is scoped around the outcomes above.">
    <div class="areas-list">
      {serviceAreas.map((area, i) => (
        <div class="area" data-reveal data-reveal-delay={String((i % 3) + 1)}>
          <button type="button" class="area-summary" aria-expanded="false" aria-controls={`area-body-${i}`}>
            <span class="area-head">
              <h3>{area.title}</h3>
              <p class="area-intro" set:html={area.introHtml} />
            </span>
            <span class="area-toggle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12h14" /></svg>
            </span>
          </button>
          <div class="area-collapse" id={`area-body-${i}`}>
            <div class="area-collapse-inner">
              <ul class="area-bullets">
                {area.bulletsHtml.map((b) => <li set:html={b} />)}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="consult-cta" data-reveal>
      <p><a class="inline-link" href="/contact">Get in touch</a> if you'd like help with any of them.</p>
      <Button href="/contact">Book a conversation</Button>
    </div>
  </Section>

  <noscript>
    <style>
      /* Zero-JS fallback: the accordion needs a click handler to open, so
         without JS every bullet list is shown flat and the (now inert)
         toggle button is hidden — nothing is ever inaccessible. */
      .area-collapse { grid-template-rows: 1fr !important; }
      .area-toggle { display: none !important; }
    </style>
  </noscript>

  <script>
    // Accessible accordion: a real <button aria-expanded>, height animated
    // via the CSS grid-template-rows 0fr->1fr trick (see styles below) so
    // it transitions smoothly in every modern browser without JS measuring
    // scrollHeight. Native <details> was replaced because it can't animate
    // height at all — it snaps open/closed instantly.
    document.querySelectorAll<HTMLElement>('.area').forEach((area) => {
      const btn = area.querySelector<HTMLButtonElement>('.area-summary');
      const collapse = area.querySelector<HTMLElement>('.area-collapse');
      if (!btn || !collapse || area.dataset.accInit) return;
      area.dataset.accInit = 'true';
      btn.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        collapse.classList.toggle('is-open', !open);
        area.classList.toggle('is-open', !open);
      });
    });
  </script>

  {editorialSections.length > 0 && (
    <Section eyebrow="In depth" heading="More on how we work">
      <div class="editorial">
        {editorialSections.map((section, i) => (
          <div class:list={['editorial-row', section.imageSide === 'left' && 'editorial-row--flip']}>
            <div class="editorial-text" data-reveal>
              <h2>{section.heading}</h2>
              <div class="editorial-body" set:html={section.bodyHtml} />
            </div>
            {section.image && (
              <div class="editorial-media" data-reveal data-reveal-delay="1">
                <img src={section.image} alt={section.imageAlt} loading={i === 0 ? 'eager' : 'lazy'} />
              </div>
            )}
          </div>
        ))}
      </div>
    </Section>
  )}

  {testimonials.length > 0 && (
    <Section eyebrow={page?.testimonialsEyebrow || 'Testimonials'} heading={page?.testimonialsHeading || 'What people say'}>
      <div class="testimonial-grid">
        {testimonials.map((testimonial) => (
          <TestimonialCard quote={testimonial.quote} name={testimonial.name} role={testimonial.role} />
        ))}
      </div>
    </Section>
  )}

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .areas-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .area {
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--forest);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .area:hover {
    border-color: var(--hairline-hover);
    box-shadow: var(--shadow-sm);
  }
  .area.is-open {
    border-color: color-mix(in srgb, var(--signal) 35%, var(--hairline));
  }

  .area-summary {
    width: 100%;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 22px 24px;
    cursor: pointer;
    background: none;
    border: none;
    text-align: left;
    font-family: inherit;
    color: inherit;
  }

  .area-head { min-width: 0; }

  .area h3 {
    font-size: 17px;
    color: var(--text-strong);
    margin: 0 0 6px;
  }

  .area-intro {
    font-size: 14px;
    line-height: 1.6;
    color: var(--mist-muted);
    margin: 0;
  }
  .area-intro :global(a) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .area-toggle {
    flex-shrink: 0;
    margin-left: auto;
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--hairline);
    color: var(--signal);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.25s ease;
  }
  .area:hover .area-toggle { background: var(--signal-soft); }
  .area.is-open .area-toggle { transform: rotate(45deg); }

  /* The height-animation trick: the OUTER element transitions its single
     grid row between 0fr and 1fr — a track-size change, which (unlike
     height/max-height) animates smoothly to an intrinsic, unmeasured
     content height in every modern browser. The INNER element clips
     overflow during the transition and holds the actual padding, so nudge
     visible/hidden padding lives on it, not on the row that's animating. */
  .area-collapse {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .area-collapse.is-open {
    grid-template-rows: 1fr;
  }
  .area-collapse-inner {
    overflow: hidden;
    min-height: 0;
  }

  .area-bullets {
    list-style: none;
    margin: 0 24px;
    padding: 18px 0 22px;
    display: flex;
    flex-direction: column;
    gap: 9px;
    border-top: 1px solid var(--hairline);
  }
  .area-bullets li {
    position: relative;
    padding-left: 20px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--mist-muted);
  }
  .area-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--signal);
    opacity: 0.7;
  }
  .area-bullets :global(a) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .consult-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    margin-top: var(--space-lg);
    padding: 24px 28px;
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    background: var(--forest);
  }
  .consult-cta p {
    font-size: 15px;
    color: var(--mist-muted);
    margin: 0;
  }
  .consult-cta .inline-link { color: var(--signal); }

  .editorial {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .editorial-row {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: var(--space-lg);
    align-items: center;
  }
  .editorial-row--flip .editorial-text { order: 2; }
  .editorial-row--flip .editorial-media { order: 1; }
  .editorial-text h2 {
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--text-strong);
    margin: 0 0 14px;
  }
  .editorial-body {
    font-size: 15.5px;
    line-height: 1.75;
    color: var(--mist-muted);
    max-width: 58ch;
  }
  .editorial-body :global(p) { margin: 0 0 1em; }
  .editorial-body :global(p:last-child) { margin-bottom: 0; }
  .editorial-body :global(a) { color: var(--signal); text-decoration: underline; text-underline-offset: 2px; }
  .editorial-media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 860px) {
    .editorial-row, .editorial-row--flip { grid-template-columns: 1fr; }
    .editorial-row--flip .editorial-text { order: 1; }
    .editorial-row--flip .editorial-media { order: 2; }
    .testimonial-grid { grid-template-columns: 1fr; }
  }

  @media (prefers-reduced-motion: reduce) {
    .area, .area-toggle, .area-collapse { transition: none; }
  }
</style>
