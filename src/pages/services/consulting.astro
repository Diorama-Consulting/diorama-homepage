---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import Footer from '../../components/Footer.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';

const page = await reader.singletons.servicesConsulting.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Consulting — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Fractional CTO/CPTO leadership and pragmatic AI strategy for Boards, Founders and Investors, with a focus on D2C marketplaces.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

const capabilities = page?.capabilities?.length
  ? page.capabilities
  : [
      { title: 'High Level Experience', description: 'Fractional/Interim leadership (CTO, CPTO).' },
      { title: 'Economics Driven', description: 'Pragmatic AI and Data Strategy aligned to P&L.' },
      { title: 'E-commerce', description: 'D2C marketplace optimisation and innovation.' },
      { title: 'Platform Modernisation', description: 'Architecture modernisation without rewrite.' },
      { title: 'Engineering', description: 'Product Engineering team organisation design.' },
      { title: 'Sustainability', description: 'Practical operationalisation of sustainability initiatives.' },
    ];

// Testimonials are entirely optional now — leave the array empty in
// Keystatic until there are real client quotes to show. No placeholder
// content is shown in the meantime.
const testimonials = page?.testimonials ?? [];
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'Consulting'}
    heading={page?.heading || 'Built on decades of experience'}
    subheading={page?.subheading || 'We help create defensible growth, reduce risk and accelerate value creation through:'}
  >
    <div class="card-grid">
      {capabilities.map((capability) => (
        <Card title={capability.title} description={capability.description} />
      ))}
    </div>
  </Section>

  {testimonials.length > 0 && (
    <Section eyebrow={page?.testimonialsEyebrow || 'Testimonials'} heading={page?.testimonialsHeading || 'What people say'}>
      <div class="testimonial-grid">
        {testimonials.map((testimonial) => (
          <TestimonialCard quote={testimonial.quote} name={testimonial.name} role={testimonial.role} />
        ))}
      </div>
    </Section>
  )}

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .card-grid,
  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  @media (max-width: 860px) {
    .card-grid,
    .testimonial-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
