---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Footer from '../../components/Footer.astro';

const charities = (await getCollection('charities')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout
  title="Charities — Diorama Consulting"
  description="Practical Digital and AI strategy support for UK charities, delivered through Trustee and advisory roles."
>
  <Header />

  <Section
    eyebrow="For UK Charities"
    heading="Technology support for mission-led organisations"
    subheading="Alongside commercial advisory, Diorama supports the charity sector directly through Trustee roles — bringing the same pragmatic, P&L-literate approach to mission impact instead of margin."
  >
    <div class="charity-grid">
      {charities.map((charity) => (
        <div class="charity-card">
          {charity.data.logo && (
            typeof charity.data.logo === 'string' ? (
              <img src={charity.data.logo} alt={charity.data.name} class="charity-logo" />
            ) : (
              <Image src={charity.data.logo} alt={charity.data.name} class="charity-logo" width={64} height={64} />
            )
          )}
          <h3>{charity.data.name}</h3>
          <p class="charity-role">{charity.data.role}</p>
          <p class="charity-summary">{charity.data.summary}</p>
          {charity.data.externalUrl && (
            <a href={charity.data.externalUrl} target="_blank" rel="noopener noreferrer" class="charity-link">
              Visit site ↗
            </a>
          )}
        </div>
      ))}
    </div>
  </Section>

  <Footer />
</Layout>

<style>
  .charity-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .charity-card {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 28px;
  }

  .charity-logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    object-fit: contain;
    margin-bottom: 14px;
    background: #fff;
  }

  .charity-card h3 {
    font-size: 1.2rem;
    margin-bottom: 4px;
  }

  .charity-role {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 12px;
  }

  .charity-summary {
    color: var(--mist-muted);
    font-size: 14.5px;
    margin-bottom: 14px;
  }

  .charity-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
    text-decoration: none;
  }

  .charity-link:hover {
    color: var(--mint);
  }

  @media (max-width: 720px) {
    .charity-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
