---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Footer from '../../components/Footer.astro';
import CharityShowcase from '../../components/CharityShowcase.astro';
import FloatingLeaves from '../../components/FloatingLeaves.astro';
import FallingLeaves from '../../components/FallingLeaves.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';

const charityEntries = (await getCollection('charities')).sort(
  (a, b) => a.data.order - b.data.order,
);

// Render each charity's MDX body once here (Content components can't be
// generated inside a child component from plain data — they need
// astro:content's render() at the page level), then hand each one to
// CharityShowcase via a named slot (content-<index>).
const rendered = await Promise.all(charityEntries.map((entry) => render(entry)));

// Astro requires slot names to be static strings, not computed ones — see
// CharityShowcase.astro. Pulling each Content component out into its own
// named binding (up to a bounded max) is the standard workaround.
const Content0 = rendered[0]?.Content;
const Content1 = rendered[1]?.Content;
const Content2 = rendered[2]?.Content;
const Content3 = rendered[3]?.Content;
const Content4 = rendered[4]?.Content;
const Content5 = rendered[5]?.Content;
const Content6 = rendered[6]?.Content;
const Content7 = rendered[7]?.Content;
const Content8 = rendered[8]?.Content;
const Content9 = rendered[9]?.Content;
const Content10 = rendered[10]?.Content;
const Content11 = rendered[11]?.Content;

const charityItems = charityEntries.map((charity) => ({
  name: charity.data.name,
  role: charity.data.role,
  summary: charity.data.summary,
  mission: charity.data.mission,
  logo: resolveImageUrl(charity.data.logo, charity.data.logoUrl),
  heroImage: resolveImageUrl(charity.data.heroImage, charity.data.heroImageUrl),
  focusAreas: charity.data.focusAreas,
  stats: charity.data.stats,
  externalUrl: charity.data.externalUrl,
}));

const page = await reader.singletons.servicesCharities.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Charities — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Practical Digital and AI strategy support for UK charities, delivered through Trustee and advisory roles.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'For UK Charities'}
    heading={page?.heading || 'Technology support for brilliant organisations'}
    subheading={page?.subheading || 'Alongside commercial advisory, Diorama supports the charity sector directly through Trustee roles — bringing the same pragmatic, P&L-literate approach to mission impact instead of margin.'}
  >
    <FloatingLeaves count={5} seed={9} maxOpacity={0.06} />
    <FallingLeaves count={14} seed={17} maxOpacity={0.09} />
    <CharityShowcase charities={charityItems}>
      {Content0 && <Fragment slot="content-0"><Content0 /></Fragment>}
      {Content1 && <Fragment slot="content-1"><Content1 /></Fragment>}
      {Content2 && <Fragment slot="content-2"><Content2 /></Fragment>}
      {Content3 && <Fragment slot="content-3"><Content3 /></Fragment>}
      {Content4 && <Fragment slot="content-4"><Content4 /></Fragment>}
      {Content5 && <Fragment slot="content-5"><Content5 /></Fragment>}
      {Content6 && <Fragment slot="content-6"><Content6 /></Fragment>}
      {Content7 && <Fragment slot="content-7"><Content7 /></Fragment>}
      {Content8 && <Fragment slot="content-8"><Content8 /></Fragment>}
      {Content9 && <Fragment slot="content-9"><Content9 /></Fragment>}
      {Content10 && <Fragment slot="content-10"><Content10 /></Fragment>}
      {Content11 && <Fragment slot="content-11"><Content11 /></Fragment>}
    </CharityShowcase>
  </Section>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>
