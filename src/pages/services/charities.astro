---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import Footer from '../../components/Footer.astro';
import { reader, resolveImageSrc, resolveImageUrl } from '../../lib/keystatic';

const charities = (await getCollection('charities')).sort(
  (a, b) => a.data.order - b.data.order,
);

const page = await reader.singletons.servicesCharities.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Charities — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Practical Digital and AI strategy support for UK charities, delivered through Trustee and advisory roles.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'For UK Charities'}
    heading={page?.heading || 'Technology support for mission-led organisations'}
    subheading={page?.subheading || 'Alongside commercial advisory, Diorama supports the charity sector directly through Trustee roles — bringing the same pragmatic, P&L-literate approach to mission impact instead of margin.'}
  >
    <div class="charity-grid">
      {charities.map((charity) => {
        const logo = resolveImageSrc(charity.data.logo, charity.data.logoUrl);
        return (
          <div class="charity-card">
            {logo && (
              typeof logo === 'string' ? (
                <img src={logo} alt={charity.data.name} class="charity-logo" />
              ) : (
                <Image src={logo} alt={charity.data.name} class="charity-logo" width={64} height={64} />
              )
            )}
            <h3>{charity.data.name}</h3>
            <p class="charity-role">{charity.data.role}</p>
            <p class="charity-summary">{charity.data.summary}</p>
            {charity.data.externalUrl && (
              <a href={charity.data.externalUrl} target="_blank" rel="noopener noreferrer" class="charity-link">
                Visit site ↗
              </a>
            )}
          </div>
        );
      })}
    </div>
  </Section>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .charity-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .charity-card {
    background: var(--forest);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-md);
    padding: 28px;
  }

  .charity-logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    object-fit: contain;
    margin-bottom: 14px;
    background: #fff;
  }

  .charity-card h3 {
    font-size: 1.2rem;
    margin-bottom: 4px;
  }

  .charity-role {
    font-family: var(--font-mono);
    font-size: 11.5px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 12px;
  }

  .charity-summary {
    color: var(--mist-muted);
    font-size: 14.5px;
    margin-bottom: 14px;
  }

  .charity-link {
    font-size: 13px;
    font-weight: 600;
    color: var(--signal);
    text-decoration: none;
  }

  .charity-link:hover {
    color: var(--mint);
  }

  @media (max-width: 720px) {
    .charity-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
