---
import { marked } from 'marked';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Section from '../../components/Section.astro';
import FeatureToggle from '../../components/FeatureToggle.astro';
import HowWeWork from '../../components/HowWeWork.astro';
import CapabilityReveal from '../../components/CapabilityReveal.astro';
import OutcomesBand from '../../components/OutcomesBand.astro';
import FloatingLeaves from '../../components/FloatingLeaves.astro';
import FallingLeaves from '../../components/FallingLeaves.astro';
import Footer from '../../components/Footer.astro';
import SpacerBlank from '../../components/spacers/SpacerBlank.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';
import defaultHeroPhoto from '../../assets/hero/dark-background.jpg';

const page = await reader.singletons.servicesIndex.read();

// The six consulting capability points — relocated here from
// /services/consulting into the animated segment below, still edited via
// the "Services — Consulting" singleton in Keystatic (same field as
// before; only where they're displayed has moved).
const consulting = await reader.singletons.servicesConsulting.read();
const capabilities = consulting?.capabilities?.length
  ? consulting.capabilities
  : [
      { title: 'High Level Experience', description: 'Fractional/Interim leadership (CTO, CPTO).' },
      { title: 'Economics Driven', description: 'Pragmatic AI and Data Strategy aligned to P&L.' },
      { title: 'E-commerce', description: 'D2C marketplace optimisation and innovation.' },
      { title: 'Platform Modernisation', description: 'Architecture modernisation without rewrite.' },
      { title: 'Engineering', description: 'Product Engineering team organisation design.' },
      { title: 'Sustainability', description: 'Practical operationalisation of sustainability initiatives.' },
    ];

// sectionBody is trusted CMS content (Paolo/Mal via Keystatic), not public
// user input, so this mirrors the FAQ page's set:html approach rather than
// sanitising — see pages/about/faq/index.astro for the equivalent
// hand-rolled version of this same trust call. `marked.parse()` runs
// synchronously here because no async extensions are registered.
const sectionHtml = page?.sectionBody ? (marked.parse(page.sectionBody) as string) : '';
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

const pageTitle = page?.seoTitle || `Services — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Fractional CTO/CPTO leadership and AI advisory for D2C marketplaces, plus pro-bono Digital and AI strategy support for UK charities.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);

const tiles = page?.tiles?.length
  ? page.tiles
  : [
      {
        eyebrow: 'For Boards, Founders & Investors',
        title: 'Consulting',
        description:
          'Fractional and interim CTO/CPTO leadership, AI and data strategy aligned to P&L, platform modernisation, and product engineering organisation design — with a particular focus on D2C marketplaces and consumer products.',
        href: '/services/consulting',
        linkText: 'Explore Consulting',
      },
      {
        eyebrow: 'For UK Charities',
        title: 'Charities',
        description:
          'Practical Digital and AI strategy support for the charity sector — helping trustees and leadership teams adopt technology responsibly, on a realistic budget, without disrupting frontline delivery.',
        href: '/services/charities',
        linkText: 'Explore Charity Support',
      },
    ];

const defaultHeroPhotoUrl = (defaultHeroPhoto as unknown as { src: string }).src;
const tileItems = tiles.map((tile) => ({
  title: tile.title,
  description: tile.description,
  href: tile.href,
  linkText: tile.linkText,
  image: resolveImageUrl(tile.image, tile.imageUrl) || defaultHeroPhotoUrl,
}));
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <Section
    eyebrow={page?.eyebrow || 'What we do'}
    heading={page?.heading || 'Two practices, one disciplined approach'}
    subheading={page?.subheading || 'Diorama Consulting brings the same rigour to commercial engagements and charity advisory: clear scope, pragmatic technology choices, and outcomes tied to P&L or mission impact.'}
  >
    <FallingLeaves count={16} seed={13} maxOpacity={0.1} />
    <FeatureToggle groupId="services" items={tileItems} />
  </Section>

  <OutcomesBand showProofStrip={false} />

  <Section eyebrow="How we work" heading="Four steps, every engagement" subheading="Scroll through — the same shape whether it's a six-week fractional CTO sprint or a pro-bono charity project.">
    <div style="position: relative;">
      <FloatingLeaves count={5} seed={4} maxOpacity={0.08} />
      <HowWeWork
        steps={[
          {
            title: 'Discover',
            description: 'Understand the problem, the stakeholders, and the real constraints — technical, commercial, or organisational — before proposing anything.',
          },
          {
            title: 'Design',
            description: "Shape the approach with the client, not for them: agree scope, sequencing, and what success actually looks like before work starts.",
          },
          {
            title: 'Build',
            description: 'Ship in focused increments with visibility throughout — no black-box months, no surprise scope creep.',
          },
          {
            title: 'Embed',
            description: 'Hand over cleanly, measure the impact against what we agreed at the start, and stay reachable after the engagement ends.',
          },
        ]}
      />

      <div class="capabilities-block" id="capabilities">
        <div class="capabilities-intro" data-reveal>
          <h3>{consulting?.capabilitiesHeading || 'What every engagement draws on'}</h3>
          <p>{consulting?.capabilitiesIntro || 'Six capabilities underpin the four steps — the same toolkit, tuned to each engagement.'}</p>
        </div>
        <CapabilityReveal capabilities={capabilities} />
      </div>
    </div>
  </Section>

  <SpacerBlank size="lg" showMarker />

  {sectionHtml && (
    <Section heading={page?.sectionHeading}>
      <div class="markdown-body" set:html={sectionHtml} />
    </Section>
  )}

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  .capabilities-block {
    margin-top: var(--space-xl);
  }

  .capabilities-intro {
    max-width: 560px;
    margin-bottom: var(--space-md);
  }

  .capabilities-intro h3 {
    font-size: clamp(20px, 2.2vw, 26px);
    color: var(--text-strong);
    margin: 0 0 10px;
  }

  .capabilities-intro p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--mist-muted);
    margin: 0;
  }

  /* Markdown section below the tiles. Scoped with :global() because the
     content inside comes from set:html, so Astro's scoping attribute never
     reaches these elements directly. */
  .markdown-body {
    max-width: 720px;
    color: var(--mist-muted);
    font-size: 15.5px;
    line-height: 1.7;
  }

  .markdown-body :global(h1),
  .markdown-body :global(h2),
  .markdown-body :global(h3) {
    color: var(--text-strong);
    margin: 1.6em 0 0.6em;
  }

  .markdown-body :global(h1:first-child),
  .markdown-body :global(h2:first-child),
  .markdown-body :global(h3:first-child) {
    margin-top: 0;
  }

  .markdown-body :global(h2) {
    font-size: 1.4rem;
  }

  .markdown-body :global(h3) {
    font-size: 1.15rem;
  }

  .markdown-body :global(p) {
    margin: 0 0 1em;
  }

  .markdown-body :global(ul),
  .markdown-body :global(ol) {
    margin: 0 0 1em;
    padding-left: 1.3em;
  }

  .markdown-body :global(li) {
    margin-bottom: 0.4em;
  }

  .markdown-body :global(a) {
    color: var(--signal);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .markdown-body :global(a:hover) {
    color: var(--mint);
  }

  .markdown-body :global(strong) {
    color: var(--mist);
  }

  .markdown-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--hairline);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  .markdown-body :global(blockquote) {
    margin: 0 0 1em;
    padding-left: 1em;
    border-left: 2px solid var(--moss);
    color: var(--mist-muted);
    font-style: italic;
  }
</style>