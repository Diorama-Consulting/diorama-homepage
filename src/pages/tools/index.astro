---
// /tools — redesigned around the ToolRack.
//
// Everything shown here is driven by the `projects` collection (labelled
// "Tools" in Keystatic). To add a new tool: deploy its container + Caddy
// route on the droplet, then create one entry in Keystatic (title, tagline,
// summary, category, accent, monogram, live URL) — it appears in the right
// rack automatically, with its own /tools/<slug> page. No code changes.
//
// The collection keeps its internal name `projects` (renaming content
// files was unnecessary risk for zero reader-facing benefit — same
// reasoning as the blog -> insights rename).
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolRack from '../../components/ToolRack.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';

const all = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);

const page = await reader.singletons.projectsIndex.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();

// Split into the two racks; within each, the featured entry (or the first)
// starts open. `open` is per-rack, exactly one true.
function toRack(category: 'application' | 'learning') {
  const entries = all.filter((e) => e.data.category === category);
  const featuredIdx = Math.max(0, entries.findIndex((e) => e.data.featured));
  return entries.map((e, i) => ({
    id: e.id,
    title: e.data.title,
    tagline: e.data.tagline,
    summary: e.data.summary,
    accent: e.data.accent,
    monogram: e.data.monogram,
    status: e.data.status,
    externalUrl: e.data.externalUrl,
    repoUrl: e.data.repoUrl,
    techStack: e.data.techStack,
    heroImage: e.data.heroImage ?? null,
    heroImageUrl: e.data.heroImageUrl ?? null,
    open: i === featuredIdx,
  }));
}

const applications = toRack('application');
const learning = toRack('learning');

const pageTitle = page?.seoTitle || `Tools — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription =
  page?.seoDescription ||
  page?.subheading ||
  'Working applications and interactive learning tools, built by Diorama with AI coding assistants. Every one of them runs live — open any and try it.';
const pageImage =
  resolveImageUrl(page?.seoImage, page?.seoImageUrl) ||
  resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);
---

<Layout title={pageTitle} description={pageDescription} image={pageImage}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <main class="container">
    <section class="page-intro">
      <p class="eyebrow">{page?.eyebrow || 'Building'}</p>
      <h1>{page?.heading || 'Tools'}</h1>
      <p class="subheading">
        {page?.subheading ||
          'Everything here runs live. Working applications Diorama built and actually uses, and interactive tools for demystifying AI, quantum computing and search. Hover a spine to bring it into focus; open any tool and try it.'}
      </p>
    </section>

    {applications.length > 0 && (
      <section class="rack-block">
        <div class="rack-heading">
          <h2>Applications</h2>
          <p>Working products — built with AI coding assistants, running in production on this site.</p>
        </div>
        <ToolRack label="Applications" tools={applications} />
      </section>
    )}

    {learning.length > 0 && (
      <section class="rack-block">
        <div class="rack-heading">
          <h2>Learning tools</h2>
          <p>Interactive introductions to the ideas underneath the applications — no prior technical knowledge assumed.</p>
        </div>
        <ToolRack label="Learning tools" tools={learning} />
      </section>
    )}
  </main>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  main.container {
    padding-top: 56px;
    padding-bottom: 96px;
  }

  .page-intro {
    max-width: 640px;
    margin-bottom: var(--space-lg);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 8px;
  }

  .subheading {
    color: var(--mist-muted);
  }

  .rack-block {
    margin-bottom: var(--space-xl);
  }

  .rack-heading {
    display: flex;
    align-items: baseline;
    gap: 18px;
    margin-bottom: var(--space-sm);
    flex-wrap: wrap;
  }

  .rack-heading h2 {
    font-size: 1.3rem;
    color: var(--text-strong);
    margin: 0;
  }

  .rack-heading p {
    font-size: 14px;
    color: var(--mist-faint);
    margin: 0;
  }
</style>
