---
// /tools/<slug> — now rendered by the ToolPage layout (dark hero band,
// feature grid, launch band). Underlying content collection is still
// called `projects` internally (renaming content files was unnecessary
// risk for zero reader-facing benefit).
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ToolPage from '../../layouts/ToolPage.astro';
import Iframe from '../../components/Iframe.astro';

export async function getStaticPaths() {
  // Restricted tools don't get a public static page at all — they're
  // only reachable through /tools/gated/<slug>?token=... (see that route
  // for the access check). A direct visit to /tools/<restricted-slug>
  // 404s, same as any URL Astro never generated.
  const projects = await getCollection('projects', ({ data }) => !data.draft && !data.restricted);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}

type Props = CollectionEntry<'projects'>;
const project = Astro.props;
const { Content } = await render(project);
---

<ToolPage {...project.data} slug={project.id}>
  <Content components={{ Iframe }} />
</ToolPage>
