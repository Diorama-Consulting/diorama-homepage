---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import BlogCard from '../../components/BlogCard.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { reader, resolveImageUrl } from '../../lib/keystatic';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const [featured, ...rest] = posts;

const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();
const siteSettings = await reader.singletons.siteSettings.read();
const pageImage = resolveImageUrl(siteSettings?.defaultSeoImage, siteSettings?.defaultSeoImageUrl);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Blog — ${siteSettings?.siteName ?? 'Diorama Consulting'}`}
      description={siteSettings?.defaultSeoDescription ?? 'Writing on AI, technology strategy, and the occasional side project.'}
      image={pageImage}
    />
  </head>
  <body>
    <Header
      transparentOverHero={false}
      logoText={headerNav?.logoText}
      links={headerNav?.links}
      ctaText={headerNav?.ctaText}
      ctaHref={headerNav?.ctaHref}
    />
    <main class="container">
      <section class="blog-grid">
        {featured && (
          <div class="featured">
            <BlogCard
              title={featured.data.title}
              excerpt={featured.data.description ?? ''}
              href={`/blog/${featured.id}/`}
              date={featured.data.pubDate.toISOString()}
              image={resolveImageUrl(featured.data.heroImage, featured.data.heroImageUrl)}
            />
          </div>
        )}
        {rest.map((post) => (
          <BlogCard
            title={post.data.title}
            excerpt={post.data.description ?? ''}
            href={`/blog/${post.id}/`}
            date={post.data.pubDate.toISOString()}
            image={resolveImageUrl(post.data.heroImage, post.data.heroImageUrl)}
          />
        ))}
      </section>
    </main>
    <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
  </body>
</html>

<style>
  main.container {
    padding-top: 56px;
    padding-bottom: 80px;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 32px;
  }

  .featured {
    grid-column: 1 / -1;
  }

  .featured :global(.blog-card) {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
  }

  .featured :global(.blog-image) {
    height: 100%;
    min-height: 320px;
  }

  .featured :global(.blog-body) {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .featured :global(h3) {
    font-size: 1.6rem;
  }

  @media (max-width: 720px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .featured :global(.blog-card) {
      grid-template-columns: 1fr;
    }

    .featured :global(.blog-image) {
      min-height: 220px;
    }
  }
</style>
