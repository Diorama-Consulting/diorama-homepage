---
// /legal/terms-of-use — exact supplied wording (12 Oct 2025); only
// structure and links added.
import LegalPage from '../../layouts/LegalPage.astro';

const toc = [
  { id: 'purpose', label: '1. Purpose of the Site' },
  { id: 'changes', label: '2. Changes to these Terms' },
  { id: 'privacy', label: '3. Privacy and Cookies' },
  { id: 'access', label: '4. Access and Availability' },
  { id: 'ip', label: '5. Intellectual Property' },
  { id: 'acceptable-use', label: '6. Acceptable Use' },
  { id: 'user-content', label: '7. User Content and Submissions' },
  { id: 'third-party', label: '8. Third-Party Links and Resources' },
  { id: 'no-advice', label: '9. No Advice or Reliance' },
  { id: 'security', label: '10. Security and Viruses' },
  { id: 'liability', label: '11. Liability' },
  { id: 'indemnity', label: '12. Indemnity' },
  { id: 'termination', label: '13. Suspension and Termination' },
  { id: 'law', label: '14. Governing Law and Jurisdiction' },
  { id: 'contact', label: '15. Contact' },
];
---

<LegalPage
  title="Terms of Use"
  lastUpdated="12 October 2025"
  description="The terms governing your use of the Diorama Consulting website."
  toc={toc}
>
  <section data-reveal>
    <p>These Terms of Use (“Terms”) govern your access to and use of <a href="https://dioramaconsulting.co.uk">https://dioramaconsulting.co.uk</a> (the “Site”), operated by Diorama Consulting Ltd (“we”, “us”, “our”). By using the Site you agree to these Terms. If you do not agree, please do not use the Site.</p>
    <div class="legal-card">
      <p><strong>Company details</strong></p>
      <p>Diorama Consulting Ltd (Company No. 16137029)</p>
      <p>Registered in England &amp; Wales</p>
      <p>Registered office: 71–75 Shelton Street, Covent Garden, London, WC2H 9JQ, UK</p>
      <p><a href="/contact">Contact Diorama Consulting</a>.</p>
    </div>
  </section>

  <section id="purpose" data-reveal>
    <h2>1. Purpose of the Site</h2>
    <p>The Site provides information about our services, articles, resources, and contact details. It is informational only and does not constitute advice. Any engagement for services will be subject to a separate written agreement.</p>
