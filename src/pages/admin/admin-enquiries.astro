---
// /admin/enquiries — the front-end view onto the contact-service database.
//
// Access: token-gated. First visit with ?key=<CONTACT_ADMIN_TOKEN> sets a
// cookie (30 days) and redirects to the clean URL; anything without a valid
// token gets a 404 (not a login page — no need to advertise this exists).
// The token is the same ADMIN_TOKEN the contact-service checks; this page
// presents it server-side as X-Admin-Token, so it never reaches the browser
// beyond the cookie on the owner's own machine.
//
// Actions (mark handled / archive / reopen) POST back to this same page,
// which PATCHes the service and redirects — no client JS needed at all.
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Badge from '../../components/Badge.astro';
import { reader } from '../../lib/keystatic';
import { secret } from '../../lib/env';

export const prerender = false;

const ADMIN_TOKEN = secret('CONTACT_ADMIN_TOKEN') || '';
const SERVICE_URL = secret('CONTACT_SERVICE_URL') || 'http://contact-service:8104';
const COOKIE = 'diorama_admin';

// ---- Auth ----------------------------------------------------------------
const url = Astro.url;
const keyParam = url.searchParams.get('key');
const cookieToken = Astro.cookies.get(COOKIE)?.value;

if (ADMIN_TOKEN && keyParam === ADMIN_TOKEN) {
  Astro.cookies.set(COOKIE, ADMIN_TOKEN, {
    path: '/admin',
    httpOnly: true,
    secure: true,
    sameSite: 'strict',
    maxAge: 60 * 60 * 24 * 30,
  });
  return Astro.redirect('/admin/enquiries');
}

if (!ADMIN_TOKEN || cookieToken !== ADMIN_TOKEN) {
  return new Response('Not found', { status: 404 });
}

// ---- Actions (status changes) -------------------------------------------
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const id = String(form.get('id') ?? '');
  const status = String(form.get('status') ?? '');
  if (id && ['new', 'handled', 'archived'].includes(status)) {
    try {
      await fetch(`${SERVICE_URL}/api/submissions/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-Admin-Token': ADMIN_TOKEN },
        body: JSON.stringify({ status }),
        signal: AbortSignal.timeout(10_000),
      });
    } catch (e) {
      console.error('enquiries: status update failed', e);
    }
  }
  return Astro.redirect(`/admin/enquiries${url.searchParams.get('filter') ? `?filter=${url.searchParams.get('filter')}` : ''}`);
}

// ---- Data ----------------------------------------------------------------
const filter = url.searchParams.get('filter') || '';
let submissions: Array<Record<string, unknown>> = [];
let loadError = false;
try {
  const query = ['new', 'handled', 'archived'].includes(filter) ? `?status=${filter}` : '';
  const res = await fetch(`${SERVICE_URL}/api/submissions${query}`, {
    headers: { 'X-Admin-Token': ADMIN_TOKEN },
    signal: AbortSignal.timeout(10_000),
  });
  if (!res.ok) throw new Error(`service responded ${res.status}`);
  submissions = (await res.json())?.submissions ?? [];
} catch (e) {
  console.error('enquiries: failed to load submissions', e);
  loadError = true;
}

const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();

const fmt = (iso: unknown) =>
  typeof iso === 'string'
    ? new Date(iso).toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' })
    : '';
const counts = {
  new: submissions.filter((s) => s.status === 'new').length,
};
---

<Layout title="Enquiries — Admin" description="Contact form submissions" showChatWidget={false}>
  <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

  <main class="container">
    <div class="admin-head">
      <div>
        <p class="eyebrow">Admin</p>
        <h1>Enquiries</h1>
      </div>
      <div class="head-right">
        <nav class="admin-nav" aria-label="Admin pages">
          <a href="/admin/dashboard">Dashboard</a>
          <a class="active" href="/admin/enquiries">Enquiries</a>
        </nav>
        <nav class="filters" aria-label="Filter by status">
        <a class:list={[{ active: !filter }]} href="/admin/enquiries">All</a>
        <a class:list={[{ active: filter === 'new' }]} href="/admin/enquiries?filter=new">New{!filter && counts.new > 0 ? ` (${counts.new})` : ''}</a>
        <a class:list={[{ active: filter === 'handled' }]} href="/admin/enquiries?filter=handled">Handled</a>
        <a class:list={[{ active: filter === 'archived' }]} href="/admin/enquiries?filter=archived">Archived</a>
        </nav>
      </div>
    </div>

    {loadError && (
      <p class="notice">Couldn't reach the contact service — check that the <code>contact-service</code> container is running.</p>
    )}

    {!loadError && submissions.length === 0 && (
      <p class="notice">No enquiries {filter ? `with status "${filter}"` : 'yet'}. When someone uses the contact form, it appears here.</p>
    )}

    <div class="cards">
      {submissions.map((s) => (
        <article class:list={['enquiry', `enquiry--${s.status}`]}>
          <header>
            <div class="who">
              <strong>{s.name}</strong>
              <a href={`mailto:${s.email}`}>{s.email}</a>
            </div>
            <div class="meta">
              <Badge variant={s.status === 'new' ? 'accent' : 'outline'}>{s.status}</Badge>
              <time>{fmt(s.submitted_at)}</time>
            </div>
          </header>
          <p class="message">{s.message}</p>
          <footer>
            <span class="delivery" title="notification to you / confirmation to them">
              emails: {s.notify_sent ? '✓' : '✗'} owner · {s.confirm_sent ? '✓' : '✗'} customer
            </span>
            <div class="actions">
              {s.status !== 'handled' && (
                <form method="POST"><input type="hidden" name="id" value={s.id} /><input type="hidden" name="status" value="handled" /><button>Mark handled</button></form>
              )}
              {s.status !== 'archived' && (
                <form method="POST"><input type="hidden" name="id" value={s.id} /><input type="hidden" name="status" value="archived" /><button>Archive</button></form>
              )}
              {s.status !== 'new' && (
                <form method="POST"><input type="hidden" name="id" value={s.id} /><input type="hidden" name="status" value="new" /><button>Reopen</button></form>
              )}
              <a class="reply" href={`mailto:${s.email}?subject=${encodeURIComponent('Re: your enquiry to Diorama Consulting')}`}>Reply</a>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </main>

  <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
</Layout>

<style>
  main.container { padding-top: 56px; padding-bottom: 96px; }

  .admin-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: var(--space-md);
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--signal);
    margin-bottom: 8px;
  }

  .head-right { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
  .admin-nav { display: flex; gap: 6px; }
  .admin-nav a {
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    color: var(--mist-muted);
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
  }
  .admin-nav a.active { background: var(--signal); border-color: var(--signal); color: hsl(0 0% 100%); }
  .admin-nav a:not(.active):hover { border-color: var(--hairline-hover); background: var(--charcoal-soft); }

  .filters { display: flex; gap: 6px; }
  .filters a {
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    color: var(--mist-muted);
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid var(--hairline);
  }
  .filters a.active { background: var(--signal); border-color: var(--signal); color: hsl(0 0% 100%); }
  .filters a:not(.active):hover { border-color: var(--hairline-hover); background: var(--charcoal-soft); }

  .notice {
    color: var(--mist-muted);
    border: 1px dashed var(--hairline);
    border-radius: var(--radius-md);
    padding: 22px;
  }
  .notice code { font-family: var(--font-mono); font-size: 0.9em; }

  .cards { display: flex; flex-direction: column; gap: 14px; }

  .enquiry {
    border: 1px solid var(--hairline);
    border-left: 3px solid var(--pine);
    border-radius: var(--radius-md);
    background: var(--forest);
    padding: 18px 22px;
  }
  .enquiry--new { border-left-color: var(--signal); }

  .enquiry header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .who { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .who strong { color: var(--text-strong); }
  .who a { color: var(--signal); text-decoration: none; font-size: 14px; }
  .meta { display: flex; align-items: center; gap: 12px; }
  .meta time { font-family: var(--font-mono); font-size: 12px; color: var(--mist-faint); }

  .message {
    white-space: pre-wrap;
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--mist);
    margin: 0 0 14px;
  }

  .enquiry footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .delivery { font-family: var(--font-mono); font-size: 11.5px; color: var(--mist-faint); }
  .actions { display: flex; gap: 8px; align-items: center; }
  .actions form { margin: 0; }
  .actions button,
  .actions .reply {
    font-size: 13px;
    font-weight: 600;
    padding: 7px 13px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--mist);
    cursor: pointer;
    text-decoration: none;
    font-family: var(--font-body);
  }
  .actions button:hover,
  .actions .reply:hover { border-color: var(--hairline-hover); background: var(--charcoal-soft); }
  .actions .reply { color: var(--signal); }
</style>
