---
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
  description?: string;
  /** Already-unwrapped plain URL string — see lib/keystatic.ts resolveImageUrl(). */
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description = 'Built with Astro.', image, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} jsonLd={jsonLd} />
  </head>
  <body>
    <slot />
  </body>
</html>
