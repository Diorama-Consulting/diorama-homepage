---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import PostHog from '../components/posthog.astro';
import SiteBanner from '../components/SiteBanner.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { reader, resolveImageUrl } from '../lib/keystatic';

type Props = CollectionEntry<'blog'>['data'] & { slug: string };

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    heroImageUrl: heroImageUrlField,
    audioFile,
    audioUrl,
    audioTitle,
    link,
    seoTitle,
    seoDescription,
    slug,
} = Astro.props;

// Audio narration — Keystatic upload (served from /audio/) takes
// precedence over an external URL, mirroring the image-pair convention.
const audioSrc = audioFile || audioUrl || undefined;
const audioLabel = audioTitle || 'Listen to this article';

// heroImage (local upload) and heroImageUrl (external URL alternative) are
// two separate, independent fields — see lib/keystatic.ts for why this
// replaced an earlier single-field conditional design.
const heroImageUrl = resolveImageUrl(heroImage, heroImageUrlField);

// `link` is genuinely optional — only posts cross-posted from Substack set
// it. Everything below that depends on it is gated behind `hasSourceLink` so
// natively-written posts don't show a "originally published on Substack"
// banner that isn't true, and so we never call `new URL(undefined)`.
const hasSourceLink = Boolean(link);

let subscribeUrl: string | undefined;
if (hasSourceLink) {
    try {
        subscribeUrl = `${new URL(link).origin}/subscribe`;
    } catch {
        // link wasn't a valid absolute URL — fall back to linking the post itself
        subscribeUrl = link;
    }
}

const siteSettings = await reader.singletons.siteSettings.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();

const pageTitle = seoTitle || `${title} — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = seoDescription || description || siteSettings?.defaultSeoDescription || '';

const articleJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description: pageDescription,
    image: heroImageUrl ? [heroImageUrl] : undefined,
    datePublished: pubDate?.toISOString?.() ?? pubDate,
    dateModified: (updatedDate ?? pubDate)?.toISOString?.() ?? updatedDate ?? pubDate,
    author: siteSettings?.founderName
        ? { '@type': 'Person', name: siteSettings.founderName }
        : undefined,
    publisher: siteSettings?.legalName
        ? { '@type': 'Organization', name: siteSettings.legalName }
        : undefined,
    mainEntityOfPage: { '@type': 'WebPage', '@id': Astro.url.toString() },
};
---

<html lang="en">
    <head>
        <BaseHead title={pageTitle} description={pageDescription} image={heroImageUrl} jsonLd={articleJsonLd} />
        <PostHog />
        <style>
            main {
                width: 100%;
                margin: 0;
            }

            .hero-container {
                position: relative;
                width: 100%;
                height: 55vh;
                min-height: 400px;
                background-color: var(--forest);
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                display: flex;
                align-items: flex-end;
                overflow: hidden;
            }

            .hero-scrim {
                position: absolute;
                inset: 0;
                z-index: 2;
                background: linear-gradient(
                    to top,
                    hsl(var(--hue-green) 30% 9% / 1) 0%,
                    hsl(var(--hue-green) 30% 9% / 0.6) 40%,
                    transparent 100%
                );
            }

            .hero-content {
                position: relative;
                z-index: 3;
                width: 960px;
                max-width: calc(100% - 2em);
                margin: 0 auto;
                padding-bottom: 3rem;
                color: var(--ink-text);
            }

            .hero-content h1 {
                font-size: 3rem;
                margin: 0.2em 0;
                line-height: 1.1;
                color: var(--ink-text);
            }

            .date {
                font-family: var(--font-mono, monospace);
                font-size: 0.9rem;
                color: var(--ink-accent);
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            .last-updated-on {
                font-style: italic;
                color: var(--ink-text-muted);
                margin-top: 0.25rem;
            }

            .prose {
                width: 960px;
                max-width: calc(100% - 2em);
                margin: 3rem auto;
                color: var(--mist);
            }

            /* --- Audio narration dock ---
               Wide screens: a compact card pinned to the LEFT gutter that
               stays put while you scroll (position: fixed). Narrower
               screens (no spare gutter beside the 960px prose column): it
               sits inline at the top of the article instead. Same DOM
               node, purely CSS repositioning. --- */
            .audio-dock {
                background: var(--forest);
                border: 1px solid var(--hairline);
                border-radius: var(--radius-md);
                padding: 14px 16px;
                box-shadow: var(--shadow-sm);
                margin-bottom: 2rem;
            }

            @media (min-width: 1420px) {
                .audio-dock {
                    position: fixed;
                    left: 24px;
                    top: 170px;
                    width: 200px;
                    margin-bottom: 0;
                    z-index: 30;
                }
            }

            .audio-dock-head {
                display: flex;
                align-items: center;
                gap: 8px;
                margin-bottom: 10px;
            }

            .audio-dock-icon {
                display: flex;
                color: var(--signal);
            }

            .audio-dock-label {
                font-family: var(--font-mono);
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                color: var(--mist-muted);
                line-height: 1.3;
            }

            .audio-dock-controls {
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .audio-play {
                flex-shrink: 0;
                width: 38px;
                height: 38px;
                border-radius: 50%;
                border: none;
                background: var(--signal);
                color: var(--canopy);
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                transition: background 0.2s ease, transform 0.2s ease;
            }
            .audio-play:hover {
                background: var(--mint);
                transform: scale(1.05);
            }
            .audio-play svg {
                display: block;
            }

            .audio-timeline {
                flex: 1;
                min-width: 0;
            }

            #audio-seek {
                width: 100%;
                appearance: none;
                -webkit-appearance: none;
                height: 4px;
                border-radius: 999px;
                background: linear-gradient(
                    to right,
                    var(--signal) 0%,
                    var(--signal) var(--audio-progress, 0%),
                    var(--hairline-hover) var(--audio-progress, 0%),
                    var(--hairline-hover) 100%
                );
                cursor: pointer;
                outline-offset: 3px;
            }
            #audio-seek::-webkit-slider-thumb {
                appearance: none;
                -webkit-appearance: none;
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: var(--signal);
                border: 2px solid var(--canopy);
                box-shadow: 0 1px 4px rgb(0 0 0 / 0.25);
            }
            #audio-seek::-moz-range-thumb {
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: var(--signal);
                border: 2px solid var(--canopy);
                box-shadow: 0 1px 4px rgb(0 0 0 / 0.25);
            }

            .audio-times {
                display: flex;
                justify-content: space-between;
                font-family: var(--font-mono);
                font-size: 10.5px;
                color: var(--mist-faint);
                margin-top: 4px;
            }

            /* Stack the pinned variant vertically — it's narrow. */
            @media (min-width: 1420px) {
                .audio-dock-controls {
                    flex-direction: column;
                    align-items: stretch;
                    gap: 10px;
                }
                .audio-play {
                    align-self: center;
                }
            }

            /* --- Read-on-Substack banner --- */
            .source-banner {
                display: flex;
                align-items: center;
                gap: 0.6rem;
                margin-bottom: 2rem;
                padding: 12px 18px;
                border: 1px solid var(--hairline);
                border-radius: var(--radius-sm, 8px);
                background: var(--charcoal-soft);
                font-family: var(--font-mono, monospace);
                font-size: 0.85rem;
                color: var(--mist-muted);
            }
            .source-banner-icon {
                color: var(--mint);
                font-size: 1rem;
            }
            .source-banner a {
                color: var(--signal);
                text-decoration: underline;
                text-decoration-color: rgba(46, 204, 113, 0.4);
            }
            .source-banner a:hover {
                color: var(--mint);
            }

            /* --- Floating action bar: tracks scroll via position: fixed --- */
            .floating-actions {
                position: fixed;
                top: 100px;
                left: 0;
                right: 0;
                z-index: 40;
                display: flex;
                justify-content: space-between;
                padding-inline: 24px;
                pointer-events: none; /* lets clicks pass through the empty middle */
            }

            .floating-btn {
                pointer-events: auto;
                display: flex;
                align-items: center;
                gap: 0.5rem;
                border-radius: var(--radius-sm, 8px);
                padding: 8px 16px;
                font-size: 0.9rem;
                text-decoration: none;
                cursor: pointer;
                backdrop-filter: blur(8px);
                transition: color 0.2s, border-color 0.2s, background-color 0.2s;
            }

            .back-btn {
                background: hsl(var(--hue-green) 30% 9% / 0.8);
                color: var(--ink-text);
                border: 1px solid var(--ink-border);
            }
            .back-btn:hover {
                color: var(--ink-accent);
                border-color: var(--ink-accent);
            }

            .subscribe-btn {
                background: var(--signal);
                color: var(--canopy);
                font-weight: 600;
                border: 1px solid var(--signal);
            }
            .subscribe-btn:hover {
                background: var(--mint);
                border-color: var(--mint);
            }

            @media (max-width: 720px) {
                .hero-content h1 {
                    font-size: 2rem;
                }
                .hero-container {
                    height: 45vh;
                }
                .floating-actions {
                    top: 84px;
                    padding-inline: 16px;
                }
                .floating-btn {
                    padding: 7px 12px;
                    font-size: 0.82rem;
                }
            }
        </style>
    </head>

    <body>
        <SiteBanner />
        <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

        <div class="floating-actions">
            <button id="back-btn" class="floating-btn back-btn" style="display: none;">
                &larr; Go back
            </button>
            {hasSourceLink && (
                <a
                    class="floating-btn subscribe-btn"
                    href={subscribeUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Subscribe on Substack
                </a>
            )}
        </div>

        <main>
            <article>
                <div
                    class="hero-container"
                    style={heroImageUrl ? `background-image: url('${heroImageUrl}');` : ''}
                >
                    <div class="hero-scrim"></div>

                    <div class="hero-content">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                            {updatedDate && (
                                <div class="last-updated-on">
                                    Updated <FormattedDate date={updatedDate} />
                                </div>
                            )}
                        </div>
                        <h1>{title}</h1>
                    </div>
                </div>

                <div class="prose">
                    {audioSrc && (
                        <aside class="audio-dock" id="audio-dock" aria-label="Audio version of this article">
                            <div class="audio-dock-head">
                                <span class="audio-dock-icon" aria-hidden="true">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M3 18v-6a9 9 0 0 1 18 0v6" />
                                        <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z" />
                                    </svg>
                                </span>
                                <span class="audio-dock-label">{audioLabel}</span>
                            </div>
                            <div class="audio-dock-controls">
                                <button type="button" id="audio-play" class="audio-play" aria-label="Play audio">
                                    <svg id="audio-icon-play" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
                                    <svg id="audio-icon-pause" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none"><path d="M6 4h4v16H6zM14 4h4v16h-4z" /></svg>
                                </button>
                                <div class="audio-timeline">
                                    <input type="range" id="audio-seek" min="0" max="100" step="0.1" value="0" aria-label="Seek" />
                                    <div class="audio-times">
                                        <span id="audio-current">0:00</span>
                                        <span id="audio-duration">–:––</span>
                                    </div>
                                </div>
                            </div>
                            <audio id="audio-el" src={audioSrc} preload="metadata"></audio>
                        </aside>
                    )}

                    {hasSourceLink && (
                        <div class="source-banner">
                            <span class="source-banner-icon" aria-hidden="true">↗</span>
                            <span>
                                Originally published on Substack ·
                                {' '}
                                <a href={link} target="_blank" rel="noopener noreferrer">
                                    Read the original article
                                </a>
                            </span>
                        </div>
                    )}

                    <slot />
                </div>
            </article>
        </main>

        <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />

        <script>
            // --- Audio narration player ---
            (() => {
                const audio = document.getElementById('audio-el') as HTMLAudioElement | null;
                const playBtn = document.getElementById('audio-play');
                const iconPlay = document.getElementById('audio-icon-play');
                const iconPause = document.getElementById('audio-icon-pause');
                const seek = document.getElementById('audio-seek') as HTMLInputElement | null;
                const current = document.getElementById('audio-current');
                const duration = document.getElementById('audio-duration');
                if (!audio || !playBtn || !seek || !current || !duration || !iconPlay || !iconPause) return;

                const fmt = (s: number) => {
                    if (!isFinite(s)) return '–:––';
                    const m = Math.floor(s / 60);
                    const sec = Math.floor(s % 60);
                    return `${m}:${String(sec).padStart(2, '0')}`;
                };

                const setIcon = (playing: boolean) => {
                    iconPlay.style.display = playing ? 'none' : '';
                    iconPause.style.display = playing ? '' : 'none';
                    playBtn.setAttribute('aria-label', playing ? 'Pause audio' : 'Play audio');
                };

                playBtn.addEventListener('click', () => {
                    if (audio.paused) audio.play();
                    else audio.pause();
                });
                audio.addEventListener('play', () => setIcon(true));
                audio.addEventListener('pause', () => setIcon(false));
                audio.addEventListener('ended', () => setIcon(false));

                audio.addEventListener('loadedmetadata', () => {
                    duration.textContent = fmt(audio.duration);
                });

                let seeking = false;
                const paint = () => {
                    const pct = audio.duration ? (audio.currentTime / audio.duration) * 100 : 0;
                    if (!seeking) seek.value = String(pct);
                    seek.style.setProperty('--audio-progress', `${pct}%`);
                    current.textContent = fmt(audio.currentTime);
                };
                audio.addEventListener('timeupdate', paint);

                seek.addEventListener('input', () => {
                    seeking = true;
                    if (audio.duration) {
                        const t = (Number(seek.value) / 100) * audio.duration;
                        current.textContent = fmt(t);
                        seek.style.setProperty('--audio-progress', `${seek.value}%`);
                    }
                });
                seek.addEventListener('change', () => {
                    if (audio.duration) audio.currentTime = (Number(seek.value) / 100) * audio.duration;
                    seeking = false;
                });
            })();

            document.addEventListener('DOMContentLoaded', () => {
                const backBtn = document.getElementById('back-btn');
                if (backBtn && history.length > 1) {
                    backBtn.style.display = 'flex';
                    backBtn.addEventListener('click', () => history.back());
                }
            });
        </script>
        <script is:inline define:vars={{ postSlug: slug, postTitle: title }}>
          window.posthog?.capture('blog_post_viewed', {
            post_slug: postSlug,
            post_title: postTitle,
          });
        </script>
    </body>
</html>