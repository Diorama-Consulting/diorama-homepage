---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Badge from '../components/Badge.astro';
import SiteBanner from '../components/SiteBanner.astro';
import { reader, resolveImageSrc, resolveImageUrl } from '../lib/keystatic';

type Props = CollectionEntry<'projects'>['data'] & { slug: string };

const {
  title,
  summary,
  heroImage,
  heroImageUrl: heroImageUrlField,
  status,
  externalUrl,
  repoUrl,
  seoTitle,
  seoDescription,
  slug,
} = Astro.props;

const statusVariant = status === 'live' ? 'accent' : status === 'in-progress' ? 'outline' : 'default';

const resolvedHeroImage = resolveImageSrc(heroImage, heroImageUrlField);
const heroImageUrl = resolveImageUrl(heroImage, heroImageUrlField);

const siteSettings = await reader.singletons.siteSettings.read();
const headerNav = await reader.singletons.headerNav.read();
const footerNav = await reader.singletons.footerNav.read();

const pageTitle = seoTitle || `${title} — ${siteSettings?.siteName ?? 'Diorama Consulting'}`;
const pageDescription = seoDescription || summary;

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: title,
  description: pageDescription,
  image: heroImageUrl ? [heroImageUrl] : undefined,
  url: Astro.url.toString(),
  creator: siteSettings?.founderName
    ? { '@type': 'Person', name: siteSettings.founderName }
    : undefined,
};
---

<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} image={heroImageUrl} jsonLd={projectJsonLd} />
    <style>
      .hero-container {
        position: relative;
        width: 100%;
        height: 45vh;
        min-height: 320px;
        background-color: var(--forest);
        background-size: cover;
        background-position: center;
        overflow: hidden;
      }

      .hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .prose {
        width: 860px;
        max-width: calc(100% - 2em);
        margin: 0 auto;
        padding: 3rem 0;
        color: var(--mist);
      }

      .project-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.2rem;
      }

      .project-actions {
        display: flex;
        gap: 12px;
        margin-top: 2rem;
        flex-wrap: wrap;
      }

      .project-actions a {
        font-size: 14px;
        font-weight: 600;
        color: var(--signal);
        text-decoration: none;
        border: 1px solid var(--hairline);
        border-radius: var(--radius-sm);
        padding: 10px 18px;
      }

      .project-actions a:hover {
        border-color: var(--signal);
        color: var(--mint);
      }

      .prose h1 {
        font-size: 2.4rem;
        margin-bottom: 0.6rem;
      }

      .prose :global(h2) {
        margin-top: 2rem;
      }

      .prose :global(p) {
        color: var(--mist);
        line-height: 1.7;
      }

      .prose :global(img) {
        border-radius: var(--radius-md);
        margin: 1.5rem 0;
      }
    </style>
  </head>

  <body>
    <SiteBanner />
    <Header logoText={headerNav?.logoText} links={headerNav?.links} ctaText={headerNav?.ctaText} ctaHref={headerNav?.ctaHref} />

    <main>
      <article>
        {resolvedHeroImage && (
          <div class="hero-container">
            {typeof resolvedHeroImage === 'string' ? (
              <img src={resolvedHeroImage} alt="" class="hero-image" />
            ) : (
              <Image src={resolvedHeroImage} alt="" class="hero-image" width={1600} height={720} />
            )}
          </div>
        )}

        <div class="prose">
          <div class="project-meta">
            <Badge variant={statusVariant}>{status}</Badge>
          </div>
          <h1>{title}</h1>
          <p>{summary}</p>

          <slot />

          <div class="project-actions">
            {externalUrl && (
              <a href={externalUrl} target="_blank" rel="noopener noreferrer">Try it ↗</a>
            )}
            {repoUrl && (
              <a href={repoUrl} target="_blank" rel="noopener noreferrer">Source code ↗</a>
            )}
          </div>
        </div>
      </article>
    </main>

    <Footer brandBlurb={footerNav?.brandBlurb} groups={footerNav?.groups} legalLine={footerNav?.legalLine} />
  </body>
</html>
